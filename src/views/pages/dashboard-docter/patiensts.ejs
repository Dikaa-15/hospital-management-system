<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <% if (typeof baseHref === 'string' && baseHref) { %>
    <base href="<%= baseHref %>">
    <% } %>
    <title>Patients Management - MedCore HMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        'jakarta': ['Plus Jakarta Sans', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        :root {
            --bg: #f8fafc;
            --bg-card: #ffffff;
            --fg: #0f172a;
            --fg-muted: #64748b;
            --accent: #4ade80;
            --accent-soft: rgba(74, 222, 128, 0.12);
            --border: #e2e8f0;
            --teal: #2dd4bf;
            --navy: #1e3a5f;
        }

        * {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        body {
            background: var(--bg);
            color: var(--fg);
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(100%);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @keyframes slideOutRight {
            from {
                opacity: 1;
                transform: translateX(0);
            }
            to {
                opacity: 0;
                transform: translateX(100%);
            }
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        @keyframes pulse-dot {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.2); opacity: 0.7; }
        }

        .animate-fade-in-up {
            animation: fadeInUp 0.6s ease-out forwards;
        }

        .animate-slide-in-right {
            animation: slideInRight 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        .animate-slide-out-right {
            animation: slideOutRight 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        .animate-fade-in {
            animation: fadeIn 0.3s ease-out forwards;
        }

        .stagger-1 { animation-delay: 0.05s; opacity: 0; }
        .stagger-2 { animation-delay: 0.1s; opacity: 0; }
        .stagger-3 { animation-delay: 0.15s; opacity: 0; }
        .stagger-4 { animation-delay: 0.2s; opacity: 0; }
        .stagger-5 { animation-delay: 0.25s; opacity: 0; }

        @media (prefers-reduced-motion: reduce) {
            .animate-fade-in-up,
            .animate-slide-in-right,
            .animate-slide-out-right,
            .animate-fade-in {
                animation: none;
                opacity: 1;
                transform: none;
            }
        }

        .nav-item {
            position: relative;
            transition: all 0.2s ease;
        }

        .nav-item::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 3px;
            height: 0;
            background: var(--accent);
            border-radius: 0 2px 2px 0;
            transition: height 0.2s ease;
        }

        .nav-item.active::before,
        .nav-item:hover::before {
            height: 24px;
        }

        .nav-item.active {
            background: var(--accent-soft);
            color: #16a34a;
        }

        .table-row {
            transition: all 0.15s ease;
            cursor: pointer;
        }

        .table-row:hover {
            background: rgba(74, 222, 128, 0.05);
        }

        .table-row.selected {
            background: rgba(74, 222, 128, 0.1);
            border-left: 3px solid var(--accent);
        }

        .btn-primary {
            background: var(--accent);
            color: #15803d;
            transition: all 0.2s ease;
        }

        .btn-primary:hover {
            background: #22c55e;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(74, 222, 128, 0.3);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        .btn-secondary {
            background: white;
            border: 1px solid var(--border);
            color: var(--fg);
            transition: all 0.2s ease;
        }

        .btn-secondary:hover {
            border-color: var(--accent);
            background: rgba(74, 222, 128, 0.05);
        }

        .focus-ring:focus {
            outline: none;
            box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.3);
        }

        .search-input::placeholder {
            color: #94a3b8;
        }

        .sparkline-container {
            display: flex;
            align-items: flex-end;
            gap: 2px;
            height: 32px;
        }

        .sparkline-bar {
            width: 4px;
            border-radius: 2px;
            transition: all 0.2s ease;
        }

        .sparkline-bar:hover {
            filter: brightness(1.1);
        }

        .overlay {
            background: rgba(15, 23, 42, 0.4);
            backdrop-filter: blur(4px);
        }

        .filter-dropdown {
            transform-origin: top right;
        }

        .pulse-dot {
            animation: pulse-dot 2s ease-in-out infinite;
        }

        .vital-card {
            transition: all 0.2s ease;
        }

        .vital-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
        }

        .status-badge {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.02em;
        }

        .sidebar-item {
            transition: all 0.2s ease;
        }

        .sidebar-item:hover {
            background: rgba(74, 222, 128, 0.08);
        }

        .hms-swal-popup {
            border-radius: 1rem;
            border: 1px solid #e2e8f0;
            box-shadow: 0 20px 50px rgba(15, 23, 42, 0.14);
            padding: 0;
            overflow: hidden;
        }

        .hms-swal-title {
            font-size: 1.125rem;
            font-weight: 700;
            color: #0f172a;
            margin: 0;
            padding: 1rem 1.25rem;
            border-bottom: 1px solid #f1f5f9;
            text-align: left;
        }

        .hms-swal-html {
            margin: 0;
            padding: 1rem 1.25rem 0.5rem 1.25rem;
            text-align: left;
        }

        .hms-swal-actions {
            margin: 0;
            padding: 1rem 1.25rem 1.25rem 1.25rem;
            gap: 0.5rem;
            justify-content: flex-end;
            width: 100%;
        }

        .hms-swal-confirm {
            background: #4ade80;
            color: #166534;
            border: 0;
            border-radius: 0.75rem;
            font-size: 0.875rem;
            font-weight: 700;
            padding: 0.625rem 1rem;
        }

        .hms-swal-cancel {
            background: #ffffff;
            color: #334155;
            border: 1px solid #e2e8f0;
            border-radius: 0.75rem;
            font-size: 0.875rem;
            font-weight: 600;
            padding: 0.625rem 1rem;
        }

        .hms-swal-input {
            width: 100%;
            border: 1px solid #e2e8f0;
            border-radius: 0.75rem;
            padding: 0.625rem 0.75rem;
            font-size: 0.875rem;
            color: #0f172a;
            background: #ffffff;
        }

        .hms-swal-input:focus {
            outline: none;
            border-color: #4ade80;
            box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.2);
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen">
    <%
      const doctorName = user?.fullName || [user?.first_name, user?.last_name].filter(Boolean).join(' ').trim() || 'Doctor';
      const doctorRole = user?.role || 'doctor';
      const doctorInitials = doctorName.split(' ').map((s) => s.charAt(0)).join('').slice(0, 2).toUpperCase() || 'DR';
    %>
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="w-20 lg:w-64 bg-white border-r border-slate-200 flex flex-col fixed h-full z-30">
            <!-- Logo -->
            <div class="p-4 lg:p-6 border-b border-slate-200">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-green-400 flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-green-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                        </svg>
                    </div>
                    <span class="hidden lg:block text-lg font-bold text-slate-900">MedCore</span>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 p-3 lg:p-4 space-y-1">
                <a href="/dashboard" class="nav-item flex items-center gap-3 px-3 py-3 rounded-xl text-slate-600 hover:bg-green-50 focus-ring" aria-label="Dashboard">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                    </svg>
                    <span class="hidden lg:block font-medium">Dashboard</span>
                </a>
                <a href="/doctor/patients" class="nav-item active flex items-center gap-3 px-3 py-3 rounded-xl text-slate-600 hover:bg-green-50 focus-ring" aria-label="Patients" aria-current="page">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                    <span class="hidden lg:block font-medium">Patients</span>
                </a>
                <a href="/doctor/appointments" class="nav-item flex items-center gap-3 px-3 py-3 rounded-xl text-slate-600 hover:bg-green-50 focus-ring" aria-label="Appointments">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <span class="hidden lg:block font-medium">Appointments</span>
                </a>
                <a href="/doctor/schedules" class="nav-item flex items-center gap-3 px-3 py-3 rounded-xl text-slate-600 hover:bg-green-50 focus-ring" aria-label="Schedule">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <span class="hidden lg:block font-medium">Schedule</span>
                </a>
                <a href="/doctor/reports" class="nav-item flex items-center gap-3 px-3 py-3 rounded-xl text-slate-600 hover:bg-green-50 focus-ring" aria-label="Reports">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    <span class="hidden lg:block font-medium">Reports</span>
                </a>
                <a href="/templates/dashboard-docter/settings" class="nav-item flex items-center gap-3 px-3 py-3 rounded-xl text-slate-600 hover:bg-green-50 focus-ring" aria-label="Settings">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <span class="hidden lg:block font-medium">Settings</span>
                </a>
            </nav>

            <!-- User Section -->
            <div class="p-4 border-t border-slate-200">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-green-400 to-teal-400 flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
                        <%= doctorInitials %>
                    </div>
                    <div class="hidden lg:block flex-1 min-w-0">
                        <p class="text-sm font-semibold text-slate-900 truncate"><%= doctorName %></p>
                        <p class="text-xs text-slate-500 truncate"><%= doctorRole %></p>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 ml-20 lg:ml-64">
            <!-- Header -->
            <header class="sticky top-0 bg-slate-50/95 backdrop-blur-lg border-b border-slate-200 z-20">
                <div class="px-6 lg:px-8 py-4">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <h1 class="text-2xl font-bold text-slate-900">Patients Management</h1>
                            <p class="text-sm text-slate-500 mt-1">Manage and view patient records</p>
                        </div>
                        <button class="btn-primary px-5 py-2.5 rounded-xl text-sm font-semibold flex items-center gap-2 focus-ring" id="addPatientBtn">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                            </svg>
                            Add Patient
                        </button>
                    </div>
                    
                    <!-- Search and Filters -->
                    <div class="flex flex-col sm:flex-row gap-3">
                        <div class="relative flex-1 max-w-xl">
                            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                            </svg>
                            <input type="search" 
                                   id="searchInput"
                                   placeholder="Search by name, ID, or diagnosis..." 
                                   class="search-input w-full pl-11 pr-4 py-3 bg-white border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-green-400 focus:ring-2 focus:ring-green-100 transition-all">
                        </div>
                        <div class="flex gap-2">
                            <button class="btn-secondary px-4 py-3 rounded-xl text-sm font-medium flex items-center gap-2 focus-ring" id="filterBtn">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
                                </svg>
                                Filters
                                <span class="hidden sm:inline" id="filterCount">(0)</span>
                            </button>
                            <button class="btn-secondary px-4 py-3 rounded-xl text-sm font-medium flex items-center gap-2 focus-ring" id="exportBtn">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
                                </svg>
                                <span class="hidden sm:inline">Export</span>
                            </button>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Filter Dropdown -->
            <div id="filterDropdown" class="hidden fixed top-32 right-8 w-72 bg-white rounded-2xl shadow-xl border border-slate-200 p-4 z-30 filter-dropdown">
                <h3 class="text-sm font-semibold text-slate-900 mb-4">Filter Patients</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-medium text-slate-500 mb-2">Status</label>
                        <div class="flex flex-wrap gap-2">
                            <button class="filter-tag px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:border-green-400 hover:text-green-700 transition-colors" data-filter="status" data-value="in-treatment">In Treatment</button>
                            <button class="filter-tag px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:border-green-400 hover:text-green-700 transition-colors" data-filter="status" data-value="recovered">Recovered</button>
                            <button class="filter-tag px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:border-green-400 hover:text-green-700 transition-colors" data-filter="status" data-value="check-up">Check-up</button>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-500 mb-2">Gender</label>
                        <div class="flex flex-wrap gap-2">
                            <button class="filter-tag px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:border-green-400 hover:text-green-700 transition-colors" data-filter="gender" data-value="male">Male</button>
                            <button class="filter-tag px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:border-green-400 hover:text-green-700 transition-colors" data-filter="gender" data-value="female">Female</button>
                            <button class="filter-tag px-3 py-1.5 text-xs font-medium rounded-lg border border-slate-200 text-slate-600 hover:border-green-400 hover:text-green-700 transition-colors" data-filter="gender" data-value="other">Other</button>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-slate-500 mb-2">Age Range</label>
                        <select id="ageRangeFilter" class="w-full px-3 py-2 text-sm border border-slate-200 rounded-lg focus:outline-none focus:border-green-400 focus:ring-2 focus:ring-green-100">
                            <option value="">All Ages</option>
                            <option value="0-18">0-18 years</option>
                            <option value="19-40">19-40 years</option>
                            <option value="41-60">41-60 years</option>
                            <option value="60+">60+ years</option>
                        </select>
                    </div>
                    <div class="flex gap-2 pt-2">
                        <button class="flex-1 btn-secondary px-3 py-2 rounded-lg text-sm font-medium" id="clearFilters">Clear All</button>
                        <button class="flex-1 btn-primary px-3 py-2 rounded-lg text-sm font-semibold" id="applyFilters">Apply</button>
                    </div>
                </div>
            </div>
            <div id="kebabActionMenu" class="hidden fixed z-40 w-52 rounded-xl border border-slate-200 bg-white shadow-xl p-1.5">
                <button type="button" class="kebab-action-item w-full text-left px-3 py-2 rounded-lg text-sm text-slate-700 hover:bg-slate-100 transition-colors" data-action="view">
                    View Details
                </button>
                <button type="button" class="kebab-action-item w-full text-left px-3 py-2 rounded-lg text-sm text-slate-700 hover:bg-slate-100 transition-colors" data-action="clinical">
                    Edit Clinical Data
                </button>
                <button type="button" class="kebab-action-item w-full text-left px-3 py-2 rounded-lg text-sm text-slate-700 hover:bg-slate-100 transition-colors" data-action="edit">
                    Edit Patient
                </button>
                <button type="button" class="kebab-action-item w-full text-left px-3 py-2 rounded-lg text-sm text-rose-600 hover:bg-rose-50 transition-colors" data-action="archive">
                    Archive Patient
                </button>
            </div>

            <!-- Patient Table -->
            <div class="px-6 lg:px-8 py-6">
                <% if (typeof pageError !== 'undefined' && pageError) { %>
                <div class="mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"><%= pageError %></div>
                <% } %>
                <!-- Stats Row -->
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                    <div class="bg-white rounded-2xl p-5 border border-slate-200 animate-fade-in-up stagger-1">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center">
                                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                            </div>
                            <div>
                                <p class="text-2xl font-bold text-slate-900" id="totalPatientsStat">0</p>
                                <p class="text-xs text-slate-500">Total Patients</p>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white rounded-2xl p-5 border border-slate-200 animate-fade-in-up stagger-2">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center">
                                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                                </svg>
                            </div>
                            <div>
                                <p class="text-2xl font-bold text-slate-900" id="inTreatmentStat">0</p>
                                <p class="text-xs text-slate-500">In Treatment</p>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white rounded-2xl p-5 border border-slate-200 animate-fade-in-up stagger-3">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center">
                                <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                            <div>
                                <p class="text-2xl font-bold text-slate-900" id="recoveredStat">0</p>
                                <p class="text-xs text-slate-500">Recovered</p>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white rounded-2xl p-5 border border-slate-200 animate-fade-in-up stagger-4">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center">
                                <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                                </svg>
                            </div>
                            <div>
                                <p class="text-2xl font-bold text-slate-900" id="checkupStat">0</p>
                                <p class="text-xs text-slate-500">Check-ups</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Table -->
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden animate-fade-in-up stagger-5">
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="bg-slate-50 border-b border-slate-200">
                                <tr>
                                    <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wide px-6 py-4">Patient</th>
                                    <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wide px-6 py-4">Age / Gender</th>
                                    <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wide px-6 py-4">Last Visit</th>
                                    <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wide px-6 py-4">Diagnosis</th>
                                    <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wide px-6 py-4">Status</th>
                                    <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wide px-6 py-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="patientTable">
                                <!-- Patient rows will be rendered here -->
                            </tbody>
                        </table>
                    </div>
                    
                    <!-- Pagination -->
                    <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between">
                        <p class="text-sm text-slate-500" id="tableMeta">Showing <span class="font-medium text-slate-900">0</span> of <span class="font-medium text-slate-900">0</span> patients</p>
                        <div class="flex items-center gap-2">
                            <button class="px-3 py-2 text-sm font-medium text-slate-400 bg-slate-100 rounded-lg cursor-not-allowed" disabled>Previous</button>
                            <button class="px-3 py-2 text-sm font-medium text-white bg-green-400 rounded-lg hover:bg-green-500 transition-colors">1</button>
                            <button class="px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 rounded-lg transition-colors">2</button>
                            <button class="px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 rounded-lg transition-colors">3</button>
                            <span class="px-2 text-slate-400">...</span>
                            <button class="px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 rounded-lg transition-colors">285</button>
                            <button class="px-3 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 rounded-lg transition-colors">Next</button>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Patient Detail Panel Overlay -->
    <div id="panelOverlay" class="hidden fixed inset-0 overlay z-40" aria-hidden="true"></div>

    <!-- Patient Detail Slide-over Panel -->
    <aside id="patientPanel" class="hidden fixed inset-y-0 right-0 w-full sm:max-w-lg bg-white shadow-2xl z-50 overflow-y-auto" role="dialog" aria-modal="true" aria-labelledby="panelTitle">
        <div class="h-full flex flex-col">
            <!-- Panel Header -->
            <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between bg-slate-50">
                <h2 id="panelTitle" class="text-lg font-bold text-slate-900">Patient Details</h2>
                <button id="closePanel" class="p-2 hover:bg-slate-200 rounded-lg transition-colors focus-ring" aria-label="Close panel">
                    <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            <!-- Panel Content -->
            <div class="flex-1 p-6 space-y-6" id="panelContent">
                <!-- Content will be dynamically populated -->
            </div>

            <!-- Panel Footer -->
            <div class="px-6 py-4 border-t border-slate-200 bg-slate-50 flex gap-3">
                <button id="editPatientBtn" class="flex-1 btn-secondary px-4 py-2.5 rounded-xl text-sm font-semibold focus-ring">
                    Edit Patient
                </button>
                <button id="deletePatientBtn" class="flex-1 px-4 py-2.5 rounded-xl text-sm font-semibold border border-rose-200 bg-rose-50 text-rose-700 hover:bg-rose-100 transition-colors focus-ring">
                    Archive Patient
                </button>
            </div>
        </div>
    </aside>

    <script>
        // Patient Data
        const patients = <%- JSON.stringify(patientsData || []) %>;
        const csrfToken = '<%= csrfToken %>';

        // DOM Elements - initialized after definition
        const patientTable = document.getElementById('patientTable');
        const patientPanel = document.getElementById('patientPanel');
        const panelOverlay = document.getElementById('panelOverlay');
        const panelContent = document.getElementById('panelContent');
        const closePanel = document.getElementById('closePanel');
        const searchInput = document.getElementById('searchInput');
        const filterBtn = document.getElementById('filterBtn');
        const filterDropdown = document.getElementById('filterDropdown');
        const ageRangeFilter = document.getElementById('ageRangeFilter');
        const exportBtn = document.getElementById('exportBtn');
        const kebabActionMenu = document.getElementById('kebabActionMenu');
        const addPatientBtn = document.getElementById('addPatientBtn');
        const editPatientBtn = document.getElementById('editPatientBtn');
        const deletePatientBtn = document.getElementById('deletePatientBtn');

        // State
        let selectedPatientId = null;
        let activeFilters = [];
        let latestRenderedPatients = Array.isArray(patients) ? patients : [];
        let openActionTrigger = null;

        // Status badge styles
        const statusStyles = {
            'in-treatment': 'bg-green-100 text-green-700',
            'recovered': 'bg-blue-100 text-blue-700',
            'check-up': 'bg-amber-100 text-amber-700'
        };

        const statusLabels = {
            'in-treatment': 'In Treatment',
            'recovered': 'Recovered',
            'check-up': 'Check-up'
        };

        // Render patient table
        function renderPatientTable(data) {
            if (!Array.isArray(data) || data.length === 0) {
                latestRenderedPatients = [];
                patientTable.innerHTML = `
                    <tr class="border-t border-slate-100">
                        <td colspan="6" class="px-6 py-10 text-center text-sm text-slate-500">No patient data found.</td>
                    </tr>
                `;
                updateTableMeta(0, patients.length);
                return;
            }

            latestRenderedPatients = data;
            patientTable.innerHTML = data.map((patient, index) => `
                <tr class="table-row border-t border-slate-100 ${selectedPatientId === patient.id ? 'selected' : ''}" 
                    data-patient-id="${patient.id}"
                    style="animation: fadeInUp 0.4s ease-out ${index * 0.05}s backwards;">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            ${patient.avatar ? `
                                <img src="${escapeHtml(patient.avatar)}" alt="${escapeHtml(patient.name)}" class="w-11 h-11 rounded-full object-cover ring-2 ring-slate-100">
                            ` : `
                                <div class="w-11 h-11 rounded-full ring-2 ring-slate-100 bg-green-100 text-green-700 flex items-center justify-center font-bold">
                                    ${escapeHtml(patient.initial || '?')}
                                </div>
                            `}
                            <div>
                                <p class="font-bold text-slate-900">${escapeHtml(patient.name)}</p>
                                <p class="text-sm text-slate-500 font-mono">${escapeHtml(patient.mrn || patient.id)}</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-2">
                            <span class="text-sm font-medium text-slate-900">${escapeHtml(patient.age)} yrs</span>
                            <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                            <span class="text-sm text-slate-500">${escapeHtml(patient.gender)}</span>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <span class="text-sm text-slate-600">${escapeHtml(patient.lastVisit)}</span>
                    </td>
                    <td class="px-6 py-4">
                        <span class="text-sm text-slate-600">${escapeHtml(patient.diagnosis)}</span>
                    </td>
                    <td class="px-6 py-4">
                        <span class="status-badge inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full ${statusStyles[patient.status] || 'bg-slate-100 text-slate-700'}">
                            <span class="w-1.5 h-1.5 rounded-full ${patient.status === 'in-treatment' ? 'bg-green-500 pulse-dot' : patient.status === 'recovered' ? 'bg-blue-500' : 'bg-amber-500'}"></span>
                            ${escapeHtml(statusLabels[patient.status] || patient.status || 'Unknown')}
                        </span>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-1">
                            <button class="p-2 hover:bg-slate-100 rounded-lg transition-colors focus-ring view-patient-btn" data-patient-id="${patient.id}" aria-label="View patient details">
                                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                            </button>
                            <button class="p-2 hover:bg-slate-100 rounded-lg transition-colors focus-ring more-actions-btn" data-patient-id="${patient.id}" aria-label="More options">
                                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"/>
                                </svg>
                            </button>
                        </div>
                    </td>
                </tr>
            `).join('');

            // Add click handlers
            document.querySelectorAll('.table-row').forEach(row => {
                row.addEventListener('click', (e) => {
                    if (!e.target.closest('button')) {
                        const patientId = row.dataset.patientId;
                        openPatientPanel(patientId);
                    }
                });
            });

            document.querySelectorAll('.view-patient-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    openPatientPanel(btn.dataset.patientId);
                });
            });

            document.querySelectorAll('.more-actions-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    openPatientActionMenu(btn.dataset.patientId, btn);
                });
            });

            updateTableMeta(data.length, patients.length);
        }

        // Generate sparkline
        function generateSparkline(data, color) {
            if (!Array.isArray(data) || data.length === 0) return '';
            const max = Math.max(...data);
            const min = Math.min(...data);
            const range = max - min || 1;
            
            return data.map(value => {
                const height = Math.max(4, ((value - min) / range) * 28);
                return `<div class="sparkline-bar" style="height: ${height}px; background: ${color};"></div>`;
            }).join('');
        }

        // Open patient panel
        function openPatientPanel(patientId) {
            const patient = patients.find(p => p.id === patientId);
            if (!patient) return;

            selectedPatientId = patientId;
            
            // Update selected row
            document.querySelectorAll('.table-row').forEach(row => {
                row.classList.toggle('selected', row.dataset.patientId === patientId);
            });

            // Generate panel content
            panelContent.innerHTML = `
                <!-- Patient Header -->
                <div class="text-center pb-6 border-b border-slate-100">
                    <div class="relative inline-block">
                        ${patient.avatar ? `
                            <img src="${escapeHtml(patient.avatar)}" alt="${escapeHtml(patient.name)}" class="w-24 h-24 rounded-full object-cover ring-4 ring-slate-100 mx-auto">
                        ` : `
                            <div class="w-24 h-24 rounded-full ring-4 ring-slate-100 mx-auto bg-green-100 text-green-700 flex items-center justify-center text-3xl font-bold">
                                ${escapeHtml(patient.initial || '?')}
                            </div>
                        `}
                        <span class="absolute bottom-1 right-1 w-4 h-4 rounded-full border-2 border-white ${patient.status === 'in-treatment' ? 'bg-green-400' : patient.status === 'recovered' ? 'bg-blue-400' : 'bg-amber-400'}"></span>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mt-4">${escapeHtml(patient.name)}</h3>
                    <p class="text-sm text-slate-500 font-mono">${escapeHtml(patient.mrn || patient.id)}</p>
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold mt-3 ${statusStyles[patient.status] || 'bg-slate-100 text-slate-700'}">
                        ${escapeHtml(statusLabels[patient.status] || patient.status || 'Unknown')}
                    </span>
                </div>

                <!-- Contact Info -->
                <div class="space-y-3">
                    <h4 class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Contact Information</h4>
                    <div class="space-y-3">
                        <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl">
                            <div class="w-8 h-8 rounded-lg bg-white flex items-center justify-center shadow-sm">
                                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                </svg>
                            </div>
                            <div>
                                <p class="text-xs text-slate-500">Phone</p>
                                <p class="text-sm font-medium text-slate-900">${escapeHtml(patient.phone || '-')}</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl">
                            <div class="w-8 h-8 rounded-lg bg-white flex items-center justify-center shadow-sm">
                                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                            </div>
                            <div>
                                <p class="text-xs text-slate-500">Email</p>
                                <p class="text-sm font-medium text-slate-900">${escapeHtml(patient.email || '-')}</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl">
                            <div class="w-8 h-8 rounded-lg bg-white flex items-center justify-center shadow-sm">
                                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                            </div>
                            <div>
                                <p class="text-xs text-slate-500">Address</p>
                                <p class="text-sm font-medium text-slate-900">${escapeHtml(patient.address || '-')}</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Vitals -->
                <div class="space-y-3">
                    <h4 class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Vitals</h4>
                    <div class="grid grid-cols-2 gap-3">
                        <div class="vital-card p-4 bg-slate-50 rounded-xl">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-xs text-slate-500">Heart Rate</span>
                                <svg class="w-4 h-4 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                                </svg>
                            </div>
                            <p class="text-2xl font-bold text-slate-900">${patient.vitals.heartRate || '-'} <span class="text-sm font-normal text-slate-400">bpm</span></p>
                            <div class="sparkline-container mt-2">
                                ${generateSparkline(patient.vitals.heartRateSeries || [], '#4ade80')}
                            </div>
                        </div>
                        <div class="vital-card p-4 bg-slate-50 rounded-xl">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-xs text-slate-500">Blood Pressure</span>
                                <svg class="w-4 h-4 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                                </svg>
                            </div>
                            <p class="text-2xl font-bold text-slate-900">${patient.vitals.bloodPressure.systolic && patient.vitals.bloodPressure.diastolic ? `${patient.vitals.bloodPressure.systolic}/${patient.vitals.bloodPressure.diastolic}` : '-'}</p>
                            <p class="text-xs text-slate-400 mt-1">mmHg</p>
                        </div>
                        <div class="vital-card p-4 bg-slate-50 rounded-xl">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-xs text-slate-500">Temperature</span>
                                <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                                </svg>
                            </div>
                            <p class="text-2xl font-bold text-slate-900">${patient.vitals.temperatureC || '-'}<span class="text-sm font-normal text-slate-400">°C</span></p>
                        </div>
                        <div class="vital-card p-4 bg-slate-50 rounded-xl">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-xs text-slate-500">Weight</span>
                                <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/>
                                </svg>
                            </div>
                            <p class="text-2xl font-bold text-slate-900">${patient.vitals.weightKg || '-'}<span class="text-sm font-normal text-slate-400"> kg</span></p>
                        </div>
                    </div>
                </div>

                <!-- Medical Info -->
                <div class="space-y-3">
                    <h4 class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Medical Information</h4>
                    <div class="grid grid-cols-2 gap-3">
                        <div class="p-3 bg-slate-50 rounded-xl">
                            <p class="text-xs text-slate-500 mb-1">SpO2</p>
                            <p class="text-sm font-bold text-slate-900">${patient.vitals.spo2 || '-'}%</p>
                        </div>
                        <div class="p-3 bg-slate-50 rounded-xl">
                            <p class="text-xs text-slate-500 mb-1">Height</p>
                            <p class="text-sm font-bold text-slate-900">${patient.vitals.heightCm || '-'} cm</p>
                        </div>
                    </div>
                    <div class="p-3 bg-rose-50 rounded-xl border border-rose-100">
                        <p class="text-xs text-rose-600 font-medium mb-1">Allergies</p>
                        <div class="flex flex-wrap gap-1.5 mt-2">
                            ${((patient.allergies || []).length ? patient.allergies : ['Not recorded']).map(allergy => `
                                <span class="px-2 py-1 bg-white text-rose-700 text-xs font-medium rounded-md border border-rose-200">${escapeHtml(allergy)}</span>
                            `).join('')}
                        </div>
                    </div>
                </div>

                <!-- Recent Notes -->
                <div class="space-y-3">
                    <h4 class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Recent Medical Notes</h4>
                    <div class="p-4 bg-slate-50 rounded-xl">
                        <p class="text-sm text-slate-600 leading-relaxed whitespace-pre-line">${escapeHtml(patient.notes)}</p>
                        <p class="text-xs text-slate-400 mt-3">Last updated: ${escapeHtml(patient.lastVisit)}</p>
                    </div>
                </div>
            `;

            // Show panel
            panelOverlay.classList.remove('hidden');
            panelOverlay.classList.add('animate-fade-in');
            patientPanel.classList.remove('hidden');
            patientPanel.classList.remove('animate-slide-out-right');
            patientPanel.classList.add('animate-slide-in-right');
        }

        // Close patient panel
        function closePatientPanel() {
            patientPanel.classList.remove('animate-slide-in-right');
            patientPanel.classList.add('animate-slide-out-right');
            
            setTimeout(() => {
                patientPanel.classList.add('hidden');
                panelOverlay.classList.add('hidden');
                selectedPatientId = null;
                
                document.querySelectorAll('.table-row').forEach(row => {
                    row.classList.remove('selected');
                });
            }, 250);
        }

        function getCurrentFilterState() {
            const status = activeFilters
                .filter((f) => f.filter === 'status')
                .map((f) => String(f.value || '').toLowerCase())
                .filter(Boolean);
            const gender = activeFilters
                .filter((f) => f.filter === 'gender')
                .map((f) => String(f.value || '').toLowerCase())
                .filter(Boolean);
            const q = (searchInput.value || '').trim();
            const ageRange = String(ageRangeFilter?.value || '').trim();
            return { q, status, gender, ageRange };
        }

        function isInAgeRange(age, ageRange) {
            const value = String(ageRange || '').trim();
            const n = Number(age || 0);
            if (!value) return true;
            if (value === '0-18') return n >= 0 && n <= 18;
            if (value === '19-40') return n >= 19 && n <= 40;
            if (value === '41-60') return n >= 41 && n <= 60;
            if (value === '60+') return n >= 60;
            return true;
        }

        function getFilteredPatients() {
            const { q, status, gender, ageRange } = getCurrentFilterState();
            const qLower = q.toLowerCase();
            return patients.filter((patient) => {
                if (status.length && !status.includes(String(patient.status || '').toLowerCase())) {
                    return false;
                }
                if (gender.length && !gender.includes(String(patient.gender || '').toLowerCase())) {
                    return false;
                }
                if (!isInAgeRange(patient.age, ageRange)) {
                    return false;
                }
                if (!qLower) return true;

                const haystack = [
                    patient.name,
                    patient.id,
                    patient.mrn,
                    patient.diagnosis,
                    patient.email,
                    patient.phone
                ]
                    .filter(Boolean)
                    .join(' ')
                    .toLowerCase();
                return haystack.includes(qLower);
            });
        }

        function refreshTable() {
            const rows = getFilteredPatients();
            renderPatientTable(rows);
        }

        function updateTableMeta(showing, total) {
            const el = document.getElementById('tableMeta');
            if (el) {
                el.innerHTML = `Showing <span class="font-medium text-slate-900">${showing}</span> of <span class="font-medium text-slate-900">${total}</span> patients`;
            }
        }

        function renderSummaryStats() {
            const total = patients.length;
            const inTreatment = patients.filter((p) => p.status === 'in-treatment').length;
            const recovered = patients.filter((p) => p.status === 'recovered').length;
            const checkup = patients.filter((p) => p.status === 'check-up').length;

            document.getElementById('totalPatientsStat').textContent = total;
            document.getElementById('inTreatmentStat').textContent = inTreatment;
            document.getElementById('recoveredStat').textContent = recovered;
            document.getElementById('checkupStat').textContent = checkup;
        }

        function selectedPatient() {
            return patients.find((p) => p.id === selectedPatientId) || null;
        }

        async function postForm(url, payload) {
            const res = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
                    'x-csrf-token': csrfToken
                },
                body: new URLSearchParams(payload)
            });
            const json = await res.json().catch(() => ({ ok: false, message: 'Request failed' }));
            if (!res.ok || !json.ok) {
                throw new Error(json.message || 'Request failed');
            }
            return json;
        }

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function swalThemeConfig(confirmText) {
            return {
                showCancelButton: true,
                focusConfirm: false,
                buttonsStyling: false,
                confirmButtonText: confirmText,
                cancelButtonText: 'Cancel',
                customClass: {
                    popup: 'hms-swal-popup',
                    title: 'hms-swal-title',
                    htmlContainer: 'hms-swal-html',
                    actions: 'hms-swal-actions',
                    confirmButton: 'hms-swal-confirm',
                    cancelButton: 'hms-swal-cancel'
                }
            };
        }

        function patientFormHtml(patient = {}) {
            const firstName = escapeHtml((patient.name || '').split(' ')[0] || '');
            const lastName = escapeHtml((patient.name || '').split(' ').slice(1).join(' '));
            const dob = escapeHtml(patient.dob || '');
            const phone = escapeHtml(patient.phone || '');
            const email = escapeHtml(patient.email || '');
            const address = escapeHtml(patient.address || '');
            return `
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <div class="sm:col-span-1">
                        <label class="block text-xs font-semibold text-slate-500 mb-1">First Name *</label>
                        <input id="swal_first_name" class="hms-swal-input" placeholder="First name" value="${firstName}">
                    </div>
                    <div class="sm:col-span-1">
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Last Name</label>
                        <input id="swal_last_name" class="hms-swal-input" placeholder="Last name" value="${lastName}">
                    </div>
                    <div class="sm:col-span-1">
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Date of Birth *</label>
                        <input id="swal_dob" type="date" class="hms-swal-input" value="${dob}">
                    </div>
                    <div class="sm:col-span-1">
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Gender</label>
                        <select id="swal_gender" class="hms-swal-input">
                            <option value="">Select gender</option>
                            <option value="Male" ${patient.gender === 'Male' ? 'selected' : ''}>Male</option>
                            <option value="Female" ${patient.gender === 'Female' ? 'selected' : ''}>Female</option>
                            <option value="Other" ${patient.gender === 'Other' ? 'selected' : ''}>Other</option>
                        </select>
                    </div>
                    <div class="sm:col-span-1">
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Phone</label>
                        <input id="swal_phone" class="hms-swal-input" placeholder="Phone number" value="${phone}">
                    </div>
                    <div class="sm:col-span-1">
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Email</label>
                        <input id="swal_email" class="hms-swal-input" placeholder="Email address" value="${email}">
                    </div>
                    <div class="sm:col-span-2">
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Address</label>
                        <input id="swal_address" class="hms-swal-input" placeholder="Address" value="${address}">
                    </div>
                </div>
            `;
        }

        function collectPatientFormValues() {
            const first_name = document.getElementById('swal_first_name').value.trim();
            const date_of_birth = document.getElementById('swal_dob').value;
            if (!first_name || !date_of_birth) {
                Swal.showValidationMessage('First name and date of birth are required');
                return null;
            }
            return {
                first_name,
                last_name: document.getElementById('swal_last_name').value.trim(),
                date_of_birth,
                gender: document.getElementById('swal_gender').value,
                phone_number: document.getElementById('swal_phone').value.trim(),
                email: document.getElementById('swal_email').value.trim(),
                address: document.getElementById('swal_address').value.trim()
            };
        }

        function toInput(value) {
            return escapeHtml(value == null ? '' : String(value));
        }

        function clinicalFormHtml(patient = {}) {
            const vitals = patient.vitals || {};
            const clinical = patient.clinical || {};
            const bp = vitals.bloodPressure || {};
            return `
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Heart Rate (bpm)</label>
                        <input id="swal_hr" type="number" min="0" class="hms-swal-input" value="${toInput(vitals.heartRate)}">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Temperature (C)</label>
                        <input id="swal_temp" type="number" min="0" step="0.1" class="hms-swal-input" value="${toInput(vitals.temperatureC)}">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Systolic BP</label>
                        <input id="swal_sys" type="number" min="0" class="hms-swal-input" value="${toInput(bp.systolic)}">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Diastolic BP</label>
                        <input id="swal_dia" type="number" min="0" class="hms-swal-input" value="${toInput(bp.diastolic)}">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1">SpO2 (%)</label>
                        <input id="swal_spo2" type="number" min="0" max="100" class="hms-swal-input" value="${toInput(vitals.spo2)}">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Weight (kg)</label>
                        <input id="swal_weight" type="number" min="0" step="0.1" class="hms-swal-input" value="${toInput(vitals.weightKg)}">
                    </div>
                    <div class="sm:col-span-2">
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Height (cm)</label>
                        <input id="swal_height" type="number" min="0" step="0.1" class="hms-swal-input" value="${toInput(vitals.heightCm)}">
                    </div>
                    <div class="sm:col-span-2">
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Subjective (S)</label>
                        <textarea id="swal_subjective" class="hms-swal-input" rows="2" placeholder="Patient complaints">${toInput(clinical.subjective)}</textarea>
                    </div>
                    <div class="sm:col-span-2">
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Objective (O)</label>
                        <textarea id="swal_objective" class="hms-swal-input" rows="2" placeholder="Physical exam">${toInput(clinical.objective)}</textarea>
                    </div>
                    <div class="sm:col-span-2">
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Assessment (A)</label>
                        <textarea id="swal_assessment" class="hms-swal-input" rows="2" placeholder="Assessment">${toInput(clinical.assessment)}</textarea>
                    </div>
                    <div class="sm:col-span-2">
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Plan (P)</label>
                        <textarea id="swal_plan" class="hms-swal-input" rows="2" placeholder="Treatment plan">${toInput(clinical.plan)}</textarea>
                    </div>
                </div>
            `;
        }

        function collectClinicalFormValues() {
            const get = (id) => document.getElementById(id)?.value?.trim() || '';
            return {
                heart_rate: get('swal_hr'),
                temp_celcius: get('swal_temp'),
                systolic_bp: get('swal_sys'),
                diastolic_bp: get('swal_dia'),
                spo2: get('swal_spo2'),
                weight_kg: get('swal_weight'),
                height_cm: get('swal_height'),
                subjective: get('swal_subjective'),
                objective: get('swal_objective'),
                assessment: get('swal_assessment'),
                plan: get('swal_plan')
            };
        }

        async function onAddPatient() {
            const { value: formValues } = await Swal.fire({
                title: 'Add Patient',
                html: patientFormHtml(),
                ...swalThemeConfig('Create'),
                preConfirm: collectPatientFormValues
            });

            if (!formValues) return;
            try {
                await postForm('/doctor/patients', formValues);
                await Swal.fire({ icon: 'success', title: 'Created', text: 'Patient has been created' });
                window.location.reload();
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Failed', text: error.message });
            }
        }

        async function onEditPatient() {
            const patient = selectedPatient();
            if (!patient) {
                Swal.fire({ icon: 'info', title: 'Select a patient first' });
                return;
            }

            const { value: formValues } = await Swal.fire({
                title: `Edit ${patient.name}`,
                html: patientFormHtml(patient),
                ...swalThemeConfig('Save'),
                preConfirm: collectPatientFormValues
            });

            if (!formValues) return;
            try {
                await postForm(`/doctor/patients/${patient.id}/update`, formValues);
                await Swal.fire({ icon: 'success', title: 'Updated', text: 'Patient has been updated' });
                window.location.reload();
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Failed', text: error.message });
            }
        }

        async function onEditPatientClinical() {
            const patient = selectedPatient();
            if (!patient) {
                Swal.fire({ icon: 'info', title: 'Select a patient first' });
                return;
            }

            const { value: formValues } = await Swal.fire({
                title: `Clinical Data: ${patient.name}`,
                html: clinicalFormHtml(patient),
                ...swalThemeConfig('Save'),
                preConfirm: collectClinicalFormValues
            });

            if (!formValues) return;
            try {
                await postForm(`/doctor/patients/${patient.id}/clinical`, formValues);
                await Swal.fire({ icon: 'success', title: 'Updated', text: 'Clinical data has been updated' });
                window.location.reload();
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Failed', text: error.message });
            }
        }

        async function onDeletePatient() {
            const patient = selectedPatient();
            if (!patient) {
                Swal.fire({ icon: 'info', title: 'Select a patient first' });
                return;
            }

            const confirm = await Swal.fire({
                icon: 'warning',
                title: 'Archive patient?',
                text: `${patient.name} will be hidden from directory.`,
                showCancelButton: true,
                confirmButtonText: 'Archive'
            });
            if (!confirm.isConfirmed) return;

            try {
                await postForm(`/doctor/patients/${patient.id}/delete`, {});
                await Swal.fire({ icon: 'success', title: 'Archived', text: 'Patient has been archived' });
                window.location.reload();
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Failed', text: error.message });
            }
        }

        function closePatientActionMenu() {
            if (!kebabActionMenu) return;
            kebabActionMenu.classList.add('hidden');
            if (openActionTrigger) {
                openActionTrigger.classList.remove('bg-slate-100');
                openActionTrigger = null;
            }
        }

        function placePatientActionMenu(triggerEl) {
            if (!kebabActionMenu || !triggerEl) return;

            const gap = 6;
            const rect = triggerEl.getBoundingClientRect();
            kebabActionMenu.style.top = '0px';
            kebabActionMenu.style.left = '0px';
            kebabActionMenu.classList.remove('hidden');

            const menuRect = kebabActionMenu.getBoundingClientRect();
            let top = rect.bottom + gap;
            let left = rect.right - menuRect.width;

            if (left < 8) left = 8;
            if (left + menuRect.width > window.innerWidth - 8) {
                left = window.innerWidth - menuRect.width - 8;
            }
            if (top + menuRect.height > window.innerHeight - 8) {
                top = rect.top - menuRect.height - gap;
            }
            if (top < 8) top = 8;

            kebabActionMenu.style.top = `${Math.round(top)}px`;
            kebabActionMenu.style.left = `${Math.round(left)}px`;
        }

        function openPatientActionMenu(patientId, triggerEl) {
            selectedPatientId = patientId;
            const patient = selectedPatient();
            if (!patient) return;

            const isSameTrigger = openActionTrigger === triggerEl && !kebabActionMenu.classList.contains('hidden');
            if (isSameTrigger) {
                closePatientActionMenu();
                return;
            }

            closePatientActionMenu();
            openActionTrigger = triggerEl;
            openActionTrigger.classList.add('bg-slate-100');
            kebabActionMenu.dataset.patientId = patientId;
            placePatientActionMenu(triggerEl);
        }

        async function handlePatientActionMenu(action) {
            if (!action) return;
            const patientId = kebabActionMenu?.dataset?.patientId;
            if (!patientId) return;
            closePatientActionMenu();

            if (action === 'view') {
                openPatientPanel(patientId);
                return;
            }
            if (action === 'clinical') {
                await onEditPatientClinical();
                return;
            }
            if (action === 'edit') {
                await onEditPatient();
                return;
            }
            if (action === 'archive') {
                await onDeletePatient();
            }
        }

        async function exportPatients() {
            try {
                applyFilters();
                const { q, status, gender, ageRange } = getCurrentFilterState();
                const params = new URLSearchParams();
                if (q) params.set('q', q);
                if (status.length) params.set('status', status.join(','));
                if (gender.length) params.set('gender', gender.join(','));
                if (ageRange) params.set('age_range', ageRange);

                const url = `/doctor/patients/export${params.toString() ? `?${params.toString()}` : ''}`;
                const res = await fetch(url, { method: 'GET' });
                if (!res.ok) {
                    const payload = await res.json().catch(() => ({ message: 'Failed to export data' }));
                    throw new Error(payload.message || 'Failed to export data');
                }

                const blob = await res.blob();
                const disposition = res.headers.get('content-disposition') || '';
                const filenameMatch = disposition.match(/filename="([^"]+)"/i);
                const filename = filenameMatch ? filenameMatch[1] : 'doctor-patients.xlsx';

                const blobUrl = URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.href = blobUrl;
                link.download = filename;
                document.body.appendChild(link);
                link.click();
                link.remove();
                URL.revokeObjectURL(blobUrl);

                await Swal.fire({ icon: 'success', title: 'Exported', text: `Exported ${latestRenderedPatients.length} patient(s) to XLSX.` });
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Export Failed', text: error.message });
            }
        }

        // Filter functionality
        function toggleFilter(filter, value) {
            const index = activeFilters.findIndex(f => f.filter === filter && f.value === value);
            if (index > -1) {
                activeFilters.splice(index, 1);
            } else {
                activeFilters.push({ filter, value });
            }
            updateFilterTags();
        }

        function updateFilterTags() {
            document.querySelectorAll('.filter-tag').forEach(tag => {
                const isActive = activeFilters.some(f => f.filter === tag.dataset.filter && f.value === tag.dataset.value);
                tag.classList.toggle('bg-green-100', isActive);
                tag.classList.toggle('border-green-400', isActive);
                tag.classList.toggle('text-green-700', isActive);
            });
            
            document.getElementById('filterCount').textContent = `(${activeFilters.length})`;
        }

        function applyFilters() {
            refreshTable();
        }

        // Event Listeners
        closePanel.addEventListener('click', closePatientPanel);
        panelOverlay.addEventListener('click', closePatientPanel);
        addPatientBtn.addEventListener('click', onAddPatient);
        editPatientBtn.addEventListener('click', onEditPatient);
        deletePatientBtn.addEventListener('click', onDeletePatient);

        searchInput.addEventListener('input', refreshTable);

        filterBtn.addEventListener('click', () => {
            filterDropdown.classList.toggle('hidden');
        });

        exportBtn.addEventListener('click', exportPatients);

        document.querySelectorAll('.filter-tag').forEach(tag => {
            tag.addEventListener('click', () => {
                toggleFilter(tag.dataset.filter, tag.dataset.value);
            });
        });

        document.getElementById('clearFilters').addEventListener('click', () => {
            activeFilters = [];
            updateFilterTags();
            searchInput.value = '';
            if (ageRangeFilter) ageRangeFilter.value = '';
            refreshTable();
        });

        document.getElementById('applyFilters').addEventListener('click', () => {
            applyFilters();
            filterDropdown.classList.add('hidden');
        });

        if (ageRangeFilter) {
            ageRangeFilter.addEventListener('change', refreshTable);
        }

        // Close filter dropdown when clicking outside
        document.addEventListener('click', (e) => {
            if (!filterDropdown.contains(e.target) && !filterBtn.contains(e.target)) {
                filterDropdown.classList.add('hidden');
            }
            const clickedKebabTrigger = e.target.closest('.more-actions-btn');
            if (!clickedKebabTrigger && kebabActionMenu && !kebabActionMenu.contains(e.target)) {
                closePatientActionMenu();
            }
        });

        // Keyboard accessibility
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && kebabActionMenu && !kebabActionMenu.classList.contains('hidden')) {
                closePatientActionMenu();
                return;
            }
            if (e.key === 'Escape' && !patientPanel.classList.contains('hidden')) {
                closePatientPanel();
            }
        });

        window.addEventListener('resize', () => {
            if (!kebabActionMenu || kebabActionMenu.classList.contains('hidden') || !openActionTrigger) return;
            placePatientActionMenu(openActionTrigger);
        });

        window.addEventListener('scroll', () => {
            if (!kebabActionMenu || kebabActionMenu.classList.contains('hidden')) return;
            closePatientActionMenu();
        }, true);

        if (kebabActionMenu) {
            kebabActionMenu.querySelectorAll('.kebab-action-item').forEach(btn => {
                btn.addEventListener('click', async (e) => {
                    e.stopPropagation();
                    await handlePatientActionMenu(btn.dataset.action);
                });
            });
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            renderSummaryStats();
            refreshTable();

            const params = new URLSearchParams(window.location.search);
            if (params.get('action') === 'add-patient') {
                onAddPatient();
                params.delete('action');
                const nextQs = params.toString();
                history.replaceState({}, '', `${window.location.pathname}${nextQs ? `?${nextQs}` : ''}`);
            }
        });
    </script>
</body>
</html>
