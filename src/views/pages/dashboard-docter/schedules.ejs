                .join('');

            scheduleList.querySelectorAll('.schedule-list-card').forEach((el) => {
                el.addEventListener('click', () => openBlockModal(el.dataset.id));
            });
        }

        // Render mini calendar
        function renderMiniCalendar() {
            const container = document.getElementById('miniCalendar');
            const titleEl = document.getElementById('miniCalendarTitle');
            const monthAnchor = new Date(miniCalendarAnchor);
            const todayYmd = toYmd(fallbackToday);
            const selectedYmd = toYmd(selectedDate);
            const firstDay = new Date(monthAnchor.getFullYear(), monthAnchor.getMonth(), 1);
            const lastDay = new Date(monthAnchor.getFullYear(), monthAnchor.getMonth() + 1, 0);
            const startOffset = firstDay.getDay();

            if (titleEl) {
                titleEl.textContent = monthAnchor.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
            }

            let html = '';
            for (let i = 0; i < startOffset; i++) {
                html += '<div class="w-7 h-7"></div>';
            }

            for (let day = 1; day <= lastDay.getDate(); day++) {
                const date = new Date(monthAnchor.getFullYear(), monthAnchor.getMonth(), day);
                const ymd = toYmd(date);
                const isToday = ymd === todayYmd;
                const isSelected = ymd === selectedYmd;
                const hasEvent = scheduleBlocks.some((b) => b.shiftDate === ymd);
                html += `
                    <button type="button" class="mini-calendar-day relative w-7 h-7 text-xs font-medium rounded-lg ${isToday ? 'today' : ''} ${isSelected && !isToday ? 'selected' : ''} ${hasEvent && !isToday ? 'has-event' : ''}" data-date="${ymd}">
                        ${day}
                    </button>
                `;
            }

            container.innerHTML = html;
            container.querySelectorAll('.mini-calendar-day[data-date]').forEach((btn) => {
                btn.addEventListener('click', () => {
                    const picked = parseYmd(btn.dataset.date);
                    if (!picked) return;
                    selectedDate = startOfDay(picked);
                    currentWeekStart = startOfWeek(selectedDate);
                    currentMonthAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
                    miniCalendarAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
                    renderAll();
                });
            });
        }

        function renderMonthCards() {
            renderMonthGrid();
        }

        // Update view toggle indicator
        function updateViewToggle() {
            const activeBtn = document.querySelector(`.view-toggle-btn[data-view="${currentView}"]`);
            if (activeBtn) {
                toggleIndicator.style.width = `${activeBtn.offsetWidth}px`;
                toggleIndicator.style.left = `${activeBtn.offsetLeft}px`;
            }
        }

        function updateSidebarOverview() {
            const todayYmd = toYmd(fallbackToday);
            const now = new Date();
            const todayBlocks = scheduleBlocks.filter((b) => b.shiftDate === todayYmd);
            const totalHours = todayBlocks.reduce((sum, b) => sum + Math.max(0, Number(b.endHour || 0) - Number(b.startHour || 0)), 0);
            const patients = todayBlocks.reduce((sum, b) => sum + Number(b.patientCount || 0), 0);

            const hoursEl = document.getElementById('workingHoursStat');
            const patientsEl = document.getElementById('patientsStat');
            const apptEl = document.getElementById('appointmentsStat');
            if (hoursEl) hoursEl.textContent = `${totalHours.toFixed(totalHours % 1 ? 1 : 0)}h`;
            if (patientsEl) patientsEl.textContent = String(patients);
            if (apptEl) apptEl.textContent = String(todayBlocks.length);

            const upcoming = scheduleBlocks
                .map((b) => {
                    const d = parseYmd(b.shiftDate);
                    if (!d) return null;
                    d.setHours(Number(b.startHour || START_HOUR), 0, 0, 0);
                    return { ...b, __start: d };
                })
                .filter(Boolean)
                .filter((b) => b.__start.getTime() >= now.getTime())
                .sort((a, b) => a.__start.getTime() - b.__start.getTime())[0];

            const dutyTitle = document.getElementById('upcomingDutyTitle');
            const dutyLocation = document.getElementById('upcomingDutyLocation');
            const dutyTime = document.getElementById('upcomingDutyTime');
            if (upcoming) {
                if (dutyTitle) dutyTitle.textContent = upcoming.title || upcoming.department || 'Shift';
                if (dutyLocation) dutyLocation.textContent = upcoming.location || upcoming.department || '-';
                if (dutyTime) dutyTime.textContent = `${upcoming.shiftDate} • ${formatHour(Number(upcoming.startHour || START_HOUR))} - ${formatHour(Number(upcoming.endHour || START_HOUR + 1))}`;
            } else {
                if (dutyTitle) dutyTitle.textContent = 'No upcoming duty';
                if (dutyLocation) dutyLocation.textContent = '-';
                if (dutyTime) dutyTime.textContent = '-';
            }
        }

        function formatIcsDate(date) {
            const y = date.getFullYear();
            const m = String(date.getMonth() + 1).padStart(2, '0');
            const d = String(date.getDate()).padStart(2, '0');
            const h = String(date.getHours()).padStart(2, '0');
            const min = String(date.getMinutes()).padStart(2, '0');
            const s = String(date.getSeconds()).padStart(2, '0');
            return `${y}${m}${d}T${h}${min}${s}`;
        }

        function escapeIcs(value) {
            return String(value || '')
                .replace(/\\/g, '\\\\')
                .replace(/\n/g, '\\n')
                .replace(/,/g, '\\,')
                .replace(/;/g, '\\;');
        }

        async function onSyncCalendar() {
            try {
                if (!scheduleBlocks.length) {
                    Swal.fire({ icon: 'info', title: 'No schedules', text: 'There are no schedule blocks to sync yet.' });
                    return;
                }
                const dtStamp = formatIcsDate(new Date());
                const events = scheduleBlocks
                    .filter((b) => b.shiftDate)
                    .map((b) => {
                        const start = parseYmd(b.shiftDate) || new Date();
                        const end = parseYmd(b.shiftDate) || new Date();
                        start.setHours(Number(b.startHour || START_HOUR), 0, 0, 0);
                        end.setHours(Number(b.endHour || START_HOUR + 1), 0, 0, 0);
                        return [
                            'BEGIN:VEVENT',
                            `UID:${b.id}@medcore-hms`,
                            `DTSTAMP:${dtStamp}`,
                            `DTSTART;TZID=Asia/Jakarta:${formatIcsDate(start)}`,
                            `DTEND;TZID=Asia/Jakarta:${formatIcsDate(end)}`,
                            `SUMMARY:${escapeIcs(b.title || b.department || 'Doctor Shift')}`,
                            `DESCRIPTION:${escapeIcs(b.notes || '')}`,
                            `LOCATION:${escapeIcs(b.location || b.department || '')}`,
                            'END:VEVENT'
                        ].join('\r\n');
                    })
                    .join('\r\n');

                const ics = [
                    'BEGIN:VCALENDAR',
                    'VERSION:2.0',
                    'PRODID:-//MedCore HMS//Doctor Schedule//EN',
                    'CALSCALE:GREGORIAN',
                    'METHOD:PUBLISH',
                    'X-WR-CALNAME:Doctor Schedule',
                    events,
                    'END:VCALENDAR'
                ].join('\r\n');

                const now = new Date();
                const filename = `doctor-schedule-${toYmd(now).replace(/-/g, '')}.ics`;
                const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
                const url = URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.href = url;
                link.download = filename;
                document.body.appendChild(link);
                link.click();
                link.remove();
                URL.revokeObjectURL(url);

                await Swal.fire({
                    icon: 'success',
                    title: 'Calendar Synced',
                    text: `${scheduleBlocks.length} schedule item(s) exported as ICS. Import this file to Google/Outlook/Apple Calendar.`
                });
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Sync Failed', text: error.message });
            }
        }

        function renderAll() {
            formatRangeLabel();
            renderTimelineHeaders();
            renderTimelineGrid();
            renderMonthCards();
            renderMiniCalendar();
            renderScheduleList();
            updateViewToggle();
            updateSidebarOverview();
        }

        // Update live time
        function updateLiveTime() {
            const now = new Date();
            document.getElementById('liveTime').textContent = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
            document.getElementById('liveDate').textContent = now.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
        }

        // Event Listeners
        document.getElementById('prevWeek').addEventListener('click', () => {
            if (currentView === 'day') {
                selectedDate = plusDays(selectedDate, -1);
                currentWeekStart = startOfWeek(selectedDate);
                currentMonthAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
            } else if (currentView === 'month') {
                currentMonthAnchor = new Date(currentMonthAnchor.getFullYear(), currentMonthAnchor.getMonth() - 1, 1);
                selectedDate = new Date(currentMonthAnchor.getFullYear(), currentMonthAnchor.getMonth(), 1);
                currentWeekStart = startOfWeek(selectedDate);
            } else {
                currentWeekStart = plusDays(currentWeekStart, -7);
                selectedDate = new Date(currentWeekStart);
            }
            miniCalendarAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
            renderAll();
        });

        document.getElementById('nextWeek').addEventListener('click', () => {
            if (currentView === 'day') {
                selectedDate = plusDays(selectedDate, 1);
                currentWeekStart = startOfWeek(selectedDate);
                currentMonthAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
            } else if (currentView === 'month') {
                currentMonthAnchor = new Date(currentMonthAnchor.getFullYear(), currentMonthAnchor.getMonth() + 1, 1);
                selectedDate = new Date(currentMonthAnchor.getFullYear(), currentMonthAnchor.getMonth(), 1);
                currentWeekStart = startOfWeek(selectedDate);
            } else {
                currentWeekStart = plusDays(currentWeekStart, 7);
                selectedDate = new Date(currentWeekStart);
            }
            miniCalendarAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
            renderAll();
        });

        document.getElementById('todayBtn').addEventListener('click', () => {
            selectedDate = new Date(fallbackToday);
            currentWeekStart = startOfWeek(selectedDate);
            currentMonthAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
            miniCalendarAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
            renderAll();
        });

        document.querySelectorAll('.view-toggle-btn').forEach((btn) => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.view-toggle-btn').forEach((b) => b.classList.remove('active'));
                btn.classList.add('active');
                currentView = btn.dataset.view;
                if (currentView === 'week') currentWeekStart = startOfWeek(selectedDate);
                if (currentView === 'month') currentMonthAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
                miniCalendarAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
                renderAll();
            });
        });

        document.getElementById('closeModal').addEventListener('click', closeModal);
        modalOverlay.addEventListener('click', closeModal);
        addScheduleBtn.addEventListener('click', openCreateShiftModal);
        deleteShiftBtn.addEventListener('click', onDeleteShift);
        editShiftBtn.addEventListener('click', openEditShiftModal);
        if (syncCalendarBtn) syncCalendarBtn.addEventListener('click', onSyncCalendar);
        if (miniPrevMonth) {
            miniPrevMonth.addEventListener('click', () => {
                miniCalendarAnchor = new Date(miniCalendarAnchor.getFullYear(), miniCalendarAnchor.getMonth() - 1, 1);
                renderMiniCalendar();
            });
        }
        if (miniNextMonth) {
            miniNextMonth.addEventListener('click', () => {
                miniCalendarAnchor = new Date(miniCalendarAnchor.getFullYear(), miniCalendarAnchor.getMonth() + 1, 1);
                renderMiniCalendar();
            });
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !scheduleModal.classList.contains('hidden')) {
                closeModal();
            }
        });

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            renderAll();
            updateLiveTime();
            
            // Update time every minute
            setInterval(() => {
                updateCurrentTimeLine();
                updateLiveTime();
            }, 60000);
            
            // Update toggle indicator on resize
            window.addEventListener('resize', () => {
                updateViewToggle();
                updateCurrentTimeLine();
            });
        });
    </script>
</body>
</html>
