                                <span class="text-xs text-slate-400 font-medium">S</span>
                                <span class="text-xs text-slate-400 font-medium">M</span>
                                <span class="text-xs text-slate-400 font-medium">T</span>
                                <span class="text-xs text-slate-400 font-medium">W</span>
                                <span class="text-xs text-slate-400 font-medium">T</span>
                                <span class="text-xs text-slate-400 font-medium">F</span>
                                <span class="text-xs text-slate-400 font-medium">S</span>
