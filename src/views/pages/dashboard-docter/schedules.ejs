    </div>

    <!-- Schedule Detail Modal -->
    <div id="scheduleModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm" id="modalOverlay"></div>
        <div class="relative bg-white rounded-2xl shadow-2xl max-w-md w-full p-6 animate-slide-in">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-slate-900" id="modalTitle">Schedule Details</h3>
                <button class="p-2 hover:bg-slate-100 rounded-lg transition-colors" id="closeModal" aria-label="Close modal">
                    <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <div id="modalContent">
                <!-- Content will be populated dynamically -->
            </div>
            <div class="flex gap-3 mt-6">
                <button class="flex-1 btn-secondary px-4 py-2.5 rounded-xl text-sm font-semibold focus-ring" id="deleteShiftBtn">Delete</button>
                <button class="flex-1 btn-primary px-4 py-2.5 rounded-xl text-sm font-semibold focus-ring" id="editShiftBtn">Edit Shift</button>
            </div>
        </div>
    </div>

    <script>
        const csrfToken = '<%= csrfToken %>';
        const serverTodayYmd = '<%= typeof todayYmd === "string" ? todayYmd : "" %>';
        const scheduleBlocks = <%- JSON.stringify(scheduleData || []) %>;

        // State
        function parseYmd(value) {
            if (!value) return null;
            const [y, m, d] = String(value).split('-').map(Number);
            if (!y || !m || !d) return null;
            return new Date(y, m - 1, d);
        }

        const fallbackToday = parseYmd(serverTodayYmd) || new Date();
        const firstShiftDate = scheduleBlocks.length ? parseYmd(scheduleBlocks[0].shiftDate) : null;
        let currentView = 'week';
        let currentWeekStart = new Date(firstShiftDate || fallbackToday);
        let selectedBlock = null;
        const HOUR_HEIGHT = 60;
        const START_HOUR = 7;
        const END_HOUR = 20;

        // DOM Elements
        const timeGrid = document.getElementById('timeGrid');
        const dayHeaders = document.getElementById('dayHeaders');
        const currentTimeLine = document.getElementById('currentTimeLine');
        const timeGridContainer = document.getElementById('timeGridContainer');
        const scheduleModal = document.getElementById('scheduleModal');
        const modalOverlay = document.getElementById('modalOverlay');
        const modalContent = document.getElementById('modalContent');
        const modalTitle = document.getElementById('modalTitle');
        const toggleIndicator = document.getElementById('toggleIndicator');
        const addScheduleBtn = document.getElementById('addScheduleBtn');
        const deleteShiftBtn = document.getElementById('deleteShiftBtn');
        const editShiftBtn = document.getElementById('editShiftBtn');

        // Initialize week
        currentWeekStart.setDate(currentWeekStart.getDate() - (currentWeekStart.getDay() === 0 ? 6 : currentWeekStart.getDay() - 1)); // Start from Monday
        currentWeekStart.setHours(0, 0, 0, 0);

        // Helper Functions
        function formatHour(hour) {
            const period = hour >= 12 ? 'PM' : 'AM';
            const displayHour = hour > 12 ? hour - 12 : hour === 0 ? 12 : hour;
            return `${displayHour}:00 ${period}`;
        }

        function getDateStr(date) {
            return date.toISOString().slice(0, 10);
        }

        function getBlockDayIndex(block, weekStart) {
            if (!block.shiftDate) return -1;
            const blockDate = new Date(`${block.shiftDate}T00:00:00`);
            const start = new Date(weekStart);
            start.setHours(0, 0, 0, 0);
            return Math.round((blockDate.getTime() - start.getTime()) / (24 * 60 * 60 * 1000));
        }

        function getBlockClass(type) {
            const classes = {
                'practice': 'block-practice',
                'surgery': 'block-surgery',
                'vip': 'block-vip',
                'meeting': 'block-meeting',
                'break': 'block-break'
            };
            return classes[type] || 'block-practice';
        }

        function getBlockIcon(type) {
            const icons = {
                'practice': '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>',
                'surgery': '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>',
                'vip': '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>',
                'meeting': '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
                'break': '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
            };
            return icons[type] || icons['practice'];
        }

        // Render Day Headers
        function renderDayHeaders() {
            const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
            const today = new Date(fallbackToday);
            today.setHours(0, 0, 0, 0);
            
            dayHeaders.innerHTML = days.map((day, index) => {
                const date = new Date(currentWeekStart);
                date.setDate(currentWeekStart.getDate() + index);
                const isToday = date.toDateString() === today.toDateString();
                
                return `
                    <div class="p-3 text-center border-l border-slate-200 ${isToday ? 'bg-green-50' : ''}">
                        <p class="text-xs font-medium ${isToday ? 'text-green-600' : 'text-slate-400'}">${day}</p>
                        <p class="text-lg font-bold ${isToday ? 'text-green-600' : 'text-slate-900'} mt-0.5">${date.getDate()}</p>
                    </div>
                `;
            }).join('');
            
            // Update week range display
            const endDate = new Date(currentWeekStart);
            endDate.setDate(currentWeekStart.getDate() + 6);
            const startMonth = currentWeekStart.toLocaleDateString('en-US', { month: 'short' });
            const endMonth = endDate.toLocaleDateString('en-US', { month: 'short' });
            document.getElementById('weekRange').textContent = 
                `${startMonth} ${currentWeekStart.getDate()} - ${endMonth !== startMonth ? endMonth + ' ' : ''}${endDate.getDate()}, ${endDate.getFullYear()}`;
        }

        // Render Time Grid
        function renderTimeGrid() {
            const today = new Date(fallbackToday);
            today.setHours(0, 0, 0, 0);
            
            let html = '';
            
            // Time labels column
            html += '<div class="border-r border-slate-100">';
            for (let hour = START_HOUR; hour <= END_HOUR; hour++) {
                html += `
                    <div class="h-[60px] px-2 flex items-start justify-end pt-1">
                        <span class="text-xs text-slate-400 font-medium">${formatHour(hour)}</span>
                    </div>
                `;
            }
            html += '</div>';
            
            // Day columns
            for (let day = 0; day < 7; day++) {
                const date = new Date(currentWeekStart);
                date.setDate(currentWeekStart.getDate() + day);
                const isToday = date.toDateString() === today.toDateString();
                
                html += `<div class="day-column relative border-r border-slate-100 ${isToday ? 'today' : ''}">`;
                
                // Time slots
                for (let hour = START_HOUR; hour <= END_HOUR; hour++) {
                    html += `
                        <div class="time-slot h-[60px] drop-zone" data-day="${day}" data-hour="${hour}"></div>
                    `;
                }
                
                // Schedule blocks for this day
                const dayBlocks = scheduleBlocks.filter((b) => getBlockDayIndex(b, currentWeekStart) === day);
                dayBlocks.forEach(block => {
                    const top = (block.startHour - START_HOUR) * HOUR_HEIGHT;
                    const height = (block.endHour - block.startHour) * HOUR_HEIGHT;
                    const isLarge = height > 60;
                    
                    html += `
                        <div class="schedule-block absolute left-1 right-1 rounded-lg p-2 shadow-sm ${getBlockClass(block.type)}" 
                             style="top: ${top}px; height: ${height}px;"
                             data-id="${block.id}">
                            <div class="flex items-start gap-1.5">
                                <span class="flex-shrink-0 mt-0.5 opacity-60">${getBlockIcon(block.type)}</span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-xs font-semibold text-slate-900 truncate">${block.title}</p>
                                    ${isLarge ? `
                                        <p class="text-xs text-slate-500 mt-0.5 truncate">${block.location}</p>
                                        <p class="text-xs text-slate-400 mt-0.5">${formatHour(block.startHour)} - ${formatHour(block.endHour)}</p>
                                    ` : ''}
                                </div>
                            </div>
                        </div>
                    `;
                });
                
                html += '</div>';
            }
            
            timeGrid.innerHTML = html;
            
            // Add click handlers to blocks
            document.querySelectorAll('.schedule-block').forEach(block => {
                block.addEventListener('click', () => openBlockModal(block.dataset.id));
            });
            
            // Update current time line
            updateCurrentTimeLine();
        }

        // Update current time line position
        function updateCurrentTimeLine() {
            const now = new Date();
            const today = now.getDay();
            const dayIndex = today === 0 ? 6 : today - 1; // Convert to Monday-based index
            
            const hour = now.getHours();
            const minute = now.getMinutes();
            
            if (hour >= START_HOUR && hour <= END_HOUR) {
                const top = (hour - START_HOUR) * HOUR_HEIGHT + (minute / 60) * HOUR_HEIGHT;
                currentTimeLine.style.top = `${top}px`;
                
                // Position within today's column (column index is dayIndex + 1 because of time label column)
                const columnWidth = timeGridContainer.offsetWidth / 8;
                currentTimeLine.style.left = `${(dayIndex + 1) * columnWidth}px`;
                currentTimeLine.style.right = `${(7 - dayIndex - 1) * columnWidth}px`;
                currentTimeLine.style.display = 'block';
            } else {
                currentTimeLine.style.display = 'none';
            }
        }

        // Open block modal
        function openBlockModal(blockId) {
            selectedBlock = scheduleBlocks.find((b) => String(b.id) === String(blockId));
            if (!selectedBlock) return;
            
            modalTitle.textContent = selectedBlock.title;
            modalContent.innerHTML = `
                <div class="space-y-4">
                    <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl">
                        <div class="w-10 h-10 rounded-xl flex items-center justify-center ${getBlockClass(selectedBlock.type)}">
                            ${getBlockIcon(selectedBlock.type)}
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-slate-900 capitalize">${selectedBlock.type}</p>
                            <p class="text-xs text-slate-500">${selectedBlock.duration || `${selectedBlock.endHour - selectedBlock.startHour} hours`}</p>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <p class="text-xs text-slate-500 mb-1">Shift</p>
                            <p class="text-sm font-semibold text-slate-900">${selectedBlock.shiftType || '-'}</p>
                        </div>
                        <div>
                            <p class="text-xs text-slate-500 mb-1">Time</p>
                            <p class="text-sm font-semibold text-slate-900">${formatHour(selectedBlock.startHour)} - ${formatHour(selectedBlock.endHour)}</p>
                        </div>
                        <div class="col-span-2">
                            <p class="text-xs text-slate-500 mb-1">Location</p>
                            <p class="text-sm font-semibold text-slate-900">${selectedBlock.location || '-'}</p>
                        </div>
                    </div>
                    ${selectedBlock.shiftDate ? `
                        <div>
                            <p class="text-xs text-slate-500 mb-1">Date</p>
                            <p class="text-sm font-semibold text-slate-900">${selectedBlock.shiftDate}</p>
                        </div>
                    ` : ''}
                    ${selectedBlock.patientCount ? `
                        <div>
                            <p class="text-xs text-slate-500 mb-1">Patients Scheduled</p>
                            <p class="text-sm font-semibold text-slate-900">${selectedBlock.patientCount} patients</p>
                        </div>
                    ` : ''}
                    ${selectedBlock.patientName ? `
                        <div>
                            <p class="text-xs text-slate-500 mb-1">Patient</p>
                            <p class="text-sm font-semibold text-slate-900">${selectedBlock.patientName}</p>
                        </div>
                    ` : ''}
                </div>
            `;
            
            scheduleModal.classList.remove('hidden');
        }

        // Close modal
        function closeModal() {
            scheduleModal.classList.add('hidden');
            selectedBlock = null;
        }

        async function postForm(url, payload) {
            const res = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
                    'x-csrf-token': csrfToken
                },
                body: new URLSearchParams(payload)
            });
            const json = await res.json().catch(() => ({ ok: false, message: 'Request failed' }));
            if (!res.ok || !json.ok) throw new Error(json.message || 'Request failed');
            return json;
        }

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        async function openCreateShiftModal() {
            const { value: formValues } = await Swal.fire({
                title: 'Add Schedule',
                html: `
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div class="sm:col-span-1">
                            <label class="block text-xs font-semibold text-slate-500 mb-1">Date</label>
                            <input id="swal_shift_date" type="date" class="hms-swal-input">
                        </div>
                        <div class="sm:col-span-1">
                            <label class="block text-xs font-semibold text-slate-500 mb-1">Shift Type</label>
                            <select id="swal_shift_type" class="hms-swal-input">
                                <option value="Morning">Morning</option>
                                <option value="Afternoon">Afternoon</option>
                                <option value="Night">Night</option>
                            </select>
                        </div>
                        <div class="sm:col-span-1">
                            <label class="block text-xs font-semibold text-slate-500 mb-1">Department</label>
                            <input id="swal_department" class="hms-swal-input" placeholder="Cardiology / ICU / etc">
                        </div>
                        <div class="sm:col-span-1">
                            <label class="block text-xs font-semibold text-slate-500 mb-1">Notes</label>
                            <input id="swal_notes" class="hms-swal-input" placeholder="Room/location">
                        </div>
                    </div>
                `,
                showCancelButton: true,
                cancelButtonText: 'Cancel',
                confirmButtonText: 'Create',
                buttonsStyling: false,
                customClass: {
                    popup: 'hms-swal-popup',
                    title: 'hms-swal-title',
                    htmlContainer: 'hms-swal-html',
                    actions: 'hms-swal-actions',
                    confirmButton: 'hms-swal-confirm',
                    cancelButton: 'hms-swal-cancel'
                },
                preConfirm: () => {
                    const shift_date = document.getElementById('swal_shift_date').value;
                    const shift_type = document.getElementById('swal_shift_type').value;
                    if (!shift_date || !shift_type) {
                        Swal.showValidationMessage('Date and shift type are required');
                        return null;
                    }
                    return {
                        shift_date,
                        shift_type,
                        department: document.getElementById('swal_department').value.trim(),
                        notes: document.getElementById('swal_notes').value.trim()
                    };
                }
            });
            if (!formValues) return;
            try {
                await postForm('/doctor/schedules', formValues);
                await Swal.fire({ icon: 'success', title: 'Created', text: 'Shift created' });
                window.location.reload();
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Failed', text: error.message });
            }
        }

        async function openEditShiftModal() {
            if (!selectedBlock) {
                Swal.fire({ icon: 'info', title: 'Select a shift first' });
                return;
            }

            const { value: formValues } = await Swal.fire({
                title: 'Edit Shift',
                html: `
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div class="sm:col-span-1">
                            <label class="block text-xs font-semibold text-slate-500 mb-1">Date</label>
                            <input id="swal_shift_date" type="date" class="hms-swal-input" value="${escapeHtml(selectedBlock.shiftDate || '')}">
                        </div>
                        <div class="sm:col-span-1">
                            <label class="block text-xs font-semibold text-slate-500 mb-1">Shift Type</label>
                            <select id="swal_shift_type" class="hms-swal-input">
                                <option value="Morning" ${selectedBlock.shiftType === 'Morning' ? 'selected' : ''}>Morning</option>
                                <option value="Afternoon" ${selectedBlock.shiftType === 'Afternoon' ? 'selected' : ''}>Afternoon</option>
                                <option value="Night" ${selectedBlock.shiftType === 'Night' ? 'selected' : ''}>Night</option>
                            </select>
                        </div>
                        <div class="sm:col-span-1">
                            <label class="block text-xs font-semibold text-slate-500 mb-1">Department</label>
                            <input id="swal_department" class="hms-swal-input" placeholder="Cardiology / ICU / etc" value="${escapeHtml(selectedBlock.department || '')}">
                        </div>
                        <div class="sm:col-span-1">
                            <label class="block text-xs font-semibold text-slate-500 mb-1">Notes</label>
                            <input id="swal_notes" class="hms-swal-input" placeholder="Room/location" value="${escapeHtml(selectedBlock.notes || selectedBlock.location || '')}">
                        </div>
                    </div>
                `,
                showCancelButton: true,
                cancelButtonText: 'Cancel',
                confirmButtonText: 'Save',
                buttonsStyling: false,
                customClass: {
                    popup: 'hms-swal-popup',
                    title: 'hms-swal-title',
                    htmlContainer: 'hms-swal-html',
                    actions: 'hms-swal-actions',
                    confirmButton: 'hms-swal-confirm',
                    cancelButton: 'hms-swal-cancel'
                },
                preConfirm: () => {
                    const shift_date = document.getElementById('swal_shift_date').value;
                    const shift_type = document.getElementById('swal_shift_type').value;
                    if (!shift_date || !shift_type) {
                        Swal.showValidationMessage('Date and shift type are required');
                        return null;
                    }
                    return {
                        shift_date,
                        shift_type,
                        department: document.getElementById('swal_department').value.trim(),
                        notes: document.getElementById('swal_notes').value.trim()
                    };
                }
            });

            if (!formValues) return;
            try {
                await postForm(`/doctor/schedules/${selectedBlock.id}/update`, formValues);
                closeModal();
                await Swal.fire({ icon: 'success', title: 'Updated', text: 'Shift updated' });
                window.location.reload();
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Failed', text: error.message });
            }
        }

        async function onDeleteShift() {
            if (!selectedBlock) return;
            const confirm = await Swal.fire({
                icon: 'warning',
                title: 'Delete shift?',
                text: `${selectedBlock.title} on ${selectedBlock.shiftDate} will be removed.`,
                showCancelButton: true,
                confirmButtonText: 'Delete'
            });
            if (!confirm.isConfirmed) return;
            try {
                await postForm(`/doctor/schedules/${selectedBlock.id}/delete`, {});
                closeModal();
                await Swal.fire({ icon: 'success', title: 'Deleted', text: 'Shift deleted' });
                window.location.reload();
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Failed', text: error.message });
            }
        }

        // Render mini calendar
        function renderMiniCalendar() {
            const container = document.getElementById('miniCalendar');
            const titleEl = document.getElementById('miniCalendarTitle');
            const monthAnchor = new Date(currentWeekStart);
            const today = new Date(fallbackToday);
            today.setHours(0, 0, 0, 0);

            const firstDay = new Date(monthAnchor.getFullYear(), monthAnchor.getMonth(), 1);
            const lastDay = new Date(monthAnchor.getFullYear(), monthAnchor.getMonth() + 1, 0);
            if (titleEl) {
                titleEl.textContent = monthAnchor.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
            }
            
            let html = '';
            
            // Empty cells for days before the first day of the month
            for (let i = 0; i < firstDay.getDay(); i++) {
                html += '<div class="w-7 h-7"></div>';
            }
            
            // Days of the month
            for (let day = 1; day <= lastDay.getDate(); day++) {
                const date = new Date(monthAnchor.getFullYear(), monthAnchor.getMonth(), day);
                const isToday = date.toDateString() === today.toDateString();
                const hasEvent = scheduleBlocks.some(b => {
                    if (!b.shiftDate) return false;
                    return b.shiftDate === getDateStr(date);
                });
                
                html += `
                    <button class="mini-calendar-day relative w-7 h-7 text-xs font-medium rounded-lg ${isToday ? 'today' : ''} ${hasEvent && !isToday ? 'has-event' : ''}">
                        ${day}
                    </button>
                `;
            }
            
            container.innerHTML = html;
        }

        // Update view toggle indicator
        function updateViewToggle() {
            const activeBtn = document.querySelector(`.view-toggle-btn[data-view="${currentView}"]`);
            if (activeBtn) {
                const indicator = document.getElementById('toggleIndicator');
                indicator.style.width = `${activeBtn.offsetWidth}px`;
                indicator.style.left = `${activeBtn.offsetLeft}px`;
            }
        }

        // Update live time
        function updateLiveTime() {
            const now = new Date();
            document.getElementById('liveTime').textContent = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
            document.getElementById('liveDate').textContent = now.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
        }

        // Event Listeners
        document.getElementById('prevWeek').addEventListener('click', () => {
            currentWeekStart.setDate(currentWeekStart.getDate() - 7);
            renderDayHeaders();
            renderTimeGrid();
            renderMiniCalendar();
        });

        document.getElementById('nextWeek').addEventListener('click', () => {
            currentWeekStart.setDate(currentWeekStart.getDate() + 7);
            renderDayHeaders();
            renderTimeGrid();
            renderMiniCalendar();
        });

        document.getElementById('todayBtn').addEventListener('click', () => {
            const today = new Date(fallbackToday);
            currentWeekStart = new Date(today);
            currentWeekStart.setDate(currentWeekStart.getDate() - (currentWeekStart.getDay() === 0 ? 6 : currentWeekStart.getDay() - 1));
            renderDayHeaders();
            renderTimeGrid();
            renderMiniCalendar();
        });

        document.querySelectorAll('.view-toggle-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.view-toggle-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentView = btn.dataset.view;
                updateViewToggle();
            });
        });

        document.getElementById('closeModal').addEventListener('click', closeModal);
        modalOverlay.addEventListener('click', closeModal);
        addScheduleBtn.addEventListener('click', openCreateShiftModal);
        deleteShiftBtn.addEventListener('click', onDeleteShift);
        editShiftBtn.addEventListener('click', openEditShiftModal);

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !scheduleModal.classList.contains('hidden')) {
                closeModal();
            }
        });

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            renderDayHeaders();
            renderTimeGrid();
            renderMiniCalendar();
            updateViewToggle();
            updateLiveTime();
            
            // Update time every minute
            setInterval(() => {
                updateCurrentTimeLine();
                updateLiveTime();
            }, 60000);
            
            // Update toggle indicator on resize
            window.addEventListener('resize', updateViewToggle);
        });
    </script>
</body>
</html>
