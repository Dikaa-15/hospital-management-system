    <!-- Schedule Detail Modal -->
    <div id="scheduleModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-slate-900/50 backdrop-blur-sm" id="modalOverlay"></div>
        <div class="relative bg-white rounded-2xl shadow-2xl max-w-md w-full p-6 animate-slide-in">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-slate-900" id="modalTitle">Schedule Details</h3>
                <button class="p-2 hover:bg-slate-100 rounded-lg transition-colors" id="closeModal" aria-label="Close modal">
                    <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <div id="modalContent">
                <!-- Content will be populated dynamically -->
            </div>
            <div class="flex gap-3 mt-6">
                <button class="flex-1 btn-secondary px-4 py-2.5 rounded-xl text-sm font-semibold focus-ring" id="deleteShiftBtn">Delete</button>
                <button class="flex-1 btn-primary px-4 py-2.5 rounded-xl text-sm font-semibold focus-ring" id="editShiftBtn">Edit Shift</button>
            </div>
        </div>
    </div>

    <script>
        const csrfToken = '<%= csrfToken %>';
        const serverTodayYmd = '<%= typeof todayYmd === "string" ? todayYmd : "" %>';
        const scheduleBlocks = <%- JSON.stringify(scheduleData || []) %>;

        function parseYmd(value) {
            if (!value) return null;
            const [y, m, d] = String(value).split('-').map(Number);
            if (!y || !m || !d) return null;
            return new Date(y, m - 1, d);
        }

        function startOfDay(date) {
            const d = new Date(date);
            d.setHours(0, 0, 0, 0);
            return d;
        }

        function startOfWeek(date) {
            const d = startOfDay(date);
            const offset = d.getDay() === 0 ? 6 : d.getDay() - 1;
            d.setDate(d.getDate() - offset);
            return d;
        }

        function toYmd(date) {
            const d = new Date(date);
            const y = d.getFullYear();
            const m = String(d.getMonth() + 1).padStart(2, '0');
            const day = String(d.getDate()).padStart(2, '0');
            return `${y}-${m}-${day}`;
        }

        function plusDays(date, days) {
            const d = new Date(date);
            d.setDate(d.getDate() + days);
            return d;
        }

        // State
        const fallbackToday = startOfDay(parseYmd(serverTodayYmd) || new Date());
        const firstShiftDate = scheduleBlocks.length ? startOfDay(parseYmd(scheduleBlocks[0].shiftDate) || fallbackToday) : fallbackToday;
        let currentView = 'week';
        let selectedDate = new Date(firstShiftDate);
        let currentWeekStart = startOfWeek(selectedDate);
        let currentMonthAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
        let miniCalendarAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
        let selectedBlock = null;
        const HOUR_HEIGHT = 60;
        const START_HOUR = 7;
        const END_HOUR = 20;
        const TIME_LABEL_WIDTH = 96;

        // DOM Elements
        const timeGrid = document.getElementById('timeGrid');
        const timelineHeaderRow = document.getElementById('timelineHeaderRow');
        const currentTimeLine = document.getElementById('currentTimeLine');
        const timeGridContainer = document.getElementById('timeGridContainer');
        const monthGridWrap = document.getElementById('monthGridWrap');
        const monthGrid = document.getElementById('monthGrid');
        const scheduleList = document.getElementById('scheduleList');
        const scheduleListMeta = document.getElementById('scheduleListMeta');
        const syncCalendarBtn = document.getElementById('syncCalendarBtn');
        const miniPrevMonth = document.getElementById('miniPrevMonth');
        const miniNextMonth = document.getElementById('miniNextMonth');
        const scheduleModal = document.getElementById('scheduleModal');
        const modalOverlay = document.getElementById('modalOverlay');
        const modalContent = document.getElementById('modalContent');
        const modalTitle = document.getElementById('modalTitle');
        const toggleIndicator = document.getElementById('toggleIndicator');
        const addScheduleBtn = document.getElementById('addScheduleBtn');
        const deleteShiftBtn = document.getElementById('deleteShiftBtn');
        const editShiftBtn = document.getElementById('editShiftBtn');

        function formatHour(hour) {
            const period = hour >= 12 ? 'PM' : 'AM';
            const displayHour = hour > 12 ? hour - 12 : hour === 0 ? 12 : hour;
            return `${displayHour}:00 ${period}`;
        }

        function getBlockClass(type) {
            const classes = {
                practice: 'block-practice',
                surgery: 'block-surgery',
                vip: 'block-vip',
                meeting: 'block-meeting',
                break: 'block-break'
            };
            return classes[type] || 'block-practice';
        }

        function getBlockIcon(type) {
            const icons = {
                practice: '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>',
                surgery: '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>',
                vip: '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>',
                meeting: '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
                break: '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
            };
            return icons[type] || icons.practice;
        }

        function getViewStartDate() {
            if (currentView === 'day') return startOfDay(selectedDate);
            if (currentView === 'month') return new Date(currentMonthAnchor);
            return startOfWeek(currentWeekStart);
        }

        function getVisibleDayCount() {
            return currentView === 'day' ? 1 : 7;
        }

        function formatRangeLabel() {
            const labelEl = document.getElementById('weekRange');
            if (!labelEl) return;
            if (currentView === 'month') {
                labelEl.textContent = currentMonthAnchor.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
                return;
            }

            if (currentView === 'day') {
                labelEl.textContent = selectedDate.toLocaleDateString('en-US', {
                    weekday: 'short',
                    month: 'short',
                    day: 'numeric',
                    year: 'numeric'
                });
                return;
            }

            const start = startOfWeek(currentWeekStart);
            const end = plusDays(start, 6);
            const startMonth = start.toLocaleDateString('en-US', { month: 'short' });
            const endMonth = end.toLocaleDateString('en-US', { month: 'short' });
            labelEl.textContent = `${startMonth} ${start.getDate()} - ${endMonth !== startMonth ? `${endMonth} ` : ''}${end.getDate()}, ${end.getFullYear()}`;
        }

        function renderTimelineHeaders() {
            if (currentView === 'month') {
                timelineHeaderRow.classList.add('hidden');
                return;
            }
            timelineHeaderRow.classList.remove('hidden');

            const dayCount = getVisibleDayCount();
            const start = getViewStartDate();
            const todayYmd = toYmd(fallbackToday);
            const selectedYmd = toYmd(selectedDate);
            timelineHeaderRow.style.gridTemplateColumns = `${TIME_LABEL_WIDTH}px repeat(${dayCount}, minmax(0, 1fr))`;

            let html = `<div class="timeline-tz-cell"><span class="text-xs font-semibold text-slate-400">GMT+7</span></div>`;
            for (let i = 0; i < dayCount; i++) {
                const date = plusDays(start, i);
                const isToday = toYmd(date) === todayYmd;
                const ymd = toYmd(date);
                const isSelected = ymd === selectedYmd;
                html += `
                    <button type="button" class="timeline-day-cell ${isToday ? 'today' : ''} ${isSelected ? 'selected' : ''}" data-date="${ymd}" aria-label="Open ${ymd}">
                        <p class="text-[11px] font-semibold uppercase tracking-wide ${isToday ? 'text-green-600' : 'text-slate-400'}">${date.toLocaleDateString('en-US', { weekday: 'short' })}</p>
                        <p class="text-lg font-bold ${isToday ? 'text-green-700' : 'text-slate-900'} mt-0.5">${date.getDate()}</p>
                    </button>
                `;
            }
            timelineHeaderRow.innerHTML = html;
            timelineHeaderRow.querySelectorAll('.timeline-day-cell[data-date]').forEach((el) => {
                el.addEventListener('click', () => {
                    const picked = parseYmd(el.dataset.date);
                    if (!picked) return;
                    selectedDate = startOfDay(picked);
                    currentWeekStart = startOfWeek(selectedDate);
                    currentMonthAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
                    miniCalendarAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
                    currentView = 'day';
                    document.querySelectorAll('.view-toggle-btn').forEach((btn) => btn.classList.toggle('active', btn.dataset.view === 'day'));
                    renderAll();
                });
            });
        }

        function getBlocksForDate(date) {
            const ymd = toYmd(date);
            return scheduleBlocks.filter((b) => b.shiftDate === ymd);
        }

        function renderTimelineGrid() {
            if (currentView === 'month') {
                timeGridContainer.classList.add('hidden');
                currentTimeLine.style.display = 'none';
                return;
            }
            timeGridContainer.classList.remove('hidden');

            const start = getViewStartDate();
            const dayCount = getVisibleDayCount();
            const todayYmd = toYmd(fallbackToday);
            timeGrid.style.gridTemplateColumns = `${TIME_LABEL_WIDTH}px repeat(${dayCount}, minmax(0, 1fr))`;

            let html = '<div class="border-r border-slate-100 time-label-column">';
            for (let hour = START_HOUR; hour <= END_HOUR; hour++) {
                html += `
                    <div class="h-[60px] px-2 flex items-start justify-end pt-1">
                        <span class="text-xs text-slate-400 font-medium">${formatHour(hour)}</span>
                    </div>
                `;
            }
            html += '</div>';

            for (let day = 0; day < dayCount; day++) {
                const date = plusDays(start, day);
                const isToday = toYmd(date) === todayYmd;
                html += `<div class="day-column relative border-r border-slate-100 ${isToday ? 'today' : ''}">`;

                for (let hour = START_HOUR; hour <= END_HOUR; hour++) {
                    html += `<div class="time-slot h-[60px]"></div>`;
                }

                getBlocksForDate(date).forEach((block) => {
                    const top = (Number(block.startHour || START_HOUR) - START_HOUR) * HOUR_HEIGHT;
                    const height = Math.max(40, (Number(block.endHour || START_HOUR + 1) - Number(block.startHour || START_HOUR)) * HOUR_HEIGHT);
                    const isLarge = height >= 72;
                    html += `
                        <button type="button"
                            class="schedule-block absolute left-1 right-1 rounded-lg p-2 shadow-sm text-left ${getBlockClass(block.type)}"
                            style="top:${top}px;height:${height}px;"
                            data-id="${block.id}">
                            <div class="flex items-start gap-1.5">
                                <span class="flex-shrink-0 mt-0.5 opacity-70">${getBlockIcon(block.type)}</span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-xs font-semibold text-slate-900 truncate">${escapeHtml(block.title || block.department || 'Shift')}</p>
                                    ${isLarge ? `<p class="text-xs text-slate-500 truncate mt-0.5">${escapeHtml(block.location || '-')}</p>` : ''}
                                    <p class="text-xs text-slate-400 mt-0.5">${formatHour(Number(block.startHour || START_HOUR))} - ${formatHour(Number(block.endHour || START_HOUR + 1))}</p>
                                </div>
                            </div>
                        </button>
                    `;
                });

                html += '</div>';
            }

            timeGrid.innerHTML = html;
            document.querySelectorAll('.schedule-block').forEach((el) => {
                el.addEventListener('click', () => openBlockModal(el.dataset.id));
            });
            updateCurrentTimeLine();
        }

        function renderMonthGrid() {
            if (currentView !== 'month') {
                monthGridWrap.classList.add('hidden');
                return;
            }
            monthGridWrap.classList.remove('hidden');
            const anchor = new Date(currentMonthAnchor.getFullYear(), currentMonthAnchor.getMonth(), 1);
            const firstWeekday = (anchor.getDay() + 6) % 7; // monday-based
            const gridStart = plusDays(anchor, -firstWeekday);
            const activeYmd = toYmd(selectedDate);

            let html = '';
            for (let i = 0; i < 42; i++) {
                const date = plusDays(gridStart, i);
                const ymd = toYmd(date);
                const inMonth = date.getMonth() === currentMonthAnchor.getMonth();
                const blocks = getBlocksForDate(date);
                const isActive = ymd === activeYmd;
                html += `
                    <button type="button"
                        class="month-cell ${inMonth ? '' : 'other-month'} ${isActive ? 'active-day' : ''}"
                        data-date="${ymd}">
                        <div class="flex items-center justify-between">
                            <span class="text-xs font-semibold">${date.getDate()}</span>
                            ${blocks.length ? `<span class="text-[10px] text-slate-500">${blocks.length} evt</span>` : ''}
                        </div>
                        <div class="mt-1 space-y-1">
                            ${blocks.slice(0, 2).map((b) => `<span class="month-event-pill ${getBlockClass(b.type)}">${escapeHtml(b.title || b.department || 'Shift')}</span>`).join('')}
                            ${blocks.length > 2 ? `<p class="text-[10px] text-slate-500">+${blocks.length - 2} more</p>` : ''}
                        </div>
                    </button>
                `;
            }
            monthGrid.innerHTML = html;

            monthGrid.querySelectorAll('.month-cell').forEach((cell) => {
                cell.addEventListener('click', () => {
                    const picked = parseYmd(cell.dataset.date);
                    if (!picked) return;
                    selectedDate = startOfDay(picked);
                    miniCalendarAnchor = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
                    currentView = 'day';
                    document.querySelectorAll('.view-toggle-btn').forEach((btn) => btn.classList.toggle('active', btn.dataset.view === 'day'));
                    renderAll();
                });
            });
        }

        function updateCurrentTimeLine() {
            if (currentView === 'month') {
                currentTimeLine.style.display = 'none';
                return;
            }

            const now = new Date();
            if (now.getHours() < START_HOUR || now.getHours() > END_HOUR) {
                currentTimeLine.style.display = 'none';
                return;
            }

            const start = getViewStartDate();
            const dayCount = getVisibleDayCount();
            const dayIndex = Math.floor((startOfDay(now).getTime() - startOfDay(start).getTime()) / (24 * 60 * 60 * 1000));
            if (dayIndex < 0 || dayIndex >= dayCount) {
                currentTimeLine.style.display = 'none';
                return;
            }

            const top = (now.getHours() - START_HOUR) * HOUR_HEIGHT + (now.getMinutes() / 60) * HOUR_HEIGHT;
            const usableWidth = Math.max(0, timeGridContainer.clientWidth - TIME_LABEL_WIDTH);
            const colWidth = usableWidth / dayCount;
            currentTimeLine.style.top = `${top}px`;
            currentTimeLine.style.left = `${TIME_LABEL_WIDTH + dayIndex * colWidth}px`;
            currentTimeLine.style.width = `${colWidth}px`;
            currentTimeLine.style.right = 'auto';
            currentTimeLine.style.display = 'block';
        }

