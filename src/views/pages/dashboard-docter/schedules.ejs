        function getListBlocks() {
            if (currentView === 'day') {
                return getBlocksForDate(selectedDate);
            }
            if (currentView === 'month') {
                return scheduleBlocks.filter((b) => {
                    const d = parseYmd(b.shiftDate);
                    return d && d.getFullYear() === currentMonthAnchor.getFullYear() && d.getMonth() === currentMonthAnchor.getMonth();
                });
            }
            const weekStart = startOfWeek(currentWeekStart);
            const weekEnd = plusDays(weekStart, 6);
            return scheduleBlocks.filter((b) => {
                const d = parseYmd(b.shiftDate);
                return d && d >= weekStart && d <= weekEnd;
            });
        }

        function renderScheduleList() {
            if (!scheduleList) return;
            const list = [...getListBlocks()].sort((a, b) => {
                if (a.shiftDate !== b.shiftDate) return String(a.shiftDate || '').localeCompare(String(b.shiftDate || ''));
                return Number(a.startHour || 0) - Number(b.startHour || 0);
            });
            if (scheduleListMeta) {
                scheduleListMeta.textContent = `${list.length} item(s)`;
            }

            if (!list.length) {
                scheduleList.innerHTML = `<div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-4 py-6 text-sm text-slate-500 text-center">No schedules for this view.</div>`;
                return;
            }

            scheduleList.innerHTML = list
                .map((block) => {
                    const duration = Math.max(0, Number(block.endHour || 0) - Number(block.startHour || 0));
                    return `
                        <button type="button" class="schedule-list-card w-full text-left rounded-xl border border-slate-200 bg-white p-4" data-id="${block.id}">
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <p class="text-sm font-semibold text-slate-900">${escapeHtml(block.title || block.department || 'Shift')}</p>
                                    <p class="text-xs text-slate-500 mt-0.5">${escapeHtml(block.shiftDate || '-')} • ${formatHour(Number(block.startHour || START_HOUR))} - ${formatHour(Number(block.endHour || START_HOUR + 1))}</p>
                                </div>
                                <span class="inline-flex px-2 py-1 rounded-full text-[11px] font-semibold ${getBlockClass(block.type)}">${escapeHtml(block.shiftType || 'Shift')}</span>
                            </div>
                            <div class="mt-2 grid grid-cols-1 sm:grid-cols-2 gap-2">
                                <div class="text-xs text-slate-600">Department: <span class="font-medium text-slate-800">${escapeHtml(block.department || '-')}</span></div>
                                <div class="text-xs text-slate-600">Duration: <span class="font-medium text-slate-800">${duration}h</span></div>
                                <div class="text-xs text-slate-600 sm:col-span-2">Notes: <span class="font-medium text-slate-800">${escapeHtml(block.notes || block.location || '-')}</span></div>
                            </div>
                        </button>
                    `;
