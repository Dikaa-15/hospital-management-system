<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Medical Records - Patient Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        'jakarta': ['Plus Jakarta Sans', 'sans-serif'],
                    },
                    colors: {
                        brand: '#4ADE80',
                    }
                }
            }
        }
    </script>
    <style>
        :root {
            --brand: #4ADE80;
        }

        * {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 6px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

        .focus-ring {
            outline: 2px solid transparent;
            outline-offset: 2px;
        }
        .focus-ring:focus-visible {
            outline: 2px solid #86efac;
            outline-offset: 2px;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 antialiased">
    <div class="flex min-h-screen">

        <!-- Sidebar (Patient Portal) -->
        <aside class="w-20 lg:w-64 bg-white border-r border-slate-100 flex flex-col fixed h-full z-30">
            <div class="p-4 lg:p-6 border-b border-slate-100">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-green-400 flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                        </svg>
                    </div>
                    <span class="hidden lg:block text-lg font-bold text-slate-900">Patient Portal</span>
                </div>
            </div>

            <nav class="flex-1 p-3 lg:p-4 space-y-1">
                <a href="prescriptions.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50 focus-ring">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    <span class="hidden lg:block">Home</span>
                </a>
                <a href="my-appointments.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50 focus-ring">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <span class="hidden lg:block">Appointments</span>
                </a>
                <a href="medical-records.html" class="flex items-center gap-3 px-3 py-3 rounded-xl bg-green-50 text-green-700 font-medium" aria-current="page">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <span class="hidden lg:block">Medical Records</span>
                </a>
                <a href="billing.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50 focus-ring">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                    <span class="hidden lg:block">Prescriptions</span>
                </a>
                <a href="overview.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50 focus-ring">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    <span class="hidden lg:block">Billing</span>
                </a>
            </nav>

            <div class="p-4 border-t border-slate-100">
                <div class="flex items-center gap-3">
                    <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=80&h=80&fit=crop&crop=face" alt="User" class="w-10 h-10 rounded-full object-cover">
                    <div class="hidden lg:block flex-1 min-w-0">
                        <p class="text-sm font-semibold text-slate-900 truncate">Jane Doe</p>
                        <p class="text-xs text-slate-500">Patient ID: PX-2847</p>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 ml-20 lg:ml-64">
            <header class="sticky top-0 bg-slate-50/90 backdrop-blur-lg z-20 border-b border-slate-100">
                <div class="flex items-center justify-between px-6 lg:px-8 py-4">
                    <div>
                        <h1 class="text-2xl lg:text-3xl font-bold text-slate-900">Medical Records</h1>
                        <p class="text-sm text-slate-500 mt-1">Personal health folder with transparent history and lab data.</p>
                    </div>
                    <div class="flex items-center gap-3">
                        <button class="px-4 py-2 rounded-xl bg-white border border-slate-200 text-sm font-semibold text-slate-600 hover:text-slate-900 focus-ring">
                            Share Access
                        </button>
                        <button class="px-4 py-2 rounded-xl bg-green-400 text-green-900 text-sm font-semibold hover:bg-green-300 focus-ring">
                            Download PDF
                        </button>
                    </div>
                </div>

                <!-- Quick Vitals Summary -->
                <div class="px-6 lg:px-8 pb-4">
                    <div class="bg-white border border-slate-100 rounded-2xl px-4 py-3 flex flex-col lg:flex-row gap-4 lg:items-center">
                        <div class="flex items-center gap-3 text-sm">
                            <div class="w-8 h-8 rounded-lg bg-green-50 flex items-center justify-center">
                                <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v12m6-6H6"/>
                                </svg>
                            </div>
                            <div>
                                <div class="text-xs text-slate-500">Blood Type</div>
                                <div class="font-semibold text-slate-900">A+</div>
                            </div>
                        </div>
                        <div class="hidden lg:block w-px h-8 bg-slate-100"></div>
                        <div class="flex items-center gap-3 text-sm">
                            <div class="w-8 h-8 rounded-lg bg-red-50 flex items-center justify-center">
                                <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m2 9H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                </svg>
                            </div>
                            <div>
                                <div class="text-xs text-slate-500">Allergies</div>
                                <div class="font-semibold text-slate-900">Seafood, Penicillin</div>
                            </div>
                        </div>
                        <div class="hidden lg:block w-px h-8 bg-slate-100"></div>
                        <div class="flex items-center gap-3 text-sm">
                            <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center">
                                <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M12 18a6 6 0 100-12 6 6 0 000 12z"/>
                                </svg>
                            </div>
                            <div>
                                <div class="text-xs text-slate-500">Chronic Conditions</div>
                                <div class="font-semibold text-slate-900">Hypertension (Stage 1)</div>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <div class="px-6 lg:px-8 py-8 grid grid-cols-1 xl:grid-cols-[1.6fr_1fr] gap-8">

                <!-- Main Column -->
                <section class="space-y-6">
                    <!-- Categories -->
                    <div class="bg-white border border-slate-100 rounded-2xl p-4 flex flex-wrap gap-2">
                        <button class="px-4 py-2 rounded-xl text-sm font-semibold bg-green-50 text-green-700 border border-green-100">Visit History</button>
                        <button class="px-4 py-2 rounded-xl text-sm font-semibold text-slate-600 border border-slate-100 hover:text-slate-900">Lab Results</button>
                        <button class="px-4 py-2 rounded-xl text-sm font-semibold text-slate-600 border border-slate-100 hover:text-slate-900">Radiology (X-Ray/MRI)</button>
                        <button class="px-4 py-2 rounded-xl text-sm font-semibold text-slate-600 border border-slate-100 hover:text-slate-900">Vaccinations</button>
                    </div>

                    <!-- Timeline -->
                    <div class="space-y-4">
                        <div class="bg-white border border-slate-100 rounded-2xl p-5">
                            <div class="flex items-start justify-between gap-4">
                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center">
                                        <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-xs text-slate-500">Feb 18, 2026 • CityCare Clinic</p>
                                        <h3 class="text-lg font-bold text-slate-900">Post-Op Check-up</h3>
                                        <p class="text-sm font-medium text-slate-500 mt-1">Dr. Aisha Rahman</p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-2">
                                    <button class="px-3 py-2 rounded-xl text-sm font-semibold border border-slate-100 text-slate-600 hover:text-slate-900">View Summary</button>
                                    <button class="px-3 py-2 rounded-xl text-sm font-semibold bg-green-400 text-green-900">Download PDF</button>
                                </div>
                            </div>
                            <div class="mt-4 flex items-center gap-3 text-xs text-slate-500">
                                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-green-50 text-green-700">
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>Vitals Normal
                                </span>
                                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-slate-50 text-slate-600">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3"/></svg>
                                    30 min consult
                                </span>
                            </div>
                        </div>

                        <div class="bg-white border border-slate-100 rounded-2xl p-5">
                            <div class="flex items-start justify-between gap-4">
                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center">
                                        <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-xs text-slate-500">Jan 30, 2026 • St. Mary Hospital</p>
                                        <h3 class="text-lg font-bold text-slate-900">Common Cold</h3>
                                        <p class="text-sm font-medium text-slate-500 mt-1">Dr. Kevin Huang</p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-2">
                                    <button class="px-3 py-2 rounded-xl text-sm font-semibold border border-slate-100 text-slate-600 hover:text-slate-900">View Summary</button>
                                    <button class="px-3 py-2 rounded-xl text-sm font-semibold bg-green-400 text-green-900">Download PDF</button>
                                </div>
                            </div>
                            <div class="mt-4 flex items-center gap-3 text-xs text-slate-500">
                                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-green-50 text-green-700">
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>Lab Results Updated
                                </span>
                                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-amber-50 text-amber-700">
                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>Follow-up in 2 weeks
                                </span>
                            </div>
                        </div>

                        <div class="bg-white border border-slate-100 rounded-2xl p-5">
                            <div class="flex items-start justify-between gap-4">
                                <div class="flex items-start gap-4">
                                    <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center">
                                        <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4h14V3M5 7v14h14V7M9 11h6M9 15h6"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-xs text-slate-500">Dec 02, 2025 • Northside Imaging</p>
                                        <h3 class="text-lg font-bold text-slate-900">Radiology Review</h3>
                                        <p class="text-sm font-medium text-slate-500 mt-1">Dr. Lina Foster</p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-2">
                                    <button class="px-3 py-2 rounded-xl text-sm font-semibold border border-slate-100 text-slate-600 hover:text-slate-900">View Summary</button>
                                    <button class="px-3 py-2 rounded-xl text-sm font-semibold bg-green-400 text-green-900">Download PDF</button>
                                </div>
                            </div>
                            <div class="mt-4 flex items-center gap-3 text-xs text-slate-500">
                                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full bg-blue-50 text-blue-700">
                                    <span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>MRI Completed
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Secure Storage Badge -->
                    <div class="flex items-center gap-2 text-xs text-slate-500 pt-4">
                        <div class="w-6 h-6 rounded-full bg-slate-100 flex items-center justify-center">
                            <svg class="w-3.5 h-3.5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                            </svg>
                        </div>
                        <span>Your data is encrypted and HIPAA compliant.</span>
                    </div>
                </section>

                <!-- Right Column -->
                <aside class="space-y-6">
                    <div class="bg-white border border-slate-100 rounded-2xl p-5">
                        <div class="flex items-center justify-between">
                            <div>
                                <h2 class="text-lg font-bold text-slate-900">Lab Results Preview</h2>
                                <p class="text-xs text-slate-500 mt-1">Jan 30, 2026 • St. Mary Hospital</p>
                            </div>
                            <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center">
                                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                                </svg>
                            </div>
                        </div>

                        <div class="mt-6 space-y-4 text-sm">
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="font-semibold text-slate-900">Hemoglobin</p>
                                    <p class="text-xs text-slate-500">Normal range 12.0 - 15.5 g/dL</p>
                                </div>
                                <span class="px-3 py-1 rounded-full bg-green-50 text-green-700 text-xs font-semibold">14.1</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="font-semibold text-slate-900">White Blood Cells</p>
                                    <p class="text-xs text-slate-500">Normal range 4.0 - 11.0</p>
                                </div>
                                <span class="px-3 py-1 rounded-full bg-green-50 text-green-700 text-xs font-semibold">6.2</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="font-semibold text-slate-900">CRP</p>
                                    <p class="text-xs text-slate-500">Normal range 0.0 - 0.5 mg/dL</p>
                                </div>
                                <span class="px-3 py-1 rounded-full bg-amber-50 text-amber-700 text-xs font-semibold">0.9</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="font-semibold text-slate-900">Glucose (Fasting)</p>
                                    <p class="text-xs text-slate-500">Normal range 70 - 99 mg/dL</p>
                                </div>
                                <span class="px-3 py-1 rounded-full bg-red-50 text-red-700 text-xs font-semibold">118</span>
                            </div>
                        </div>

                        <div class="mt-6 flex items-center gap-2">
                            <button class="px-3 py-2 rounded-xl text-sm font-semibold border border-slate-100 text-slate-600 hover:text-slate-900">View Full Report</button>
                            <button class="px-3 py-2 rounded-xl text-sm font-semibold bg-green-400 text-green-900">Download PDF</button>
                        </div>
                    </div>

                    <div class="bg-white border border-slate-100 rounded-2xl p-5">
                        <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-widest">Vaccinations</h3>
                        <div class="mt-4 space-y-3 text-sm">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-xl bg-green-50 flex items-center justify-center">
                                        <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-slate-900">Influenza</p>
                                        <p class="text-xs text-slate-500">Updated Oct 2025</p>
                                    </div>
                                </div>
                                <span class="text-xs font-semibold text-green-700 bg-green-50 px-2 py-1 rounded-full">Up to date</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center">
                                        <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-7 7-4-4"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-slate-900">COVID-19 Booster</p>
                                        <p class="text-xs text-slate-500">Updated Jul 2025</p>
                                    </div>
                                </div>
                                <span class="text-xs font-semibold text-green-700 bg-green-50 px-2 py-1 rounded-full">Up to date</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-xl bg-amber-50 flex items-center justify-center">
                                        <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-slate-900">Hepatitis B</p>
                                        <p class="text-xs text-slate-500">Due Mar 2026</p>
                                    </div>
                                </div>
                                <span class="text-xs font-semibold text-amber-700 bg-amber-50 px-2 py-1 rounded-full">Upcoming</span>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </main>
    </div>
</body>
</html>
