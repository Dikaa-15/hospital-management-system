<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prescriptions - Patient Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        'jakarta': ['Plus Jakarta Sans', 'sans-serif'],
                    },
                    colors: {
                        brand: '#4ADE80',
                    }
                }
            }
        }
    </script>
    <style>
        :root { --brand: #4ADE80; }
        * { font-family: 'Plus Jakarta Sans', sans-serif; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 6px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        .focus-ring { outline: 2px solid transparent; outline-offset: 2px; }
        .focus-ring:focus-visible { outline: 2px solid #86efac; outline-offset: 2px; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 antialiased">
    <div class="flex min-h-screen">

        <!-- Sidebar -->
        <aside class="w-20 lg:w-64 bg-white border-r border-slate-100 flex flex-col fixed h-full z-30">
            <div class="p-4 lg:p-6 border-b border-slate-100">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-green-400 flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                        </svg>
                    </div>
                    <span class="hidden lg:block text-lg font-bold text-slate-900">Patient Portal</span>
                </div>
            </div>
            <nav class="flex-1 p-3 lg:p-4 space-y-1">
                <a href="billing.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50 focus-ring">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    <span class="hidden lg:block">Home</span>
                </a>
                <a href="my-appointments.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50 focus-ring">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <span class="hidden lg:block">Appointments</span>
                </a>
                <a href="medical-records.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50 focus-ring">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <span class="hidden lg:block">Medical Records</span>
                </a>
                <a href="prescriptions.html" class="flex items-center gap-3 px-3 py-3 rounded-xl bg-green-50 text-green-700 font-medium" aria-current="page">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v6m-3-3h6m7 3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span class="hidden lg:block">Prescriptions</span>
                </a>
                <a href="overview.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50 focus-ring">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    <span class="hidden lg:block">Billing</span>
                </a>
            </nav>
            <div class="p-4 border-t border-slate-100">
                <div class="flex items-center gap-3">
                    <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=80&h=80&fit=crop&crop=face" alt="User" class="w-10 h-10 rounded-full object-cover">
                    <div class="hidden lg:block flex-1 min-w-0">
                        <p class="text-sm font-semibold text-slate-900 truncate">Jane Doe</p>
                        <p class="text-xs text-slate-500">Patient ID: PX-2847</p>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 ml-20 lg:ml-64">
            <header class="sticky top-0 bg-slate-50/90 backdrop-blur-lg z-20 border-b border-slate-100">
                <div class="flex items-center justify-between px-6 lg:px-8 py-4">
                    <div>
                        <h1 class="text-2xl lg:text-3xl font-bold text-slate-900">Prescriptions</h1>
                        <p class="text-sm text-slate-500 mt-1">Medication adherence and pharmacy integration.</p>
                    </div>
                    <button class="px-4 py-2 rounded-2xl bg-green-400 text-green-900 text-sm font-semibold hover:bg-green-300 focus-ring">
                        Order Refill
                    </button>
                </div>
            </header>

            <div class="px-6 lg:px-8 py-8 grid grid-cols-1 xl:grid-cols-[1.6fr_1fr] gap-8">

                <!-- Main Column -->
                <section class="space-y-6">
                    <!-- Active Medication Card -->
                    <div class="bg-white border border-slate-100 rounded-3xl p-6">
                        <div class="flex items-start justify-between gap-6">
                            <div>
                                <div class="inline-flex items-center gap-2 text-xs font-semibold text-green-700 bg-green-50 px-3 py-1 rounded-full">
                                    <span class="w-2 h-2 rounded-full bg-green-400"></span>
                                    Current Treatment
                                </div>
                                <h2 class="text-2xl font-bold text-slate-900 mt-3">Amoxicillin 500mg</h2>
                                <p class="text-sm font-semibold text-slate-900 mt-1">Take 1 capsule after meals</p>
                                <p class="text-sm text-slate-500 mt-2">Prescribed by Dr. Lina Foster • Jan 30, 2026</p>
                            </div>
                            <div class="flex flex-col items-end gap-3">
                                <div class="text-xs text-slate-500">14 days course</div>
                                <div class="w-32">
                                    <div class="flex items-center justify-between text-xs text-slate-500 mb-2">
                                        <span>Remaining</span>
                                        <span class="font-semibold text-slate-900">5 days</span>
                                    </div>
                                    <div class="h-2 rounded-full bg-slate-100 overflow-hidden">
                                        <div class="h-full bg-green-400 w-2/3"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-6">
                            <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-widest">Dose Schedule</h3>
                            <div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-4">
                                <div class="flex items-center justify-between p-4 rounded-2xl border border-slate-100">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center">
                                            <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2v2m6.364 1.636l-1.414 1.414M20 12h2M17.778 17.778l1.414 1.414M12 20v2M4 12H2m3.636-7.364L4.222 5.05M6.222 17.778l-1.414 1.414M12 6a6 6 0 100 12 6 6 0 000-12z"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <p class="text-sm font-semibold text-slate-900">Morning</p>
                                            <p class="text-xs text-slate-500">08:00 AM</p>
                                        </div>
                                    </div>
                                    <div class="w-8 h-8 rounded-full bg-green-400 flex items-center justify-center">
                                        <svg class="w-4 h-4 text-green-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                        </svg>
                                    </div>
                                </div>
                                <div class="flex items-center justify-between p-4 rounded-2xl border border-slate-100">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center">
                                            <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2v2m6.364 1.636l-1.414 1.414M20 12h2M17.778 17.778l1.414 1.414M12 20v2M4 12H2m3.636-7.364L4.222 5.05M6.222 17.778l-1.414 1.414M12 6a6 6 0 100 12 6 6 0 000-12z"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <p class="text-sm font-semibold text-slate-900">Afternoon</p>
                                            <p class="text-xs text-slate-500">01:00 PM</p>
                                        </div>
                                    </div>
                                    <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center">
                                        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                        </svg>
                                    </div>
                                </div>
                                <div class="flex items-center justify-between p-4 rounded-2xl border border-slate-100">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center">
                                            <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12.79A9 9 0 1111.21 3a7 7 0 109.79 9.79z"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <p class="text-sm font-semibold text-slate-900">Night</p>
                                            <p class="text-xs text-slate-500">08:30 PM</p>
                                        </div>
                                    </div>
                                    <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center">
                                        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                        </svg>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Prescription List -->
                    <div class="space-y-4">
                        <div class="bg-white border border-slate-100 rounded-3xl p-5">
                            <div class="flex items-start justify-between gap-4">
                                <div class="flex items-start gap-4">
                                    <div class="w-12 h-12 rounded-2xl bg-green-50 flex items-center justify-center">
                                        <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2v4m0 12v4m7-10h-4M9 12H5m12.95-4.95l-2.83 2.83M8.88 15.12l-2.83 2.83m0-8.49l2.83 2.83m7.24 7.24l2.83 2.83"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <div class="flex items-center gap-2 text-xs text-slate-500">
                                            <span>Jan 30, 2026</span>
                                            <span class="px-2 py-0.5 rounded-full bg-green-50 text-green-700 font-semibold">In Progress</span>
                                        </div>
                                        <h3 class="text-lg font-bold text-slate-900 mt-2">Amoxicillin 500mg</h3>
                                        <p class="text-sm font-semibold text-slate-900">Take after meals • 3x daily</p>
                                        <div class="flex items-center gap-2 mt-3">
                                            <img src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=80&h=80&fit=crop&crop=faces" alt="Doctor" class="w-8 h-8 rounded-full object-cover">
                                            <div class="text-xs text-slate-500">
                                                Prescribed by <span class="font-semibold text-slate-700">Dr. Lina Foster</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <button class="px-3 py-2 rounded-2xl bg-green-400 text-green-900 text-xs font-semibold">Refill Request</button>
                            </div>
                            <div class="mt-4 flex items-center justify-between text-xs text-slate-500">
                                <span>Pharmacy Pickup: CityCare Pharmacy</span>
                                <span class="font-semibold text-slate-700">Order #RX-2847</span>
                            </div>
                        </div>

                        <div class="bg-white border border-slate-100 rounded-3xl p-5">
                            <div class="flex items-start justify-between gap-4">
                                <div class="flex items-start gap-4">
                                    <div class="w-12 h-12 rounded-2xl bg-slate-50 flex items-center justify-center">
                                        <svg class="w-6 h-6 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <div class="flex items-center gap-2 text-xs text-slate-500">
                                            <span>Dec 12, 2025</span>
                                            <span class="px-2 py-0.5 rounded-full bg-slate-100 text-slate-500 font-semibold">Completed</span>
                                        </div>
                                        <h3 class="text-lg font-bold text-slate-900 mt-2">Ibuprofen 200mg</h3>
                                        <p class="text-sm font-semibold text-slate-900">Take when needed • Max 3x daily</p>
                                        <div class="flex items-center gap-2 mt-3">
                                            <img src="https://images.unsplash.com/photo-1527613426441-4da17471b66d?w=80&h=80&fit=crop&crop=faces" alt="Doctor" class="w-8 h-8 rounded-full object-cover">
                                            <div class="text-xs text-slate-500">
                                                Prescribed by <span class="font-semibold text-slate-700">Dr. Kevin Huang</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <button class="px-3 py-2 rounded-2xl border border-slate-200 text-xs font-semibold text-slate-500">Completed</button>
                            </div>
                            <div class="mt-4 flex items-center justify-between text-xs text-slate-500">
                                <span>Pharmacy Pickup: Northside Pharmacy</span>
                                <span class="font-semibold text-slate-700">Order #RX-2411</span>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Side Panel -->
                <aside class="space-y-6">
                    <div class="bg-white border border-slate-100 rounded-3xl p-5">
                        <div class="flex items-center justify-between">
                            <div>
                                <h2 class="text-lg font-bold text-slate-900">Instruction & Side Effects</h2>
                                <p class="text-xs text-slate-500 mt-1">Amoxicillin 500mg</p>
                            </div>
                            <div class="w-10 h-10 rounded-2xl bg-green-50 flex items-center justify-center">
                                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                        </div>
                        <div class="mt-4 space-y-3 text-sm">
                            <div class="p-3 rounded-2xl bg-slate-50">
                                <p class="font-semibold text-slate-900">Take after meal</p>
                                <p class="text-xs text-slate-500 mt-1">Helps reduce stomach discomfort.</p>
                            </div>
                            <div class="p-3 rounded-2xl bg-slate-50">
                                <p class="font-semibold text-slate-900">Avoid caffeine</p>
                                <p class="text-xs text-slate-500 mt-1">May reduce absorption for some patients.</p>
                            </div>
                            <div class="p-3 rounded-2xl bg-slate-50">
                                <p class="font-semibold text-slate-900">Mild side effects</p>
                                <p class="text-xs text-slate-500 mt-1">Slight nausea or fatigue can occur. Rest and hydrate.</p>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white border border-slate-100 rounded-3xl p-5">
                        <div class="flex items-center justify-between">
                            <div>
                                <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-widest">Pharmacy Pickup</h3>
                                <p class="text-sm font-semibold text-slate-900 mt-2">CityCare Hospital Pharmacy</p>
                                <p class="text-xs text-slate-500">2nd Floor, Wing B • Open 08:00 - 20:00</p>
                            </div>
                            <div class="w-10 h-10 rounded-2xl bg-green-50 flex items-center justify-center">
                                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7h18M3 12h18M3 17h18"/>
                                </svg>
                            </div>
                        </div>
                        <div class="mt-5 flex items-center gap-4">
                            <div class="w-28 h-28 rounded-2xl border border-dashed border-slate-200 flex items-center justify-center text-xs text-slate-400">
                                QR / Barcode
                            </div>
                            <div class="text-xs text-slate-500 space-y-2">
                                <p class="font-semibold text-slate-900">Pickup Code</p>
                                <p class="text-sm text-slate-900 font-semibold tracking-widest">RX-2847-9921</p>
                                <button class="px-3 py-2 rounded-2xl bg-green-400 text-green-900 text-xs font-semibold">Refill Request</button>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </main>
    </div>
</body>
</html>
