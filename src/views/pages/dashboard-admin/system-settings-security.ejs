    <style>
        * { font-family: 'Inter', sans-serif; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 6px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 antialiased">
    <div class="min-h-screen flex">
        <aside class="w-20 lg:w-64 bg-white border-r border-slate-100 flex flex-col fixed h-full z-30">
            <div class="p-4 lg:p-6 border-b border-slate-100">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-green-400 flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-green-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                    </div>
                    <span class="hidden lg:block text-lg font-bold text-slate-900">Admin Panel</span>
                </div>
            </div>
            <nav class="flex-1 p-3 lg:p-4 space-y-1 text-sm">
                <a href="dashboard.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg><span class="hidden lg:block">System Overview</span></a>
                <a href="user-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg><span class="hidden lg:block">User Management</span></a>
                <a href="patient-directory.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.121 17.804A4 4 0 019 16h6a4 4 0 013.879 1.804M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg><span class="hidden lg:block">Patient Directory</span></a>
                <a href="inventory-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8 4-8-4m16 0l-8-4-8 4m16 0v10l-8 4m-8-14v10l8 4"/></svg><span class="hidden lg:block">Inventory & Pharmacy</span></a>
                <a href="financial-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V6m0 12v-2"/></svg><span class="hidden lg:block">Financial & Billing</span></a>
                <a href="schedule-ward-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg><span class="hidden lg:block">Schedule & Wards</span></a>
                <a href="system-settings-security.html" class="flex items-center gap-3 px-3 py-3 rounded-xl bg-green-50 text-green-700 font-semibold" aria-current="page"><svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg><span class="hidden lg:block">System Settings</span></a>
            </nav>
            <div class="p-4 border-t border-slate-100 text-xs text-slate-500 hidden lg:block">System Online • Data Encrypted</div>
        </aside>

        <div class="flex-1 ml-20 lg:ml-64">
            <header class="bg-white border-b border-slate-100 sticky top-0 z-20">
                <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
                    <div>
                        <div class="text-xs text-slate-500 uppercase tracking-widest">Control Panel</div>
                        <div class="text-lg font-bold">System Settings & Security</div>
                    </div>
                    <button class="px-4 py-2 rounded-xl bg-green-400 text-green-900 text-sm font-semibold">Save Changes</button>
                </div>
            </header>

            <main class="max-w-7xl mx-auto px-6 py-8 grid grid-cols-1 xl:grid-cols-[260px_1fr] gap-6">
                <aside class="bg-white border border-slate-100 rounded-xl p-3 h-fit">
                    <div class="text-xs uppercase tracking-widest text-slate-500 px-2 py-2">Settings</div>
                    <nav class="space-y-1 text-sm">
                        <a href="#general" class="block px-3 py-2 rounded-lg bg-slate-50 text-slate-700">General</a>
                        <a href="#profile" class="block px-3 py-2 rounded-lg text-slate-500 hover:bg-slate-50">Hospital Profile</a>
                        <a href="#rbac" class="block px-3 py-2 rounded-lg text-slate-500 hover:bg-slate-50">Users & Permissions</a>
                        <a href="#security" class="block px-3 py-2 rounded-lg text-slate-500 hover:bg-slate-50">Security & Auth</a>
                        <a href="#api" class="block px-3 py-2 rounded-lg text-slate-500 hover:bg-slate-50">API & Integrations</a>
                        <a href="#backup" class="block px-3 py-2 rounded-lg text-slate-500 hover:bg-slate-50">Backup & Restore</a>
                    </nav>
                </aside>

                <section class="space-y-6">
                    <div id="general" class="bg-white border border-slate-100 rounded-xl p-5">
                        <h2 class="text-sm uppercase tracking-widest text-slate-500 font-semibold">General & Hospital Profile</h2>
                        <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                            <div><label class="text-xs text-slate-500">Hospital Name</label><input class="w-full mt-1 px-3 py-2 rounded-lg bg-slate-50 border border-slate-200" value="NextGen Health Hospital"></div>
                            <div><label class="text-xs text-slate-500">Medical License Number</label><input class="w-full mt-1 px-3 py-2 rounded-lg bg-slate-50 border border-slate-200" value="RS-INA-2026-991"></div>
                            <div><label class="text-xs text-slate-500">Address</label><input class="w-full mt-1 px-3 py-2 rounded-lg bg-slate-50 border border-slate-200" value="Jl. Kesehatan No. 88, Jakarta"></div>
                            <div><label class="text-xs text-slate-500">Timezone</label><select class="w-full mt-1 px-3 py-2 rounded-lg bg-slate-50 border border-slate-200"><option>Asia/Jakarta (GMT+7)</option></select></div>
                            <div><label class="text-xs text-slate-500">Date Format</label><select class="w-full mt-1 px-3 py-2 rounded-lg bg-slate-50 border border-slate-200"><option>DD/MM/YYYY</option></select></div>
                            <div><label class="text-xs text-slate-500">Logo</label><button class="w-full mt-1 px-3 py-2 rounded-lg border border-slate-200 text-slate-600">Upload Logo</button></div>
                        </div>
                    </div>

                    <div id="rbac" class="bg-white border border-slate-100 rounded-xl p-5">
                        <h2 class="text-sm uppercase tracking-widest text-slate-500 font-semibold">Role-Based Access Control</h2>
                        <div class="mt-4 overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead class="text-xs uppercase tracking-widest text-slate-500">
                                    <tr class="text-left">
                                        <th class="py-2">Module</th>
                                        <th class="py-2">Doctor</th>
                                        <th class="py-2">Nurse</th>
                                        <th class="py-2">Patient</th>
                                        <th class="py-2">Pharmacist</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="border-t border-slate-100"><td class="py-3">Medical Records</td><td><input type="checkbox" checked></td><td><input type="checkbox" checked disabled></td><td><input type="checkbox"></td><td><input type="checkbox"></td></tr>
                                    <tr class="border-t border-slate-100"><td class="py-3">Prescriptions</td><td><input type="checkbox" checked></td><td><input type="checkbox"></td><td><input type="checkbox"></td><td><input type="checkbox" checked></td></tr>
                                    <tr class="border-t border-slate-100"><td class="py-3">Billing</td><td><input type="checkbox"></td><td><input type="checkbox"></td><td><input type="checkbox" checked></td><td><input type="checkbox"></td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div id="security" class="bg-white border border-slate-100 rounded-xl p-5">
                        <h2 class="text-sm uppercase tracking-widest text-slate-500 font-semibold">Security & Authentication</h2>
                        <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4 text-sm">
                            <div class="p-3 rounded-lg bg-slate-50 border border-slate-100">
                                <div class="flex items-center justify-between">
                                    <span>Two-Factor Auth</span>
                                    <span class="w-10 h-6 rounded-full bg-green-400 relative inline-block"><span class="absolute right-1 top-1 w-4 h-4 bg-white rounded-full"></span></span>
                                </div>
                            </div>
                            <div class="p-3 rounded-lg bg-slate-50 border border-slate-100">
                                <label class="text-xs text-slate-500">Session Timeout</label>
                                <select class="w-full mt-1 px-2 py-2 rounded-lg bg-white border border-slate-200"><option>15 minutes</option><option>30 minutes</option></select>
                            </div>
                            <div class="p-3 rounded-lg bg-slate-50 border border-slate-100">
                                <label class="text-xs text-slate-500">Password Policy</label>
                                <select class="w-full mt-1 px-2 py-2 rounded-lg bg-white border border-slate-200"><option>Min 12 chars + symbol</option></select>
                            </div>
                        </div>
                    </div>

                    <div id="api" class="bg-white border border-slate-100 rounded-xl p-5">
                        <h2 class="text-sm uppercase tracking-widest text-slate-500 font-semibold">API & Integrations</h2>
                        <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                            <div>
                                <label class="text-xs text-slate-500">API Key</label>
                                <input class="w-full mt-1 px-3 py-2 rounded-lg bg-slate-50 border border-slate-200 font-mono text-xs" value="hms_live_2f93ab77d01193xx" readonly>
                            </div>
                            <div>
                                <label class="text-xs text-slate-500">Allowed IP</label>
                                <input class="w-full mt-1 px-3 py-2 rounded-lg bg-slate-50 border border-slate-200 font-mono text-xs" value="203.0.113.14" readonly>
                            </div>
                        </div>
                    </div>

                    <div id="logs" class="bg-white border border-slate-100 rounded-xl p-5">
                        <h2 class="text-sm uppercase tracking-widest text-slate-500 font-semibold">System Logs (Audit Trail)</h2>
                        <div class="mt-4 overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead class="text-xs uppercase tracking-widest text-slate-500">
                                    <tr class="text-left"><th class="py-2">Actor</th><th class="py-2">Action</th><th class="py-2">Time</th><th class="py-2">IP</th></tr>
                                </thead>
                                <tbody class="font-mono text-xs">
                                    <tr class="border-t border-slate-100"><td class="py-3">admin.root</td><td>changed Dr. Kevin schedule</td><td>10:00 AM</td><td>203.0.113.14</td></tr>
                                    <tr class="border-t border-slate-100"><td class="py-3">admin.finance</td><td>approved insurance claim CLM-PRU-7704</td><td>09:42 AM</td><td>203.0.113.15</td></tr>
                                    <tr class="border-t border-slate-100"><td class="py-3">system</td><td>automatic backup completed</td><td>03:00 AM</td><td>127.0.0.1</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div id="backup" class="bg-white border border-slate-100 rounded-xl p-5">
                        <h2 class="text-sm uppercase tracking-widest text-slate-500 font-semibold">Backup & Restore</h2>
                        <div class="mt-4 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                            <div class="text-sm text-slate-600">Last Backup: Feb 28, 2026 03:00 AM • Cloud Storage: AWS S3</div>
                            <button class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-semibold">Manual Backup</button>
                        </div>
                    </div>

                    <div class="bg-white border-2 border-red-200 rounded-xl p-5">
                        <h2 class="text-sm uppercase tracking-widest text-red-500 font-semibold">Danger Zone</h2>
                        <p class="text-sm text-slate-600 mt-2">Destructive actions are permanent. Require explicit confirmation and audit record.</p>
                        <div class="mt-4 flex flex-wrap gap-2">
                            <button class="px-4 py-2 rounded-lg border border-red-300 text-red-600 text-sm font-semibold">Reset Database</button>
                            <button class="px-4 py-2 rounded-lg border border-red-300 text-red-600 text-sm font-semibold">Revoke All Sessions</button>
                        </div>
                    </div>
                </section>
            </main>
        </div>
    </div>
</body>
</html>
