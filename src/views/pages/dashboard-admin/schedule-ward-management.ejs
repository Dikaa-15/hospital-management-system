<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Schedule & Ward Management - Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    .grid-sm { font-size: 12px; line-height: 1.35; }
  </style>
</head>
<body class="bg-slate-50 text-slate-900 antialiased">
<div class="min-h-screen flex">
  <aside class="w-20 lg:w-64 bg-white border-r border-slate-100 flex flex-col fixed h-full z-30">
    <div class="p-4 lg:p-6 border-b border-slate-100">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-green-400 flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-green-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
        </div>
        <span class="hidden lg:block text-lg font-bold text-slate-900">Admin Panel</span>
      </div>
    </div>
    <nav class="flex-1 p-3 lg:p-4 space-y-1 text-sm">
      <a href="dashboard.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg><span class="hidden lg:block">System Overview</span></a>
      <a href="user-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg><span class="hidden lg:block">User Management</span></a>
      <a href="patient-directory.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.121 17.804A4 4 0 019 16h6a4 4 0 013.879 1.804M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg><span class="hidden lg:block">Patient Directory</span></a>
      <a href="inventory-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8 4-8-4m16 0l-8-4-8 4m16 0v10l-8 4m-8-14v10l8 4"/></svg><span class="hidden lg:block">Inventory & Pharmacy</span></a>
      <a href="financial-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V6m0 12v-2"/></svg><span class="hidden lg:block">Financial & Billing</span></a>
      <a href="schedule-ward-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl bg-green-50 text-green-700 font-semibold" aria-current="page"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg><span class="hidden lg:block">Schedule & Wards</span></a>
      <a href="system-settings-security.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg><span class="hidden lg:block">System Settings</span></a>
    </nav>
  </aside>

  <div class="flex-1 ml-20 lg:ml-64">
    <header class="bg-white border-b border-slate-100 sticky top-0 z-20">
      <div class="max-w-7xl mx-auto px-6 py-5"><div class="text-xs text-slate-500 uppercase tracking-widest">Operational Logistics</div><div class="text-lg font-bold">Resource Allocation Center</div></div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-8 grid grid-cols-1 xl:grid-cols-[1.45fr_1fr] gap-6">
      <section class="space-y-6">
        <% if (flash) { %><div class="rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800"><%= flash %></div><% } %>
        <% if (error) { %><div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></div><% } %>

        <div class="bg-white border border-slate-100 rounded-xl p-5">
          <div class="flex items-center justify-between">
            <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500">Staff & Doctor Scheduling</h2>
            <form method="get" action="/templates/dashboard-admin/schedule-ward-management.html" class="text-xs">
              <input name="week" type="date" value="<%= weekRange.start %>" class="px-2 py-1 rounded border border-slate-200">
              <button class="px-2 py-1 rounded bg-slate-900 text-white">Load Week</button>
            </form>
          </div>
          <p class="text-xs text-slate-500 mt-2">Week: <%= weekRange.start %> to <%= weekRange.end %></p>

          <div class="mt-4 border border-slate-100 rounded-xl overflow-x-auto">
            <table class="w-full grid-sm">
              <thead class="bg-slate-50 text-slate-500"><tr><th class="text-left py-2 px-3">Date</th><th class="text-left py-2 px-3">Doctor</th><th class="text-left py-2 px-3">Shift</th><th class="text-left py-2 px-3">Department</th><th class="text-left py-2 px-3">Action</th></tr></thead>
              <tbody>
              <% if (!shifts.length) { %><tr><td colspan="5" class="py-4 px-3 text-slate-500">No shifts in this week.</td></tr><% } %>
              <% shifts.forEach((s)=> { %>
                <tr class="border-t border-slate-100 hover:bg-slate-50"><td class="py-2 px-3"><%= new Date(s.shift_date).toLocaleDateString('en-CA') %></td><td class="py-2 px-3 font-semibold"><%= s.doctor_name %></td><td class="py-2 px-3"><span class="px-2 py-1 rounded <%= s.shift_type==='Morning'?'bg-green-100 text-green-700':(s.shift_type==='Afternoon'?'bg-blue-100 text-blue-700':'bg-indigo-100 text-indigo-700') %>"><%= s.shift_type %></span></td><td class="py-2 px-3"><%= s.department || '-' %></td><td class="py-2 px-3"><form method="post" action="/admin/schedule/shifts/<%= s.id %>/delete"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="text-red-600 text-xs font-semibold">Delete</button></form></td></tr>
              <% }) %>
              </tbody>
            </table>
          </div>

          <form method="post" action="/admin/schedule/shifts" class="mt-4 grid grid-cols-1 md:grid-cols-5 gap-2 text-xs">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <select name="doctor_id" required class="px-2 py-2 rounded border border-slate-200"><option value="">Doctor</option><% doctors.forEach((d)=> { %><option value="<%= d.id %>"><%= d.doctor_name %></option><% }) %></select>
            <input name="shift_date" type="date" required class="px-2 py-2 rounded border border-slate-200">
            <select name="shift_type" required class="px-2 py-2 rounded border border-slate-200"><option>Morning</option><option>Afternoon</option><option>Night</option></select>
            <input name="department" placeholder="Department" class="px-2 py-2 rounded border border-slate-200">
            <button class="px-3 py-2 rounded bg-green-400 text-green-900 font-semibold">Add Shift</button>
          </form>
        </div>

        <div class="bg-white border border-slate-100 rounded-xl p-5">
          <div class="flex items-center justify-between"><h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500">Ward & Bed Occupancy</h2><div class="text-xs text-slate-500">Total Beds: <%= wardStats.total_beds %> | Occupied: <%= wardStats.occupied_beds %> | Occupancy: <%= wardStats.occupancyPct %>%</div></div>
          <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 text-xs">
            <% if (!rooms.length) { %><div class="text-slate-500">No room data.</div><% } %>
            <% rooms.forEach((r)=> { const cls = r.status==='Available' ? 'border-2 border-green-400 bg-white' : (r.status==='Cleaning' ? 'border-2 border-amber-400 bg-white' : 'bg-slate-900 text-slate-100'); %>
              <div class="rounded-xl p-3 <%= cls %>">
                <div class="font-semibold"><%= r.room_code %></div>
                <div class="mt-1"><%= r.status %> • <%= Number(r.occupied_count||0) %>/<%= Number(r.capacity||0) %></div>
                <% if (r.patient_name) { %><div class="mt-1 text-[11px]">Patient: <%= r.patient_name %></div><% } %>
                <% if (r.pic_doctor_name) { %><div class="mt-1 text-[11px]">PIC: <%= r.pic_doctor_name %></div><% } %>
              </div>
            <% }) %>
          </div>
        </div>
      </section>

      <aside class="space-y-6">
        <div class="bg-white border border-slate-100 rounded-xl p-5">
          <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500">Room Setup / Update</h2>
          <form method="post" action="/admin/wards" class="mt-3 space-y-2 text-xs">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input name="room_code" required placeholder="Room code" class="w-full px-3 py-2 rounded border border-slate-200">
            <input name="room_class" required placeholder="Class (VIP/KLS1/etc)" class="w-full px-3 py-2 rounded border border-slate-200">
            <div class="grid grid-cols-3 gap-2"><input type="number" min="1" name="floor_no" placeholder="Floor" class="px-2 py-2 rounded border border-slate-200"><input type="number" min="1" name="capacity" placeholder="Capacity" class="px-2 py-2 rounded border border-slate-200"><input type="number" min="0" name="occupied_count" placeholder="Occupied" class="px-2 py-2 rounded border border-slate-200"></div>
            <select name="status" class="w-full px-3 py-2 rounded border border-slate-200"><option>Available</option><option>Occupied</option><option>Cleaning</option></select>
            <input name="patient_name" placeholder="Patient name (if occupied)" class="w-full px-3 py-2 rounded border border-slate-200">
            <select name="pic_doctor_id" class="w-full px-3 py-2 rounded border border-slate-200"><option value="">PIC Doctor</option><% doctors.forEach((d)=> { %><option value="<%= d.id %>"><%= d.doctor_name %></option><% }) %></select>
            <button class="w-full px-3 py-2 rounded bg-green-400 text-green-900 font-semibold">Save Room</button>
          </form>
        </div>

        <div class="bg-white border border-slate-100 rounded-xl p-5">
          <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500">Transfer Queue</h2>
          <form method="post" action="/admin/transfers" class="mt-3 space-y-2 text-xs">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input name="patient_name" required placeholder="Patient name" class="w-full px-3 py-2 rounded border border-slate-200">
            <input name="from_unit" required placeholder="From unit (IGD/ER/etc)" class="w-full px-3 py-2 rounded border border-slate-200">
            <select name="target_room_id" class="w-full px-3 py-2 rounded border border-slate-200"><option value="">Target room</option><% rooms.forEach((r)=> { %><option value="<%= r.id %>"><%= r.room_code %> (<%= r.status %>)</option><% }) %></select>
            <input name="notes" placeholder="Notes" class="w-full px-3 py-2 rounded border border-slate-200">
            <button class="w-full px-3 py-2 rounded bg-green-400 text-green-900 font-semibold">Create Transfer</button>
          </form>

          <div class="mt-4 space-y-2 text-xs max-h-72 overflow-auto">
            <% if (!transfers.length) { %><div class="text-slate-500">No transfer queue.</div><% } %>
            <% transfers.forEach((t)=> { %>
              <div class="p-3 rounded-xl bg-slate-50 border border-slate-100">
                <div class="font-semibold text-slate-900"><%= t.from_unit %> -> <%= t.room_code || 'TBD' %></div>
                <div class="text-slate-500 mt-1">Patient: <%= t.patient_name %> • <%= t.status %></div>
                <form method="post" action="/admin/transfers/<%= t.id %>/status" class="mt-2 flex gap-2">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <select name="status" class="flex-1 px-2 py-1 rounded border border-slate-200"><option>Pending</option><option>Approved</option><option>Moved</option><option>Cancelled</option></select>
                  <button class="px-2 py-1 rounded border border-slate-200">Update</button>
                </form>
              </div>
            <% }) %>
          </div>
        </div>
      </aside>
    </main>
  </div>
</div>
</body>
</html>
