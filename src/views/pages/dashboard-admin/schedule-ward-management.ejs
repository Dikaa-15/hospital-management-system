<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Schedule & Ward Management - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        inter: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        * { font-family: 'Inter', sans-serif; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 6px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        .grid-sm { font-size: 12px; line-height: 1.35; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 antialiased">
    <div class="min-h-screen flex">
        <aside class="w-20 lg:w-64 bg-white border-r border-slate-100 flex flex-col fixed h-full z-30">
            <div class="p-4 lg:p-6 border-b border-slate-100">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-green-400 flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-green-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                    </div>
                    <span class="hidden lg:block text-lg font-bold text-slate-900">Admin Panel</span>
                </div>
            </div>
            <nav class="flex-1 p-3 lg:p-4 space-y-1 text-sm">
                <a href="dashboard.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg><span class="hidden lg:block">System Overview</span></a>
                <a href="user-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg><span class="hidden lg:block">User Management</span></a>
                <a href="patient-directory.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.121 17.804A4 4 0 019 16h6a4 4 0 013.879 1.804M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg><span class="hidden lg:block">Patient Directory</span></a>
                <a href="inventory-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8 4-8-4m16 0l-8-4-8 4m16 0v10l-8 4m-8-14v10l8 4"/></svg><span class="hidden lg:block">Inventory & Pharmacy</span></a>
                <a href="financial-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V6m0 12v-2"/></svg><span class="hidden lg:block">Financial & Billing</span></a>
                <a href="schedule-ward-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl bg-green-50 text-green-700 font-semibold" aria-current="page"><svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg><span class="hidden lg:block">Schedule & Wards</span></a>
                <a href="system-settings-security.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50"><svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg><span class="hidden lg:block">System Settings</span></a>
            </nav>
            <div class="p-4 border-t border-slate-100 text-xs text-slate-500 hidden lg:block">Operational control • Real-time allocation</div>
        </aside>

        <div class="flex-1 ml-20 lg:ml-64">
            <header class="bg-white border-b border-slate-100 sticky top-0 z-20">
                <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
                    <div>
                        <div class="text-xs text-slate-500 uppercase tracking-widest">Operational Logistics</div>
                        <div class="text-lg font-bold">Resource Allocation Center</div>
                    </div>
                    <button class="px-4 py-2 rounded-xl bg-green-400 text-green-900 text-sm font-semibold">Move Patient to Ward</button>
                </div>
            </header>

            <main class="max-w-7xl mx-auto px-6 py-8 grid grid-cols-1 xl:grid-cols-[1.45fr_1fr] gap-6">
                <section class="space-y-6">
                    <div class="bg-white border border-slate-100 rounded-xl p-5">
                        <div class="flex items-center justify-between">
                            <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500">Staff & Doctor Scheduling</h2>
                            <div class="flex items-center gap-2 text-xs">
                                <span class="px-2 py-1 rounded bg-green-100 text-green-700">Morning</span>
                                <span class="px-2 py-1 rounded bg-blue-100 text-blue-700">Afternoon</span>
                                <span class="px-2 py-1 rounded bg-indigo-100 text-indigo-700">Night</span>
                            </div>
                        </div>

                        <div class="mt-4 border border-slate-100 rounded-xl overflow-x-auto">
                            <table class="w-full grid-sm">
                                <thead class="bg-slate-50 text-slate-500">
                                    <tr>
                                        <th class="text-left py-2 px-3">Doctor</th>
                                        <th class="text-left py-2 px-3">Mon</th>
                                        <th class="text-left py-2 px-3">Tue</th>
                                        <th class="text-left py-2 px-3">Wed</th>
                                        <th class="text-left py-2 px-3">Thu</th>
                                        <th class="text-left py-2 px-3">Fri</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="border-t border-slate-100 hover:bg-slate-50">
                                        <td class="py-2 px-3 font-semibold">Dr. Lina Foster</td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-green-100 text-green-700">Morning</span></td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-blue-100 text-blue-700">Afternoon</span></td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-indigo-100 text-indigo-700">Night</span></td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-green-100 text-green-700">Morning</span></td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-blue-100 text-blue-700">Afternoon</span></td>
                                    </tr>
                                    <tr class="border-t border-slate-100 hover:bg-slate-50">
                                        <td class="py-2 px-3 font-semibold">Dr. Kevin Huang</td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-blue-100 text-blue-700">Afternoon</span></td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-indigo-100 text-indigo-700">Night</span></td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-green-100 text-green-700">Morning</span></td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-blue-100 text-blue-700">Afternoon</span></td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-indigo-100 text-indigo-700">Night</span></td>
                                    </tr>
                                    <tr class="border-t border-slate-100 hover:bg-slate-50">
                                        <td class="py-2 px-3 font-semibold">Dr. Aisha Rahman</td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-indigo-100 text-indigo-700">Night</span></td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-green-100 text-green-700">Morning</span></td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-blue-100 text-blue-700">Afternoon</span></td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-green-100 text-green-700">Morning</span></td>
                                        <td class="py-2 px-3"><span class="px-2 py-1 rounded bg-blue-100 text-blue-700">Afternoon</span></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-3 text-xs">
                            <div class="p-3 rounded-xl bg-red-50 border border-red-100 text-red-700">
                                Conflict Alert: Dr. Kevin assigned overlapping shift on Tuesday 20:00.
                            </div>
                            <div class="p-3 rounded-xl bg-amber-50 border border-amber-100 text-amber-700">
                                Staffing Alert: ER department short by 2 nurses for night shift.
                            </div>
                        </div>

                        <div class="mt-4 text-xs text-slate-500">Drag-and-drop simulation: shift badges can be moved between cells in production mode.</div>
                    </div>

                    <div class="bg-white border border-slate-100 rounded-xl p-5">
                        <div class="flex items-center justify-between">
                            <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500">Ward & Bed Occupancy</h2>
                            <div class="text-xs text-slate-500">Total Beds: 200 | Available: 45 | Occupancy: 77.5%</div>
                        </div>

                        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 text-xs">
                            <div class="border-2 border-green-400 rounded-xl p-3 bg-white">
                                <div class="font-semibold text-slate-900">VVIP-101</div>
                                <div class="text-green-700 mt-1">Available</div>
                            </div>
                            <div class="rounded-xl p-3 bg-slate-900 text-slate-100" title="Inpatient duration: 4 days 6 hours">
                                <div class="font-semibold">VIP-204</div>
                                <div class="text-xs mt-1">Occupied • Jane Doe</div>
                                <div class="text-xs text-slate-300 mt-1">PIC: Dr. Lina Foster</div>
                            </div>
                            <div class="border-2 border-amber-400 rounded-xl p-3 bg-white">
                                <div class="font-semibold text-slate-900">KLS1-309</div>
                                <div class="text-amber-600 mt-1">Cleaning in Progress</div>
                            </div>
                            <div class="rounded-xl p-3 bg-slate-900 text-slate-100" title="Inpatient duration: 2 days 1 hour">
                                <div class="font-semibold">KLS2-412</div>
                                <div class="text-xs mt-1">Occupied • Budi Santoso</div>
                                <div class="text-xs text-slate-300 mt-1">PIC: Dr. Kevin Huang</div>
                            </div>
                            <div class="border-2 border-green-400 rounded-xl p-3 bg-white">
                                <div class="font-semibold text-slate-900">KLS3-518</div>
                                <div class="text-green-700 mt-1">Available</div>
                            </div>
                            <div class="border-2 border-amber-400 rounded-xl p-3 bg-white">
                                <div class="font-semibold text-slate-900">ER-07</div>
                                <div class="text-amber-600 mt-1">Cleaning in Progress</div>
                            </div>
                        </div>
                    </div>
                </section>

                <aside class="space-y-6">
                    <div class="bg-white border border-slate-100 rounded-xl p-5">
                        <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500">Duty Status</h2>
                        <div class="mt-4 space-y-2 text-sm">
                            <div class="flex items-center justify-between p-2 rounded-lg bg-green-50">
                                <span>Duty Active</span>
                                <span class="text-green-700 font-semibold">86 staff</span>
                            </div>
                            <div class="flex items-center justify-between p-2 rounded-lg bg-indigo-50">
                                <span>Night Shift</span>
                                <span class="text-indigo-700 font-semibold">27 staff</span>
                            </div>
                            <div class="flex items-center justify-between p-2 rounded-lg bg-amber-50">
                                <span>Maintenance Rooms</span>
                                <span class="text-amber-700 font-semibold">8 rooms</span>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white border border-slate-100 rounded-xl p-5">
                        <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500">Transfer Queue</h2>
                        <div class="mt-4 space-y-3 text-xs">
                            <div class="p-3 rounded-xl bg-slate-50 border border-slate-100">
                                <div class="font-semibold text-slate-900">IGD -> KLS1-309</div>
                                <div class="text-slate-500 mt-1">Patient: Ahmad Rizki • Waiting bed cleaning</div>
                                <button class="mt-2 px-3 py-1.5 rounded-lg bg-green-400 text-green-900 font-semibold">Assign Room</button>
                            </div>
                            <div class="p-3 rounded-xl bg-slate-50 border border-slate-100">
                                <div class="font-semibold text-slate-900">ER -> VIP-101</div>
                                <div class="text-slate-500 mt-1">Patient: Nur Aini • Transfer approved</div>
                                <button class="mt-2 px-3 py-1.5 rounded-lg bg-green-400 text-green-900 font-semibold">Move In</button>
                            </div>
                        </div>
                    </div>
                </aside>
            </main>
        </div>
    </div>
</body>
</html>
