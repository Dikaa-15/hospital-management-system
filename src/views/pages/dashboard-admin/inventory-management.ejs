<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <% if (typeof baseHref === 'string' && baseHref) { %>
    <base href="<%= baseHref %>">
    <% } %>
    <title>Inventory Control Center - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        inter: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        brand: '#4ADE80',
                    }
                }
            }
        }
    </script>
    <style>
        * { font-family: 'Inter', sans-serif; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 6px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 antialiased">
    <div class="min-h-screen flex">
        <aside class="w-20 lg:w-64 bg-white border-r border-slate-100 flex flex-col fixed h-full z-30">
            <div class="p-4 lg:p-6 border-b border-slate-100">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-green-400 flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-green-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                        </svg>
                    </div>
                    <span class="hidden lg:block text-lg font-bold text-slate-900">Admin Panel</span>
                </div>
            </div>
            <nav class="flex-1 p-3 lg:p-4 space-y-1 text-sm">
                <a href="dashboard.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    <span class="hidden lg:block">System Overview</span>
                </a>
                <a href="user-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span class="hidden lg:block">User Management</span>
                </a>
                <a href="patient-directory.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.121 17.804A4 4 0 019 16h6a4 4 0 013.879 1.804M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span class="hidden lg:block">Patient Directory</span>
                </a>
                <a href="inventory-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl bg-green-50 text-green-700 font-semibold" aria-current="page">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8 4-8-4m16 0l-8-4-8 4m16 0v10l-8 4m-8-14v10l8 4"/></svg>
                    <span class="hidden lg:block">Inventory & Pharmacy</span>
                </a>
                <a href="financial-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V6m0 12v-2"/></svg>
                    <span class="hidden lg:block">Financial & Billing</span>
                </a>
                <a href="schedule-ward-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <span class="hidden lg:block">Schedule & Wards</span>
                </a>
                <a href="system-settings-security.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                    <span class="hidden lg:block">System Settings</span>
                </a>
            </nav>
            <div class="p-4 border-t border-slate-100 text-xs text-slate-500 hidden lg:block">Secure admin access • Audit ready</div>
        </aside>

        <div class="flex-1 ml-20 lg:ml-64">
            <header class="bg-white border-b border-slate-100 sticky top-0 z-20">
                <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
                    <div>
                        <div class="text-xs text-slate-500 uppercase tracking-widest">Logistics & Pharmacy</div>
                        <div class="text-lg font-bold">Inventory Control Center</div>
                    </div>
                    <button class="px-4 py-2 rounded-xl bg-green-400 text-green-900 text-sm font-semibold">Create Purchase Order</button>
                </div>
            </header>

            <main class="max-w-7xl mx-auto px-6 py-8 grid grid-cols-1 xl:grid-cols-[1.7fr_1fr] gap-8">
                <section class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
                        <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                            <div class="text-xs uppercase tracking-widest text-slate-500">Total Items</div>
                            <div class="text-3xl font-bold text-slate-900 mt-3">1,462</div>
                            <div class="text-xs text-slate-500 mt-2">Unique medicine & supply SKUs</div>
                        </div>
                        <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                            <div class="text-xs uppercase tracking-widest text-slate-500">Low Stock Alerts</div>
                            <div class="text-3xl font-bold text-orange-500 mt-3">34</div>
                            <div class="text-xs text-slate-500 mt-2">Immediate reorder recommended</div>
                        </div>
                        <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                            <div class="text-xs uppercase tracking-widest text-slate-500">Expiring in 30 Days</div>
                            <div class="text-3xl font-bold text-red-500 mt-3">12</div>
                            <div class="text-xs text-slate-500 mt-2">Batch review required</div>
                        </div>
                        <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                            <div class="text-xs uppercase tracking-widest text-slate-500">Daily Dispensed</div>
                            <div class="text-3xl font-bold text-slate-900 mt-3">589</div>
                            <div class="text-xs text-slate-500 mt-2">Synced from doctor prescriptions</div>
                        </div>
                    </div>

                    <div class="bg-white border border-slate-100 rounded-2xl p-4 flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                        <div class="relative flex-1">
                            <input class="w-full pl-10 pr-4 py-2.5 rounded-xl bg-slate-50 border border-slate-200 text-sm" placeholder="Search item name, SKU, or batch code...">
                            <svg class="w-4 h-4 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-4.35-4.35M16 10a6 6 0 11-12 0 6 6 0 0112 0z"/>
                            </svg>
                        </div>
                        <div class="flex flex-wrap gap-2">
                            <select class="px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-sm">
                                <option>Category</option>
                                <option>Antibiotics</option>
                                <option>Analgesics</option>
                                <option>Syringes</option>
                                <option>PPE</option>
                            </select>
                            <select class="px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-sm">
                                <option>Supplier</option>
                                <option>Medica Pharma</option>
                                <option>Care Medical</option>
                            </select>
                            <select class="px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-sm">
                                <option>Shelf Location</option>
                                <option>Rack A-12</option>
                                <option>Cold Storage C-2</option>
                            </select>
                            <button class="px-3 py-2 rounded-xl bg-green-400 text-green-900 text-sm font-semibold">Add New Item</button>
                        </div>
                    </div>

                    <div class="bg-white border border-slate-100 rounded-2xl shadow-sm overflow-hidden">
                        <div class="bg-slate-50 px-5 py-3 text-xs uppercase tracking-widest text-slate-500">Stock Table</div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead class="bg-slate-50 text-xs uppercase tracking-widest text-slate-500 sticky top-0">
                                    <tr class="text-left">
                                        <th class="py-3 px-5">Item Name & SKU</th>
                                        <th class="py-3">Current Stock</th>
                                        <th class="py-3">Expiry Date</th>
                                        <th class="py-3">Unit Price</th>
                                        <th class="py-3">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="border-t border-slate-100 hover:bg-slate-50 bg-green-50/40">
                                        <td class="py-4 px-5">
                                            <div class="font-semibold text-slate-900">Amoxicillin 500mg</div>
                                            <div class="text-xs text-slate-500 font-mono">SKU: AMX-500-B21</div>
                                        </td>
                                        <td class="py-4">
                                            <div class="font-bold text-slate-900">164 boxes</div>
                                            <div class="h-1.5 w-28 rounded-full bg-slate-100 mt-2"><div class="h-full w-4/5 bg-green-400 rounded-full"></div></div>
                                        </td>
                                        <td class="py-4">
                                            <div class="text-slate-900">Aug 18, 2026</div>
                                            <div class="text-xs text-green-600 font-semibold">Safe</div>
                                        </td>
                                        <td class="py-4 font-bold text-slate-900">Rp 42.000</td>
                                        <td class="py-4 text-green-600 font-semibold">View Batch</td>
                                    </tr>
                                    <tr class="border-t border-slate-100 hover:bg-slate-50">
                                        <td class="py-4 px-5">
                                            <div class="font-semibold text-slate-900">Paracetamol 500mg</div>
                                            <div class="text-xs text-slate-500 font-mono">SKU: PRC-500-A11</div>
                                        </td>
                                        <td class="py-4">
                                            <div class="font-bold text-orange-500">14 boxes</div>
                                            <div class="h-1.5 w-28 rounded-full bg-slate-100 mt-2"><div class="h-full w-1/6 bg-orange-400 rounded-full"></div></div>
                                        </td>
                                        <td class="py-4">
                                            <div class="text-slate-900">May 02, 2026</div>
                                            <div class="text-xs text-orange-500 font-semibold">Low stock</div>
                                        </td>
                                        <td class="py-4 font-bold text-slate-900">Rp 25.000</td>
                                        <td class="py-4 text-green-600 font-semibold">Create PO</td>
                                    </tr>
                                    <tr class="border-t border-slate-100 hover:bg-slate-50">
                                        <td class="py-4 px-5">
                                            <div class="font-semibold text-slate-900">Insulin Pen 3ml</div>
                                            <div class="text-xs text-slate-500 font-mono">SKU: INS-3ML-C44</div>
                                        </td>
                                        <td class="py-4">
                                            <div class="font-bold text-slate-900">28 units</div>
                                            <div class="h-1.5 w-28 rounded-full bg-slate-100 mt-2"><div class="h-full w-1/4 bg-orange-400 rounded-full"></div></div>
                                        </td>
                                        <td class="py-4">
                                            <div class="text-slate-900">Mar 06, 2026</div>
                                            <div class="text-xs text-red-500 font-semibold">Expiring soon</div>
                                        </td>
                                        <td class="py-4 font-bold text-slate-900">Rp 180.000</td>
                                        <td class="py-4 text-green-600 font-semibold">View Batch</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </section>

                <aside class="space-y-4">
                    <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                        <h2 class="text-sm uppercase tracking-widest text-slate-500 font-semibold">Batch Tracking</h2>
                        <p class="text-xs text-slate-500 mt-1">Amoxicillin 500mg • Rack A-12</p>
                        <div class="mt-4 space-y-3 text-sm">
                            <div class="p-3 rounded-xl bg-slate-50">
                                <div class="flex items-center justify-between">
                                    <span class="font-semibold text-slate-900 font-mono">BATCH #AMX-B21-08</span>
                                    <span class="text-xs text-green-600 font-semibold">IN +120</span>
                                </div>
                                <p class="text-xs text-slate-500 mt-1">Received from Medica Pharma • Feb 19, 2026</p>
                            </div>
                            <div class="p-3 rounded-xl bg-slate-50">
                                <div class="flex items-center justify-between">
                                    <span class="font-semibold text-slate-900 font-mono">BATCH #AMX-B20-12</span>
                                    <span class="text-xs text-orange-500 font-semibold">OUT -48</span>
                                </div>
                                <p class="text-xs text-slate-500 mt-1">Dispensed to wards & outpatient • Today</p>
                            </div>
                            <div class="p-3 rounded-xl bg-slate-50">
                                <div class="flex items-center justify-between">
                                    <span class="font-semibold text-slate-900 font-mono">BATCH #AMX-B19-22</span>
                                    <span class="text-xs text-red-500 font-semibold">EXPIRED</span>
                                </div>
                                <p class="text-xs text-slate-500 mt-1">Moved to disposal log • Jan 31, 2026</p>
                            </div>
                        </div>
                        <div class="mt-5 border-t border-slate-100 pt-4 text-xs text-slate-500">
                            Audit trail enabled • Warehouse location map synced
                        </div>
                    </div>

                    <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                        <h2 class="text-sm uppercase tracking-widest text-slate-500 font-semibold">Supplier Logistics</h2>
                        <div class="mt-4 space-y-3 text-sm">
                            <div class="flex items-center justify-between">
                                <span class="text-slate-600">Open Purchase Orders</span>
                                <span class="font-bold text-slate-900">7</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-slate-600">Incoming Today</span>
                                <span class="font-bold text-slate-900">3 trucks</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span class="text-slate-600">Backorder Items</span>
                                <span class="font-bold text-orange-500">9</span>
                            </div>
                        </div>
                        <button class="mt-5 w-full px-4 py-2 rounded-xl bg-green-400 text-green-900 text-sm font-semibold">Create Purchase Order</button>
                    </div>
                </aside>
            </main>
        </div>
    </div>
</body>
</html>
