<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <% if (typeof baseHref === 'string' && baseHref) { %>
    <base href="<%= baseHref %>">
    <% } %>
    <title>System Command Center - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        'inter': ['Inter', 'sans-serif'],
                    },
                    colors: {
                        brand: '#4ADE80',
                    }
                }
            }
        }
    </script>
    <style>
        * { font-family: 'Inter', sans-serif; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 6px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 antialiased">
    <div class="min-h-screen flex">

        <!-- Sidebar -->
        <aside class="w-20 lg:w-64 bg-white border-r border-slate-100 flex flex-col fixed h-full z-30">
            <div class="p-4 lg:p-6 border-b border-slate-100">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-green-400 flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-green-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                        </svg>
                    </div>
                    <span class="hidden lg:block text-lg font-bold text-slate-900">Admin Panel</span>
                </div>
            </div>

            <nav class="flex-1 p-3 lg:p-4 space-y-1 text-sm">
                <a href="dashboard.html" class="flex items-center gap-3 px-3 py-3 rounded-xl bg-green-50 text-green-700 font-semibold" aria-current="page">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    <span class="hidden lg:block">System Overview</span>
                </a>
                <a href="user-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span class="hidden lg:block">User Management</span>
                </a>
                <a href="patient-directory.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.121 17.804A4 4 0 019 16h6a4 4 0 013.879 1.804M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span class="hidden lg:block">Patient Directory</span>
                </a>
                <a href="inventory-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7h18M3 12h18M3 17h18"/></svg>
                    <span class="hidden lg:block">Inventory & Pharmacy</span>
                </a>
                <a href="financial-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V6m0 12v-2"/></svg>
                    <span class="hidden lg:block">Financial & Billing</span>
                </a>
                <a href="schedule-ward-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <span class="hidden lg:block">Schedule & Wards</span>
                </a>
                <a href="system-settings-security.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                    <span class="hidden lg:block">System Settings</span>
                </a>
            </nav>

            <div class="p-4 border-t border-slate-100 text-xs text-slate-500 hidden lg:block">
                Secure admin access • Audit ready
            </div>
        </aside>

        <div class="flex-1 ml-20 lg:ml-64">
        <header class="bg-white border-b border-slate-100 sticky top-0 z-20">
            <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-11 h-11 rounded-2xl bg-green-400 flex items-center justify-center shadow-sm">
                        <svg class="w-6 h-6 text-green-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                        </svg>
                    </div>
                    <div>
                        <div class="text-xs text-slate-500 uppercase tracking-widest">System Command Center</div>
                        <div class="text-lg font-bold">Hospital Administration</div>
                    </div>
                </div>
                <div class="flex items-center gap-3 text-sm">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-50 text-green-700">
                        <span class="w-2 h-2 rounded-full bg-green-400"></span>
                        System Online
                    </div>
                    <a class="text-slate-500 hover:text-slate-900" href="../../index.html">All Templates</a>
                    <form method="post" action="/logout">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="px-3 py-1.5 rounded-lg border border-slate-200 text-slate-600 hover:text-slate-900 hover:bg-slate-50">Logout</button>
                    </form>
                </div>
            </div>
        </header>

        <main class="max-w-7xl mx-auto px-6 py-8 grid grid-cols-1 xl:grid-cols-[1.7fr_1fr] gap-8">
            <section class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
                    <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                        <div class="flex items-center justify-between">
                            <div class="text-xs text-slate-500 uppercase tracking-widest">Live Patients</div>
                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                        </div>
                        <div class="text-3xl font-bold text-slate-900 mt-4">1,284</div>
                        <div class="mt-3 flex items-center justify-between text-xs text-slate-500">
                            <span>In-patient: 324</span>
                            <span>Out-patient: 960</span>
                        </div>
                    </div>
                    <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                        <div class="flex items-center justify-between">
                            <div class="text-xs text-slate-500 uppercase tracking-widest">Available Doctors</div>
                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                            </svg>
                        </div>
                        <div class="text-3xl font-bold text-slate-900 mt-4">86</div>
                        <div class="mt-3 flex items-center gap-2 text-xs text-slate-500">
                            <span class="w-2 h-2 rounded-full bg-green-400"></span>
                            Standby across 12 departments
                        </div>
                    </div>
                    <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                        <div class="flex items-center justify-between">
                            <div class="text-xs text-slate-500 uppercase tracking-widest">Revenue Today</div>
                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V6m0 12v-2"/>
                            </svg>
                        </div>
                        <div class="text-3xl font-bold text-slate-900 mt-4">Rp 128.5M</div>
                        <div class="mt-3">
                            <div class="h-2 rounded-full bg-slate-100 overflow-hidden">
                                <div class="h-full bg-green-400 w-3/4"></div>
                            </div>
                            <div class="mt-2 text-xs text-slate-500">+12.6% vs yesterday</div>
                        </div>
                    </div>
                    <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                        <div class="flex items-center justify-between">
                            <div class="text-xs text-slate-500 uppercase tracking-widest">Room Occupancy</div>
                            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7h16M4 12h16M4 17h16"/>
                            </svg>
                        </div>
                        <div class="mt-4 flex items-center gap-4">
                            <div class="relative w-14 h-14">
                                <svg viewBox="0 0 36 36" class="w-14 h-14">
                                    <path d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831" fill="none" stroke="#e2e8f0" stroke-width="3"/>
                                    <path d="M18 2.0845a 15.9155 15.9155 0 0 1 0 31.831" fill="none" stroke="#4ADE80" stroke-width="3" stroke-dasharray="78, 100"/>
                                </svg>
                                <div class="absolute inset-0 flex items-center justify-center text-xs font-bold text-slate-900">78%</div>
                            </div>
                            <div class="text-xs text-slate-500">
                                312 / 400 beds occupied
                            </div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                    <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                        <div class="flex items-center justify-between">
                            <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-widest">Patient Flow</h2>
                            <span class="text-xs text-green-700 bg-green-50 px-2 py-1 rounded-full">+8% weekly</span>
                        </div>
                        <div class="mt-5 h-48 rounded-xl bg-gradient-to-b from-green-100/60 to-transparent relative overflow-hidden">
                            <svg class="absolute inset-0" viewBox="0 0 600 200" preserveAspectRatio="none">
                                <path d="M0 150 C80 120, 140 140, 200 110 C260 80, 320 120, 380 90 C440 60, 520 80, 600 40" fill="none" stroke="#4ADE80" stroke-width="3"/>
                                <path d="M0 150 C80 120, 140 140, 200 110 C260 80, 320 120, 380 90 C440 60, 520 80, 600 40 L600 200 L0 200 Z" fill="url(#flowGradient)" opacity="0.4"/>
                                <defs>
                                    <linearGradient id="flowGradient" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="#4ADE80"/>
                                        <stop offset="100%" stop-color="#4ADE80" stop-opacity="0"/>
                                    </linearGradient>
                                </defs>
                            </svg>
                            <div class="absolute bottom-4 left-4 text-xs text-slate-500">Weekly trend</div>
                        </div>
                    </div>
                    <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                        <div class="flex items-center justify-between">
                            <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-widest">Revenue Source</h2>
                            <span class="text-xs text-slate-500">Today</span>
                        </div>
                        <div class="mt-6 space-y-4">
                            <div>
                                <div class="flex items-center justify-between text-xs text-slate-500">
                                    <span>Pharmacy</span>
                                    <span class="font-semibold text-slate-900">Rp 54.2M</span>
                                </div>
                                <div class="h-2 rounded-full bg-slate-100 overflow-hidden mt-2">
                                    <div class="h-full bg-green-400 w-4/5"></div>
                                </div>
                            </div>
                            <div>
                                <div class="flex items-center justify-between text-xs text-slate-500">
                                    <span>Consultation</span>
                                    <span class="font-semibold text-slate-900">Rp 38.6M</span>
                                </div>
                                <div class="h-2 rounded-full bg-slate-100 overflow-hidden mt-2">
                                    <div class="h-full bg-green-400 w-3/5"></div>
                                </div>
                            </div>
                            <div>
                                <div class="flex items-center justify-between text-xs text-slate-500">
                                    <span>Lab</span>
                                    <span class="font-semibold text-slate-900">Rp 21.7M</span>
                                </div>
                                <div class="h-2 rounded-full bg-slate-100 overflow-hidden mt-2">
                                    <div class="h-full bg-green-400 w-2/5"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                    <div class="flex items-center justify-between">
                        <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-widest">Doctor On-Duty</h2>
                        <span class="text-xs text-slate-500">Updated 2 min ago</span>
                    </div>
                    <div class="mt-5 overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead class="text-xs text-slate-500 uppercase tracking-widest">
                                <tr class="text-left">
                                    <th class="py-2">Doctor</th>
                                    <th class="py-2">Department</th>
                                    <th class="py-2">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="border-t border-slate-100">
                                    <td class="py-3 font-semibold text-slate-900">Dr. Lina Foster</td>
                                    <td class="py-3 text-slate-600">Cardiology</td>
                                    <td class="py-3"><span class="px-2 py-1 rounded-full bg-green-50 text-green-700 text-xs font-semibold">Live</span></td>
                                </tr>
                                <tr class="border-t border-slate-100">
                                    <td class="py-3 font-semibold text-slate-900">Dr. Kevin Huang</td>
                                    <td class="py-3 text-slate-600">General Practice</td>
                                    <td class="py-3"><span class="px-2 py-1 rounded-full bg-green-50 text-green-700 text-xs font-semibold">Live</span></td>
                                </tr>
                                <tr class="border-t border-slate-100">
                                    <td class="py-3 font-semibold text-slate-900">Dr. Aisha Rahman</td>
                                    <td class="py-3 text-slate-600">Surgery</td>
                                    <td class="py-3"><span class="px-2 py-1 rounded-full bg-green-50 text-green-700 text-xs font-semibold">Live</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- Notifications Sidebar -->
            <aside class="space-y-4">
                <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                    <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-widest">System Notifications</h2>
                    <div class="mt-4 space-y-3 text-sm">
                        <div class="p-3 rounded-xl bg-amber-50 text-amber-800">
                            <div class="font-semibold">Stock Low: Paracetamol</div>
                            <div class="text-xs mt-1">Inventory below 10% in Pharmacy</div>
                        </div>
                        <div class="p-3 rounded-xl bg-blue-50 text-blue-800">
                            <div class="font-semibold">New Doctor Registration</div>
                            <div class="text-xs mt-1">3 pending approvals</div>
                        </div>
                        <div class="p-3 rounded-xl bg-slate-50 text-slate-700">
                            <div class="font-semibold">System Update Scheduled</div>
                            <div class="text-xs mt-1">Tonight at 22:00</div>
                        </div>
                    </div>
                </div>

                <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm">
                    <h2 class="text-sm font-semibold text-slate-500 uppercase tracking-widest">Quick Actions</h2>
                    <div class="mt-4 grid grid-cols-1 gap-3 text-sm">
                        <button class="px-4 py-3 rounded-xl bg-green-400 text-green-900 font-semibold">Open Incident Room</button>
                        <button class="px-4 py-3 rounded-xl border border-slate-200 text-slate-600">Review Staff Requests</button>
                        <button class="px-4 py-3 rounded-xl border border-slate-200 text-slate-600">Download Daily Report</button>
                    </div>
                </div>
            </aside>
        </main>
        </div>
    </div>
</body>
</html>
