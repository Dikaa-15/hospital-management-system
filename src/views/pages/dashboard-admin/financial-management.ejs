<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Financial Dashboard - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = { theme: { extend: { fontFamily: { inter: ['Inter', 'sans-serif'] }, colors: { brand: '#4ADE80' } } } }
    </script>
    <style>
        * { font-family: 'Inter', sans-serif; }
        .num { font-variant-numeric: tabular-nums; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 6px; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 antialiased">
<%
function statusMeta(inv) {
  if (inv.status === 'Paid') return {label: 'Settled', cls: 'bg-green-400 text-white'};
  if ((inv.payment_type === 'BPJS' || inv.payment_type === 'Asuransi Swasta') && inv.status !== 'Paid') return {label: 'Awaiting Insurance', cls: 'bg-sky-400 text-white'};
  if (inv.status === 'Cancelled') return {label: 'Cancelled', cls: 'bg-slate-300 text-slate-700'};
  return {label: 'Unpaid', cls: 'bg-red-400 text-white'};
}
%>
<div class="min-h-screen flex">
    <aside class="w-20 lg:w-64 bg-white border-r border-slate-100 flex flex-col fixed h-full z-30">
        <div class="p-4 lg:p-6 border-b border-slate-100"><div class="flex items-center gap-3"><div class="w-10 h-10 rounded-xl bg-green-400 flex items-center justify-center flex-shrink-0"><svg class="w-6 h-6 text-green-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg></div><span class="hidden lg:block text-lg font-bold text-slate-900">Admin Panel</span></div></div>
        <nav class="flex-1 p-3 lg:p-4 space-y-1 text-sm">
            <a href="/dashboard" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                <span class="hidden lg:block">System Overview</span>
            </a>
            <a href="/templates/dashboard-admin/user-management" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <span class="hidden lg:block">User Management</span>
            </a>
            <a href="/templates/dashboard-admin/patient-directory" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.121 17.804A4 4 0 019 16h6a4 4 0 013.879 1.804M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <span class="hidden lg:block">Patient Directory</span>
            </a>
            <a href="/templates/dashboard-admin/inventory-management" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8 4-8-4m16 0l-8-4-8 4m16 0v10l-8 4m-8-14v10l8 4"/></svg>
                <span class="hidden lg:block">Inventory & Pharmacy</span>
            </a>
            <a href="/templates/dashboard-admin/financial-management" class="flex items-center gap-3 px-3 py-3 rounded-xl bg-green-50 text-green-700 font-semibold" aria-current="page">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V6m0 12v-2"/></svg>
                <span class="hidden lg:block">Financial & Billing</span>
            </a>
            <a href="/templates/dashboard-admin/schedule-ward-management" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                <span class="hidden lg:block">Schedule & Wards</span>
            </a>
            <a href="/templates/dashboard-admin/system-settings-security" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                <span class="hidden lg:block">System Settings</span>
            </a>
        </nav>
    </aside>

    <div class="flex-1 ml-20 lg:ml-64">
        <header class="bg-white border-b border-slate-100 sticky top-0 z-20">
            <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between gap-3">
                <div><div class="text-xs text-slate-500 uppercase tracking-widest">Finance & ERP</div><div class="text-lg font-bold">Financial Control Dashboard</div></div>
                <form method="get" action="/templates/dashboard-admin/financial-management" class="flex items-center gap-2">
                    <input type="hidden" name="status" value="<%= filters.status %>"><input type="hidden" name="q" value="<%= filters.q %>">
                    <select name="range" class="px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-sm">
                        <option value="today" <%= filters.range === 'today' ? 'selected' : '' %>>Today</option>
                        <option value="7d" <%= filters.range === '7d' ? 'selected' : '' %>>Last 7 Days</option>
                        <option value="30d" <%= filters.range === '30d' ? 'selected' : '' %>>Last 30 Days</option>
                    </select>
                    <button class="px-4 py-2 rounded-xl bg-green-400 text-green-900 text-sm font-semibold">Apply</button>
                </form>
            </div>
        </header>

        <main class="max-w-7xl mx-auto px-6 py-8 space-y-6">
            <% if (flash) { %><div class="rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800"><%= flash %></div><% } %>
            <% if (error) { %><div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></div><% } %>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
                <div class="bg-white border border-slate-100 rounded-2xl p-5"><div class="text-xs uppercase tracking-widest text-slate-500">Total Revenue</div><div class="num text-3xl font-bold text-slate-900 mt-3">Rp <%= Number(summary.total_revenue||0).toLocaleString('id-ID') %></div><div class="text-xs text-green-600 font-semibold mt-2">Settled invoices</div></div>
                <div class="bg-white border border-slate-100 rounded-2xl p-5"><div class="text-xs uppercase tracking-widest text-slate-500">Pending Claims</div><div class="num text-3xl font-bold text-orange-500 mt-3">Rp <%= Number(summary.pending_claims||0).toLocaleString('id-ID') %></div><div class="text-xs text-slate-500 mt-2">Draft invoices</div></div>
                <div class="bg-white border border-slate-100 rounded-2xl p-5"><div class="text-xs uppercase tracking-widest text-slate-500">Outstanding Bills</div><div class="num text-3xl font-bold text-red-500 mt-3">Rp <%= Number(summary.outstanding_bills||0).toLocaleString('id-ID') %></div><div class="text-xs text-slate-500 mt-2">Unpaid invoices</div></div>
                <div class="bg-white border border-slate-100 rounded-2xl p-5"><div class="text-xs uppercase tracking-widest text-slate-500">Insurance Savings</div><div class="num text-3xl font-bold text-slate-900 mt-3">Rp <%= Number(summary.insurance_savings||0).toLocaleString('id-ID') %></div><div class="text-xs text-slate-500 mt-2">From discounts</div></div>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-[1.6fr_1fr] gap-6">
                <section class="space-y-6">
                    <form method="get" action="/templates/dashboard-admin/financial-management" class="bg-white border border-slate-100 rounded-2xl p-4 flex flex-wrap gap-2 items-center">
                        <input type="hidden" name="range" value="<%= filters.range %>">
                        <input name="q" value="<%= filters.q %>" placeholder="Search invoice or patient..." class="flex-1 min-w-56 px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-sm">
                        <select name="status" class="px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-sm">
                            <option value="">All Status</option>
                            <option value="Draft" <%= filters.status==='Draft'?'selected':'' %>>Draft</option>
                            <option value="Unpaid" <%= filters.status==='Unpaid'?'selected':'' %>>Unpaid</option>
                            <option value="Paid" <%= filters.status==='Paid'?'selected':'' %>>Paid</option>
                            <option value="Cancelled" <%= filters.status==='Cancelled'?'selected':'' %>>Cancelled</option>
                        </select>
                        <button class="px-3 py-2 rounded-xl bg-slate-900 text-white text-sm">Filter</button>
                    </form>

                    <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden">
                        <div class="bg-slate-50 px-5 py-3 text-xs uppercase tracking-widest text-slate-500">Transaction & Billing Table (<%= invoices.length %>)</div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead class="text-xs uppercase tracking-widest text-slate-500 bg-slate-50"><tr class="text-left"><th class="py-3 px-5">Invoice</th><th class="py-3">Patient</th><th class="py-3">Date</th><th class="py-3">Amount</th><th class="py-3">Method</th><th class="py-3">Status</th></tr></thead>
                                <tbody>
                                <% if (!invoices.length) { %><tr class="border-t border-slate-100"><td colspan="6" class="py-8 text-center text-slate-500">No invoices found.</td></tr><% } %>
                                <% invoices.forEach((inv)=> { const meta = statusMeta(inv); %>
                                    <tr class="border-t border-slate-100 hover:bg-slate-50 <%= selectedInvoice && selectedInvoice.id===inv.id ? 'bg-green-50/40' : '' %>">
                                        <td class="py-4 px-5 num font-semibold"><a href="/templates/dashboard-admin/financial-management?invoice=<%= inv.id %>&range=<%= filters.range %>&status=<%= filters.status %>&q=<%= encodeURIComponent(filters.q||'') %>" class="hover:text-green-700"><%= inv.invoice_no %></a></td>
                                        <td class="py-4"><%= inv.patient_name || '-' %></td>
                                        <td class="py-4"><%= new Date(inv.created_at).toLocaleDateString('en-CA') %></td>
                                        <td class="py-4 num font-bold">Rp <%= Number(inv.net_amount||0).toLocaleString('id-ID') %></td>
                                        <td class="py-4"><%= inv.latest_method || inv.payment_type || '-' %></td>
                                        <td class="py-4"><span class="px-3 py-1 rounded-full text-xs font-semibold <%= meta.cls %>"><%= meta.label %></span></td>
                                    </tr>
                                <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </section>

                <aside class="space-y-6">
                    <div class="bg-white border border-slate-100 rounded-2xl p-5">
                        <h2 class="text-sm uppercase tracking-widest text-slate-500 font-semibold">Invoice Detail</h2>
                        <% if (!selectedInvoice) { %>
                            <p class="mt-3 text-sm text-slate-500">Select invoice from table.</p>
                        <% } else { %>
                            <div class="mt-3 space-y-2 text-sm">
                                <div class="flex justify-between"><span class="text-slate-500">Invoice</span><span class="font-semibold num"><%= selectedInvoice.invoice_no %></span></div>
                                <div class="flex justify-between"><span class="text-slate-500">Patient</span><span class="font-semibold"><%= selectedInvoice.patient_name || '-' %></span></div>
                                <div class="flex justify-between"><span class="text-slate-500">Gross</span><span class="num">Rp <%= Number(selectedInvoice.total_amount||0).toLocaleString('id-ID') %></span></div>
                                <div class="flex justify-between"><span class="text-slate-500">Discount</span><span class="num">Rp <%= Number(selectedInvoice.discount_amount||0).toLocaleString('id-ID') %></span></div>
                                <div class="flex justify-between"><span class="text-slate-500">Net</span><span class="font-semibold num">Rp <%= Number(selectedInvoice.net_amount||0).toLocaleString('id-ID') %></span></div>
                                <div class="flex justify-between"><span class="text-slate-500">Paid</span><span class="num">Rp <%= Number(selectedInvoice.total_paid||0).toLocaleString('id-ID') %></span></div>
                                <div class="flex justify-between"><span class="text-slate-500">Outstanding</span><span class="font-semibold num">Rp <%= Math.max(0, Number(selectedInvoice.net_amount||0)-Number(selectedInvoice.total_paid||0)).toLocaleString('id-ID') %></span></div>
                            </div>

                            <form method="post" action="/admin/finance/payments" class="mt-4 space-y-2 text-sm">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <input type="hidden" name="invoice_id" value="<%= selectedInvoice.id %>">
                                <select name="payment_method" required class="w-full px-3 py-2 rounded-xl bg-slate-50 border border-slate-200"><option value="">Payment Method</option><option>Cash</option><option>Insurance</option><option>VA</option><option>QRIS</option><option>Credit Card</option></select>
                                <input name="amount_paid" type="number" min="1" step="0.01" required placeholder="Amount" class="w-full px-3 py-2 rounded-xl bg-slate-50 border border-slate-200">
                                <button class="w-full px-4 py-2 rounded-xl bg-green-400 text-green-900 text-sm font-semibold">Post Payment</button>
                            </form>

                            <form method="post" action="/admin/finance/invoices/<%= selectedInvoice.id %>/status" class="mt-3 flex gap-2">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <select name="status" class="flex-1 px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-sm"><option>Draft</option><option>Unpaid</option><option>Paid</option><option>Cancelled</option></select>
                                <button class="px-3 py-2 rounded-xl border border-slate-200 text-sm">Update</button>
                            </form>
                        <% } %>
                    </div>

                    <div class="bg-white border border-slate-100 rounded-2xl p-5">
                        <h2 class="text-sm uppercase tracking-widest text-slate-500 font-semibold">Insurance Claim Management</h2>
                        <div class="mt-4 space-y-3">
                            <% if (!claims.length) { %><p class="text-sm text-slate-500">No claim queue.</p><% } %>
                            <% claims.forEach((clm)=> { %>
                                <div class="p-3 rounded-xl bg-slate-50 border border-slate-100">
                                    <div class="flex items-center justify-between"><div><p class="text-sm font-semibold text-slate-900"><%= clm.invoice_no %></p><p class="text-xs text-slate-500"><%= clm.patient_name || '-' %> • Rp <%= Number(clm.net_amount||0).toLocaleString('id-ID') %></p></div><span class="text-xs text-sky-600 font-semibold"><%= clm.payment_type %></span></div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </aside>
            </div>
        </main>
    </div>
</div>
</body>
</html>
