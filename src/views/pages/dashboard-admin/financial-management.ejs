<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Financial Dashboard - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        inter: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        brand: '#4ADE80',
                    }
                }
            }
        }
    </script>
    <style>
        * { font-family: 'Inter', sans-serif; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 6px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        .num { font-variant-numeric: tabular-nums; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 antialiased">
    <div class="min-h-screen flex">
        <aside class="w-20 lg:w-64 bg-white border-r border-slate-100 flex flex-col fixed h-full z-30">
            <div class="p-4 lg:p-6 border-b border-slate-100">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-green-400 flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-green-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                        </svg>
                    </div>
                    <span class="hidden lg:block text-lg font-bold text-slate-900">Admin Panel</span>
                </div>
            </div>
            <nav class="flex-1 p-3 lg:p-4 space-y-1 text-sm">
                <a href="dashboard.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    <span class="hidden lg:block">System Overview</span>
                </a>
                <a href="user-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span class="hidden lg:block">User Management</span>
                </a>
                <a href="patient-directory.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.121 17.804A4 4 0 019 16h6a4 4 0 013.879 1.804M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span class="hidden lg:block">Patient Directory</span>
                </a>
                <a href="inventory-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8 4-8-4m16 0l-8-4-8 4m16 0v10l-8 4m-8-14v10l8 4"/></svg>
                    <span class="hidden lg:block">Inventory & Pharmacy</span>
                </a>
                <a href="financial-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl bg-green-50 text-green-700 font-semibold" aria-current="page">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V6m0 12v-2"/></svg>
                    <span class="hidden lg:block">Financial & Billing</span>
                </a>
                <a href="schedule-ward-management.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <span class="hidden lg:block">Schedule & Wards</span>
                </a>
                <a href="system-settings-security.html" class="flex items-center gap-3 px-3 py-3 rounded-xl text-slate-500 hover:bg-slate-50">
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                    <span class="hidden lg:block">System Settings</span>
                </a>
            </nav>
            <div class="p-4 border-t border-slate-100 text-xs text-slate-500 hidden lg:block">Secure admin access • Audit ready</div>
        </aside>

        <div class="flex-1 ml-20 lg:ml-64">
            <header class="bg-white border-b border-slate-100 sticky top-0 z-20">
                <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
                    <div>
                        <div class="text-xs text-slate-500 uppercase tracking-widest">Finance & ERP</div>
                        <div class="text-lg font-bold">Financial Control Dashboard</div>
                    </div>
                    <div class="flex items-center gap-2">
                        <select class="px-3 py-2 rounded-xl bg-slate-50 border border-slate-200 text-sm">
                            <option>Today</option>
                            <option>Last 7 Days</option>
                            <option>Custom Range</option>
                        </select>
                        <button class="px-4 py-2 rounded-xl bg-green-400 text-green-900 text-sm font-semibold">Generate Financial Report</button>
                    </div>
                </div>
            </header>

            <main class="max-w-7xl mx-auto px-6 py-8 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
                    <div class="bg-white border border-slate-100 rounded-2xl p-5">
                        <div class="text-xs uppercase tracking-widest text-slate-500">Total Revenue</div>
                        <div class="num text-3xl font-bold text-slate-900 mt-3">Rp 4,289,000,000</div>
                        <div class="h-1.5 rounded-full bg-slate-100 mt-3 overflow-hidden"><div class="h-full w-4/5 bg-green-400"></div></div>
                        <div class="text-xs text-green-600 font-semibold mt-2">+14.2% Revenue Growth</div>
                    </div>
                    <div class="bg-white border border-slate-100 rounded-2xl p-5">
                        <div class="text-xs uppercase tracking-widest text-slate-500">Pending Claims</div>
                        <div class="num text-3xl font-bold text-orange-500 mt-3">Rp 842,500,000</div>
                        <div class="text-xs text-slate-500 mt-2">Awaiting BPJS/Insurance validation</div>
                    </div>
                    <div class="bg-white border border-slate-100 rounded-2xl p-5">
                        <div class="text-xs uppercase tracking-widest text-slate-500">Outstanding Patient Bills</div>
                        <div class="num text-3xl font-bold text-red-500 mt-3">Rp 193,200,000</div>
                        <div class="text-xs text-slate-500 mt-2">Unpaid private invoices</div>
                    </div>
                    <div class="bg-white border border-slate-100 rounded-2xl p-5">
                        <div class="text-xs uppercase tracking-widest text-slate-500">Expense Overview</div>
                        <div class="num text-3xl font-bold text-slate-900 mt-3">Rp 2,731,400,000</div>
                        <div class="text-xs text-slate-500 mt-2">Payroll, utilities, pharmacy stock</div>
                    </div>
                </div>

                <div class="grid grid-cols-1 xl:grid-cols-[1.6fr_1fr] gap-6">
                    <section class="space-y-6">
                        <div class="bg-white border border-slate-100 rounded-2xl p-5">
                            <div class="flex items-center justify-between">
                                <h2 class="text-sm uppercase tracking-widest text-slate-500 font-semibold">Revenue Stream Trend</h2>
                                <span class="text-xs text-green-600 font-semibold">IGD • Rawat Jalan • Farmasi</span>
                            </div>
                            <div class="mt-4 h-56 rounded-xl bg-gradient-to-b from-green-100/60 to-transparent relative overflow-hidden">
                                <svg class="absolute inset-0" viewBox="0 0 700 260" preserveAspectRatio="none">
                                    <defs>
                                        <linearGradient id="revA" x1="0" y1="0" x2="0" y2="1">
                                            <stop offset="0%" stop-color="#4ADE80"/>
                                            <stop offset="100%" stop-color="#4ADE80" stop-opacity="0"/>
                                        </linearGradient>
                                    </defs>
                                    <path d="M0 210 C90 180, 150 190, 220 150 C290 110, 360 145, 440 100 C510 65, 590 90, 700 40 L700 260 L0 260 Z" fill="url(#revA)" opacity="0.35"/>
                                    <path d="M0 210 C90 180, 150 190, 220 150 C290 110, 360 145, 440 100 C510 65, 590 90, 700 40" fill="none" stroke="#4ADE80" stroke-width="3"/>
                                </svg>
                            </div>
                        </div>

                        <div class="bg-white border border-slate-100 rounded-2xl overflow-hidden">
                            <div class="bg-slate-50 px-5 py-3 text-xs uppercase tracking-widest text-slate-500">Transaction & Billing Table</div>
                            <div class="overflow-x-auto">
                                <table class="w-full text-sm">
                                    <thead class="text-xs uppercase tracking-widest text-slate-500 bg-slate-50">
                                        <tr class="text-left">
                                            <th class="py-3 px-5">Invoice</th>
                                            <th class="py-3">Patient</th>
                                            <th class="py-3">Service</th>
                                            <th class="py-3">Date</th>
                                            <th class="py-3">Amount</th>
                                            <th class="py-3">Method</th>
                                            <th class="py-3">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr class="border-t border-slate-100 hover:bg-slate-50">
                                            <td class="py-4 px-5 num font-semibold">INV-24091</td>
                                            <td class="py-4">John Doe</td>
                                            <td class="py-4">General Consultation</td>
                                            <td class="py-4">Feb 27, 2026</td>
                                            <td class="py-4 num font-bold">Rp 750,000</td>
                                            <td class="py-4">Insurance</td>
                                            <td class="py-4"><span class="px-3 py-1 rounded-full bg-green-400 text-white text-xs font-semibold">Settled</span></td>
                                        </tr>
                                        <tr class="border-t border-slate-100 hover:bg-slate-50">
                                            <td class="py-4 px-5 num font-semibold">INV-24065</td>
                                            <td class="py-4">Alya Putri</td>
                                            <td class="py-4">Lab Test</td>
                                            <td class="py-4">Feb 25, 2026</td>
                                            <td class="py-4 num font-bold">Rp 420,000</td>
                                            <td class="py-4">Insurance</td>
                                            <td class="py-4"><span class="px-3 py-1 rounded-full bg-sky-400 text-white text-xs font-semibold">Awaiting Insurance</span></td>
                                        </tr>
                                        <tr class="border-t border-slate-100 hover:bg-slate-50">
                                            <td class="py-4 px-5 num font-semibold">INV-24010</td>
                                            <td class="py-4">Budi Santoso</td>
                                            <td class="py-4">Pharmacy Pickup</td>
                                            <td class="py-4">Feb 21, 2026</td>
                                            <td class="py-4 num font-bold">Rp 280,000</td>
                                            <td class="py-4">VA</td>
                                            <td class="py-4"><span class="px-3 py-1 rounded-full bg-red-400 text-white text-xs font-semibold">Unpaid</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </section>

                    <aside class="space-y-6">
                        <div class="bg-white border border-slate-100 rounded-2xl p-5">
                            <h2 class="text-sm uppercase tracking-widest text-slate-500 font-semibold">Insurance Claim Management</h2>
                            <div class="mt-4 space-y-3">
                                <div class="p-3 rounded-xl bg-slate-50 border border-slate-100">
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <p class="text-sm font-semibold text-slate-900">CLM-BPJS-8812</p>
                                            <p class="text-xs text-slate-500">Alya Putri • Rp 420,000</p>
                                        </div>
                                        <span class="text-xs text-sky-600 font-semibold">In Review</span>
                                    </div>
                                    <div class="mt-3 flex gap-2">
                                        <button class="px-3 py-1.5 rounded-lg bg-green-400 text-green-900 text-xs font-semibold">Approve</button>
                                        <button class="px-3 py-1.5 rounded-lg border border-slate-200 text-xs text-slate-600">Upload Document</button>
                                    </div>
                                </div>
                                <div class="p-3 rounded-xl bg-slate-50 border border-slate-100">
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <p class="text-sm font-semibold text-slate-900">CLM-PRU-7704</p>
                                            <p class="text-xs text-slate-500">Dewi Lestari • Rp 1,250,000</p>
                                        </div>
                                        <span class="text-xs text-orange-500 font-semibold">Need Docs</span>
                                    </div>
                                    <div class="mt-3 flex gap-2">
                                        <button class="px-3 py-1.5 rounded-lg bg-green-400 text-green-900 text-xs font-semibold">Approve</button>
                                        <button class="px-3 py-1.5 rounded-lg border border-slate-200 text-xs text-slate-600">Upload Document</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="bg-white border border-slate-100 rounded-2xl p-5">
                            <h2 class="text-sm uppercase tracking-widest text-slate-500 font-semibold">Export & Reporting</h2>
                            <div class="mt-4 grid grid-cols-1 gap-2">
                                <button class="px-4 py-2 rounded-xl bg-green-400 text-green-900 text-sm font-semibold">Generate Financial Report</button>
                                <button class="px-4 py-2 rounded-xl border border-slate-200 text-sm text-slate-600">Export Profit/Loss (PDF)</button>
                                <button class="px-4 py-2 rounded-xl border border-slate-200 text-sm text-slate-600">Export Tax Report (Excel)</button>
                            </div>
                            <div class="mt-4 pt-4 border-t border-slate-100 text-xs text-slate-500">Data synced with billing, insurance, and pharmacy modules.</div>
                        </div>
                    </aside>
                </div>
            </main>
        </div>
    </div>
</body>
</html>
