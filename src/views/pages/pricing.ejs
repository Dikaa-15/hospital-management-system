    <script>
        // Billing Toggle Logic
        const billingBtns = document.querySelectorAll('.billing-btn');
        const toggleIndicator = document.getElementById('toggleIndicator');
        const priceStarter = document.getElementById('price-starter');
        const pricePro = document.getElementById('price-pro');
        
        const pricing = {
            monthly: { starter: '$99', pro: '$299' },
            yearly: { starter: '$79', pro: '$239' }
        };

        billingBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const period = btn.dataset.period;
                
                // Update active state
                billingBtns.forEach(b => b.classList.remove('text-slate-900'));
                btn.classList.add('text-slate-900');

                // Move indicator
                if (period === 'yearly') {
                    toggleIndicator.style.transform = 'translateX(100%)';
                } else {
                    toggleIndicator.style.transform = 'translateX(0)';
                }

                // Update prices with fade effect
                priceStarter.style.opacity = 0;
                pricePro.style.opacity = 0;
                
                setTimeout(() => {
                    priceStarter.textContent = pricing[period].starter;
                    pricePro.textContent = pricing[period].pro;
                    priceStarter.style.opacity = 1;
                    pricePro.style.opacity = 1;
                }, 150);
            });
        });

        // FAQ Accordion Logic
        const faqItems = document.querySelectorAll('.faq-item');

        faqItems.forEach(item => {
            const btn = item.querySelector('.faq-btn');
            btn.addEventListener('click', () => {
                const isOpen = item.classList.contains('open');
                
                // Close all others
                faqItems.forEach(i => i.classList.remove('open'));
                
                // Toggle current
                if (!isOpen) {
                    item.classList.add('open');
                }
            });
        });

        // Set initial active state for toggle text
        document.querySelector('.billing-btn[data-period="monthly"]').classList.add('text-slate-900');
    </script>
</body>
