                                <td class="py-4 px-6 text-center bg-green-50/50"><svg class="w-5 h-5 feature-check mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></td>
                                <td class="py-4 px-6 text-center"><svg class="w-5 h-5 feature-check mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></td>
