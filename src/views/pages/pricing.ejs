                <div class="space-y-4">
                    <!-- FAQ Item 1 -->
                    <div class="faq-item border-slate-200 bg-white rounded-2xl shadow-sm overflow-hidden">
                        <button class="faq-btn w-full px-6 py-5 text-left flex items-center justify-between">
