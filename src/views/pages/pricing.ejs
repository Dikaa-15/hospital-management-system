<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pricing Plans - NextGen Health</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        'jakarta': ['Plus Jakarta Sans', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        :root {
            --bg-dark: #0f172a;
            --bg-light: #f8fafc;
            --accent: #4ade80;
            --accent-dark: #22c55e;
        }

        * {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }

        /* Animations */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        @keyframes pulseBadge {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .animate-fade-in-up {
            animation: fadeInUp 0.6s ease-out forwards;
        }

        .animate-badge-pulse {
            animation: pulseBadge 2s ease-in-out infinite;
        }

        .stagger-1 { animation-delay: 0.1s; opacity: 0; }
        .stagger-2 { animation-delay: 0.2s; opacity: 0; }
        .stagger-3 { animation-delay: 0.3s; opacity: 0; }
        .stagger-4 { animation-delay: 0.4s; opacity: 0; }

        @media (prefers-reduced-motion: reduce) {
            .animate-fade-in-up, .animate-badge-pulse {
                animation: none;
                opacity: 1;
            }
        }

        /* Pricing Card Styles */
        .pricing-card {
            transition: all 0.3s ease;
        }

        .pricing-card:hover {
            transform: translateY(-8px);
        }

        .pricing-card.featured {
            border: 2px solid #4ade80;
            box-shadow: 0 25px 50px -12px rgba(74, 222, 128, 0.25);
        }

        /* Toggle Switch */
        .billing-toggle-container {
            background: rgba(248, 250, 252, 0.8);
            backdrop-filter: blur(10px);
            border: 1px solid #e2e8f0;
        }

        .toggle-indicator {
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Checkmark */
        .feature-check {
            color: #4ade80;
        }

        /* Table */
        .comparison-table th, .comparison-table td {
            border-bottom: 1px solid #f1f5f9;
        }

        .comparison-table tbody tr:hover {
            background: #f8fafc;
        }

        /* FAQ Accordion */
        .faq-item {
            border-bottom: 1px solid #e2e8f0;
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease, padding 0.3s ease;
        }

        .faq-item.open .faq-answer {
            max-height: 500px;
        }

        .faq-item.open .faq-icon {
            transform: rotate(45deg);
        }

        .faq-icon {
            transition: transform 0.2s ease;
        }

        /* Buttons */
        .btn-primary {
            background: var(--accent);
            color: #15803d;
            transition: all 0.2s ease;
        }
        .btn-primary:hover {
            background: var(--accent-dark);
            box-shadow: 0 10px 20px rgba(74, 222, 128, 0.3);
        }

        .btn-secondary {
            background: white;
            border: 1px solid #e2e8f0;
            color: #0f172a;
            transition: all 0.2s ease;
        }
        .btn-secondary:hover {
            border-color: #4ade80;
            color: #15803d;
        }
    </style>
</head>
<body class="bg-white text-slate-900 antialiased">

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-lg border-b border-slate-200">
        <div class="max-w-7xl mx-auto px-6 lg:px-8">
            <div class="flex items-center justify-between h-20">
                <a href="/" class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-green-400 flex items-center justify-center shadow-lg shadow-green-400/30">
                        <svg class="w-6 h-6 text-green-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                        </svg>
                    </div>
                    <span class="text-xl font-bold text-slate-900">NextGen Health</span>
                </a>
                <div class="hidden md:flex items-center gap-8">
                    <a href="/#features" class="text-sm font-medium text-slate-600 hover:text-slate-900">Features</a>
                    <a href="/pricing" class="text-sm font-semibold text-slate-900">Pricing</a>
                    <a href="/#about" class="text-sm font-medium text-slate-600 hover:text-slate-900">About</a>
                </div>
                <div class="flex items-center gap-4">
                    <a href="/login" class="text-sm font-semibold text-slate-700 hover:text-slate-900">Login</a>
                    <a href="/templates/auth/sign-up" class="btn-primary px-5 py-2.5 rounded-xl text-sm font-semibold">Start Free Trial</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="pt-20">
        <!-- Header Section -->
        <section class="py-24 text-center">
            <div class="max-w-4xl mx-auto px-6 animate-fade-in-up">
