        </section>

        <!-- FAQ Section -->
        <section class="py-24">
            <div class="max-w-3xl mx-auto px-6 lg:px-8">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight mb-4">
                        Frequently Asked Questions
