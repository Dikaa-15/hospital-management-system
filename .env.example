PORT=3000
NODE_ENV=development
SESSION_SECRET=replace-with-strong-secret
SESSION_COOKIE_NAME=hms.sid
SESSION_MAX_AGE_MS=28800000
SESSION_STORE=memory
AUDIT_LOG_ENABLED=true

# auth mode: demo | db
AUTH_MODE=demo

# MySQL config (used when AUTH_MODE=db)
DB_HOST=127.0.0.1
DB_PORT=8889
DB_USER=root
DB_PASSWORD=
DB_NAME=hms
DB_PREFER_IPV4=true
DB_CONNECT_TIMEOUT_MS=10000
# Optional socket path for local MySQL on macOS/Linux (if TCP is disabled)
# DB_SOCKET_PATH=/tmp/mysql.sock

# Supabase (optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
